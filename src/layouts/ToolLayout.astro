---
import PageLayout from "@layouts/PageLayout.astro";
import CTASection from "@components/CTASection.astro";
import ToolCard from "@components/ToolCard.astro";
import { getCollection } from "astro:content";
import { generateWebApplicationSchema, generateBreadcrumbSchema, generateFAQSchema } from "@utils/seo";

interface Props {
  title: string;
  headline: string;
  description: string;
  category: string;
  icon: string;
  relatedTags?: string[];
  slug: string;
  lastUpdated?: string;
  faqItems?: { question: string; answer: string }[];
  relatedTools?: { name: string; slug: string; icon: string }[];
  featureList?: string[];
}

const {
  title,
  headline,
  description,
  category,
  icon,
  relatedTags = [],
  slug,
  lastUpdated,
  faqItems = [],
  relatedTools = [],
  featureList = [],
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://joinclearcareer.com";
const toolUrl = `${siteUrl}/free-tools/${slug}`;

const appCategoryMap: Record<string, string> = {
  "Financial Planning": "FinanceApplication",
  "Job Search": "BusinessApplication",
  "Interview & Resume": "BusinessApplication",
};

// Get related blog posts
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter((post) => post.data.tags.some((tag: string) => relatedTags.includes(tag)))
  .sort(
    (a, b) =>
      new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
  )
  .slice(0, 3);
---

<PageLayout title={`${title} | ClearCareer`} description={description}>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(
      generateWebApplicationSchema({
        name: headline,
        description,
        url: toolUrl,
        category: appCategoryMap[category] || "BusinessApplication",
        featureList: featureList.length > 0 ? featureList : undefined,
      })
    )}
  />

  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(
      generateBreadcrumbSchema([
        { name: "Home", url: siteUrl },
        { name: "Free Tools", url: `${siteUrl}/free-tools` },
        { name: headline, url: toolUrl },
      ])
    )}
  />

  {faqItems.length > 0 && (
    <script
      type="application/ld+json"
      slot="head"
      set:html={JSON.stringify(generateFAQSchema(faqItems))}
    />
  )}

  <!-- Hero (compact) -->
  <section class="bg-blue-bg py-8 md:py-10">
    <div class="mx-auto max-w-[1080px] px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-4 text-sm text-text-muted">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-blue">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/free-tools" class="hover:text-blue">Free Tools</a></li>
          <li aria-hidden="true">/</li>
          <li class="truncate text-text" aria-current="page">{headline}</li>
        </ol>
      </nav>

      <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <div>
          <div class="flex items-center gap-3">
            <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-xs font-medium text-blue">
              <span>{icon}</span> {category}
            </span>
            {lastUpdated && (
              <span class="text-xs text-text-muted">
                Updated {lastUpdated}
              </span>
            )}
          </div>
          <h1 class="mt-3 font-display text-[clamp(1.75rem,4vw,2.5rem)] leading-[1.1] text-navy">
            {headline}
          </h1>
          <p class="mt-2 max-w-[640px] text-[1rem] leading-[1.6] text-text-muted">
            {description}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tool (full-width framed card, immediately after hero) -->
  <section class="py-8 md:py-12">
    <div class="mx-auto max-w-[1080px] px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border-2 border-blue/20 bg-white p-6 shadow-sm md:p-8">
        <slot />
      </div>
    </div>
  </section>

  <!-- Intro (blue card, badge 01) — below tool -->
  {Astro.slots.has('intro') && (
    <section class="py-8 md:py-10">
      <div class="mx-auto max-w-[720px] px-4 sm:px-6 lg:px-8">
        <div class="rounded-xl border border-border/60 bg-white p-6 shadow-sm md:p-8" style="border-left: 4px solid var(--color-blue)">
          <span class="mb-4 flex h-8 w-8 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">01</span>
          <slot name="intro" />
        </div>
      </div>
    </section>
  )}

  <!-- Methodology (teal card, badge 02) -->
  {Astro.slots.has('methodology') && (
    <section class="py-8 md:py-10">
      <div class="mx-auto max-w-[720px] px-4 sm:px-6 lg:px-8">
        <div class="rounded-xl border border-teal/20 bg-teal-bg p-6 shadow-sm md:p-8" style="border-left: 4px solid var(--color-teal)">
          <span class="mb-4 flex h-8 w-8 items-center justify-center rounded-full bg-teal text-xs font-bold text-white">02</span>
          <slot name="methodology" />
        </div>
      </div>
    </section>
  )}

  <!-- Example (amber card, badge 03) -->
  {Astro.slots.has('example') && (
    <section class="py-8 md:py-10">
      <div class="mx-auto max-w-[720px] px-4 sm:px-6 lg:px-8">
        <div class="rounded-xl border border-warning/20 bg-amber-bg p-6 shadow-sm md:p-8" style="border-left: 4px solid var(--color-warning)">
          <span class="mb-4 flex h-8 w-8 items-center justify-center rounded-full bg-warning text-xs font-bold text-white">03</span>
          <slot name="example" />
        </div>
      </div>
    </section>
  )}

  <!-- Tips (navy card, badge 04) -->
  {Astro.slots.has('tips') && (
    <section class="py-8 md:py-10">
      <div class="mx-auto max-w-[720px] px-4 sm:px-6 lg:px-8">
        <div class="rounded-xl border border-border/60 bg-white p-6 shadow-sm md:p-8" style="border-left: 4px solid var(--color-navy)">
          <span class="mb-4 flex h-8 w-8 items-center justify-center rounded-full bg-navy text-xs font-bold text-white">04</span>
          <slot name="tips" />
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  {faqItems.length > 0 && (
    <section class="border-t border-border py-12 md:py-16">
      <div class="mx-auto max-w-[720px] px-4 sm:px-6 lg:px-8">
        <h2 class="font-display text-[clamp(1.5rem,3vw,2.25rem)] leading-[1.15] text-navy">
          Frequently Asked Questions
        </h2>
        <div class="mt-8 space-y-4">
          {faqItems.map((item) => (
            <details class="group rounded-xl border border-border bg-white p-6 transition-shadow hover:shadow-sm">
              <summary class="cursor-pointer list-none text-lg font-semibold text-navy [&::-webkit-details-marker]:hidden">
                <div class="flex items-center justify-between gap-4">
                  <span>{item.question}</span>
                  <svg
                    class="h-5 w-5 flex-shrink-0 text-blue transition-transform group-open:rotate-180"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </div>
              </summary>
              <p class="mt-4 text-[1.0625rem] leading-[1.75] text-text-muted">
                {item.answer}
              </p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Tools -->
  {relatedTools.length > 0 && (
    <section class="bg-blue-bg py-12 md:py-16">
      <div class="mx-auto max-w-[720px] px-4 sm:px-6 lg:px-8">
        <h2 class="text-xl font-bold text-navy">Related Tools</h2>
        <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {relatedTools.map((tool) => (
            <a
              href={`/free-tools/${tool.slug}`}
              class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md"
            >
              <span class="text-2xl">{tool.icon}</span>
              <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">{tool.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Articles -->
  {relatedPosts.length > 0 && (
    <section class="border-t border-border py-12 md:py-16">
      <div class="mx-auto max-w-[720px] px-4 sm:px-6 lg:px-8">
        <h2 class="text-xl font-bold text-navy">Related Articles</h2>
        <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-3">
          {relatedPosts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group rounded-lg border border-border p-4 transition-shadow hover:shadow-md"
            >
              <h3 class="text-sm font-semibold text-navy group-hover:text-blue transition-colors line-clamp-2">
                {post.data.title}
              </h3>
              <p class="mt-2 text-xs text-text-muted line-clamp-2">
                {post.data.description}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTASection
    heading="Want a Personalized Strategy for Your Job Search?"
    primaryCTA={{
      text: "Book a Free Audit",
      href: "https://calendly.com/clearcareer/discovery-call",
    }}
    variant="blue"
  />
</PageLayout>
