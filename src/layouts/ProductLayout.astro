---
import BaseLayout from "@layouts/BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  headline: string;
  subheadline?: string;
  bullets?: string[];
  price: string;
  originalPrice?: string;
  ctaText?: string;
  ctaHref: string;
  guaranteeText?: string;
  faq?: { q: string; a: string }[];
}

const {
  title,
  description,
  headline,
  subheadline,
  bullets = [],
  price,
  originalPrice,
  ctaText = "Get Instant Access",
  ctaHref,
  guaranteeText = "30-day money-back guarantee. No questions asked.",
  faq = [],
} = Astro.props;

const currentYear = new Date().getFullYear();
---

<BaseLayout title={title} description={description} type="website">
  <div class="min-h-screen bg-white">
    <!-- Minimal Header -->
    <header class="border-b border-border/50 bg-white">
      <div class="mx-auto max-w-[720px] px-4 py-4 text-center">
        <a href="/" class="text-lg font-bold text-blue">ClearCareer</a>
      </div>
    </header>

    <!-- Hero -->
    <section class="bg-gradient-to-b from-blue-bg/50 to-white py-12 md:py-16">
      <div class="mx-auto max-w-[640px] px-4 text-center">
        <h1 class="font-display text-[clamp(1.75rem,4vw,2.75rem)] leading-[1.1] text-navy">
          <Fragment set:html={headline} />
        </h1>
        {subheadline && (
          <p class="mx-auto mt-4 max-w-lg text-lg leading-relaxed text-text-muted">
            {subheadline}
          </p>
        )}

        {bullets.length > 0 && (
          <ul class="mx-auto mt-6 max-w-md space-y-3 text-left">
            {bullets.map((bullet) => (
              <li class="flex items-start gap-3 text-[1.0625rem] text-text">
                <svg class="mt-1 h-5 w-5 flex-shrink-0 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        )}

        <!-- Price + CTA -->
        <div class="mt-8">
          <div class="flex items-center justify-center gap-3">
            <span class="text-3xl font-bold text-navy">{price}</span>
            {originalPrice && (
              <span class="text-lg text-text-muted line-through">{originalPrice}</span>
            )}
          </div>
          <a
            href={ctaHref}
            class="mt-4 inline-flex items-center justify-center rounded-lg bg-blue px-8 py-4 text-lg font-semibold text-white shadow-md transition-colors hover:bg-blue-dark"
          >
            {ctaText}
          </a>
          <p class="mt-3 flex items-center justify-center gap-2 text-sm text-text-muted">
            <svg class="h-4 w-4 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            {guaranteeText}
          </p>
        </div>

        <!-- Social Proof -->
        <p class="mt-6 text-sm font-medium text-text-muted">
          200+ professionals coached · $1.2M+ in collective raises
        </p>
      </div>
    </section>

    <!-- Product Preview / Content -->
    <section class="py-8 md:py-12">
      <div class="mx-auto max-w-[720px] px-4">
        <slot name="preview" />
      </div>
    </section>

    <!-- Testimonial / Social Proof -->
    <slot name="testimonial" />

    <!-- FAQ -->
    {faq.length > 0 && (
      <section class="bg-blue-bg/30 py-12">
        <div class="mx-auto max-w-[640px] px-4">
          <h2 class="mb-8 text-center text-xl font-bold text-navy">Frequently Asked Questions</h2>
          <div class="space-y-4">
            {faq.map(({ q, a }) => (
              <details class="group rounded-xl border border-border bg-white px-6 py-4">
                <summary class="flex cursor-pointer items-center justify-between font-semibold text-navy">
                  {q}
                  <svg class="h-5 w-5 shrink-0 text-text-muted transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <p class="mt-3 text-sm leading-relaxed text-text-muted">{a}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Bottom CTA -->
    <section class="py-12 text-center">
      <div class="mx-auto max-w-[480px] px-4">
        <div class="flex items-center justify-center gap-3">
          <span class="text-3xl font-bold text-navy">{price}</span>
          {originalPrice && (
            <span class="text-lg text-text-muted line-through">{originalPrice}</span>
          )}
        </div>
        <a
          href={ctaHref}
          class="mt-4 inline-flex items-center justify-center rounded-lg bg-blue px-8 py-4 text-lg font-semibold text-white shadow-md transition-colors hover:bg-blue-dark"
        >
          {ctaText}
        </a>
        <p class="mt-3 flex items-center justify-center gap-2 text-sm text-text-muted">
          <svg class="h-4 w-4 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          {guaranteeText}
        </p>
      </div>
    </section>

    <!-- Minimal Footer -->
    <footer class="border-t border-border/50 py-6 text-center">
      <p class="text-xs text-text-muted">&copy; {currentYear} ClearCareer. All rights reserved.</p>
    </footer>
  </div>
</BaseLayout>
