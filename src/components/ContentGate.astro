---
interface Props {
  source?: string;
  storageKey?: string;
}

const { source = 'make-it-count', storageKey = 'makeitcount_unlocked' } = Astro.props;
---

<div id="content-gate" class="my-12" data-source={source} data-storage-key={storageKey}>
  <!-- Gate -->
  <div class="rounded-xl border-2 border-blue/30 bg-blue-bg p-8 text-center sm:p-10">
    <div class="mx-auto max-w-lg">
      <div class="mb-4 text-4xl">🔓</div>
      <h3 class="font-display text-2xl leading-tight text-navy sm:text-3xl">
        Unlock the Full Guide + All 10 AI Prompts
      </h3>
      <p class="mx-auto mt-3 max-w-md text-base leading-relaxed text-text-muted sm:text-lg">
        Enter your email to access the complete playbook with frameworks, real coaching examples, and copy-paste prompts.
      </p>

      <form id="gate-form" class="mx-auto mt-6 flex max-w-md flex-col gap-3 sm:flex-row">
        <label for="gate-email" class="sr-only">Email address</label>
        <input
          id="gate-email"
          type="email"
          placeholder="your@email.com"
          required
          class="flex-1 rounded-lg border border-border bg-white px-4 py-3 text-text placeholder:text-text-muted focus:border-blue focus:outline-none focus:ring-2 focus:ring-blue/20"
        />
        <button
          type="submit"
          id="gate-btn"
          class="rounded-lg bg-blue px-6 py-3 font-semibold text-white transition-colors hover:bg-blue-dark disabled:cursor-not-allowed disabled:opacity-60"
        >
          Unlock the Guide
        </button>
      </form>

      <p class="mt-3 text-xs text-text-muted">
        Plus one career tip per week. Unsubscribe anytime.
      </p>
    </div>
  </div>

  <!-- Blurred Preview -->
  <div class="relative mt-8 overflow-hidden rounded-xl">
    <div class="pointer-events-none select-none blur-sm opacity-50" aria-hidden="true">
      <div class="prose prose-lg max-w-none">
        <h2>Find Your Numbers: The 5 Dimensions</h2>
        <p>When I coach people through achievement mining, I use five dimensions. These are five different lenses for finding numbers in any role...</p>
        <h3>1. Volume: How Many?</h3>
        <p>This is the most straightforward dimension. How many projects did you complete?...</p>
        <h3>2. Time: How Fast? How Long?</h3>
        <p>Time is money, and employers know it...</p>
      </div>
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-white/80 to-white"></div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var gate = document.getElementById('content-gate');
    var form = document.getElementById('gate-form');
    var btn = document.getElementById('gate-btn');
    var input = document.getElementById('gate-email');
    var gatedContent = document.querySelector('.gated-content');
    var storageKey = gate ? gate.dataset.storageKey : 'makeitcount_unlocked';
    var source = gate ? gate.dataset.source : 'make-it-count';

    function unlock() {
      if (gate) gate.style.display = 'none';
      if (gatedContent) gatedContent.style.display = 'block';
    }

    // Check on load
    if (localStorage.getItem(storageKey) === 'true') {
      unlock();
    }

    // Form submit
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var email = input ? input.value : '';
        if (!email || !btn) return;

        btn.textContent = 'Sending...';
        btn.setAttribute('disabled', 'true');

        fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, source: source }),
        })
        .then(function(res) {
          if (res.ok) {
            localStorage.setItem(storageKey, 'true');
            btn.textContent = 'Unlocked!';
            setTimeout(unlock, 500);
          } else {
            btn.textContent = 'Try Again';
            btn.removeAttribute('disabled');
          }
        })
        .catch(function() {
          btn.textContent = 'Try Again';
          btn.removeAttribute('disabled');
        });
      });
    }
  });
</script>
