---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;
---

<!-- FAQ Schema.org JSON-LD -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: items.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  })}
/>

<section class={`mt-12 border-t border-border pt-10 ${className}`}>
  <h2 class="font-display text-[clamp(1.5rem,3vw,2.25rem)] leading-[1.15] text-navy">
    Frequently Asked Questions
  </h2>

  <div class="mt-8 space-y-6">
    {items.map((item) => (
      <details class="group rounded-xl border border-border bg-white p-6 transition-shadow hover:shadow-sm">
        <summary class="cursor-pointer list-none text-lg font-semibold text-navy [&::-webkit-details-marker]:hidden">
          <div class="flex items-center justify-between gap-4">
            <span>{item.question}</span>
            <svg
              class="h-5 w-5 flex-shrink-0 text-blue transition-transform group-open:rotate-180"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
        </summary>
        <p class="mt-4 text-[1.0625rem] leading-[1.75] text-text-muted">
          {item.answer}
        </p>
      </details>
    ))}
  </div>
</section>
