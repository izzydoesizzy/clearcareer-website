---
interface Props {
  id: string;
  visibleCount?: number;
  autoPlay?: boolean;
  autoPlayInterval?: number;
}

const {
  id,
  visibleCount = 3,
  autoPlay = false,
  autoPlayInterval = 5000,
} = Astro.props;
---

<div
  class="testimonial-carousel relative"
  data-carousel={id}
  data-visible={visibleCount}
  data-autoplay={autoPlay}
  data-interval={autoPlayInterval}
>
  {/* Track */}
  <div class="overflow-hidden">
    <div class="flex transition-transform duration-500 ease-out" data-carousel-track={id}>
      <slot />
    </div>
  </div>

  {/* Navigation */}
  <div class="mt-6 flex items-center justify-center gap-4">
    <button
      data-carousel-prev={id}
      class="flex h-10 w-10 items-center justify-center rounded-full border border-border bg-white text-text-muted shadow-sm transition-all hover:border-blue hover:text-blue hover:shadow-md"
      aria-label="Previous testimonial"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <div class="flex gap-2" data-carousel-dots={id}></div>

    <button
      data-carousel-next={id}
      class="flex h-10 w-10 items-center justify-center rounded-full border border-border bg-white text-text-muted shadow-sm transition-all hover:border-blue hover:text-blue hover:shadow-md"
      aria-label="Next testimonial"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </button>
  </div>
</div>

<script>
  document.querySelectorAll('.testimonial-carousel').forEach(carousel => {
    const el = carousel as HTMLElement;
    const id = el.dataset.carousel!;
    const maxVisible = parseInt(el.dataset.visible || '3');
    const shouldAutoPlay = el.dataset.autoplay === 'true';
    const interval = parseInt(el.dataset.interval || '5000');

    const track = el.querySelector(`[data-carousel-track="${id}"]`) as HTMLElement;
    const dotsContainer = el.querySelector(`[data-carousel-dots="${id}"]`) as HTMLElement;
    const prevBtn = el.querySelector(`[data-carousel-prev="${id}"]`) as HTMLElement;
    const nextBtn = el.querySelector(`[data-carousel-next="${id}"]`) as HTMLElement;

    if (!track) return;

    // Get all direct children as slides
    const slides = Array.from(track.children) as HTMLElement[];
    const totalSlides = slides.length;

    // Responsive visible count
    function getVisibleCount(): number {
      const width = window.innerWidth;
      if (width < 640) return 1;
      if (width < 1024) return Math.min(2, maxVisible);
      return maxVisible;
    }

    let currentIndex = 0;
    let visibleCount = getVisibleCount();

    // Style slides
    function styleSlides() {
      visibleCount = getVisibleCount();
      const gap = 20; // 1.25rem
      const slideWidth = `calc((100% - ${gap * (visibleCount - 1)}px) / ${visibleCount})`;

      slides.forEach(slide => {
        slide.style.flex = `0 0 ${slideWidth}`;
        slide.style.minWidth = slideWidth;
        slide.style.paddingRight = `${gap}px`;
      });

      // Remove padding from last visible
      if (slides.length > 0) {
        slides[slides.length - 1].style.paddingRight = '0px';
      }
    }

    // Calculate max index
    function getMaxIndex(): number {
      return Math.max(0, totalSlides - visibleCount);
    }

    // Build dots
    function buildDots() {
      dotsContainer.innerHTML = '';
      const dotCount = getMaxIndex() + 1;
      for (let i = 0; i < dotCount; i++) {
        const dot = document.createElement('button');
        dot.className = `h-2.5 w-2.5 rounded-full transition-colors ${i === currentIndex ? 'bg-blue' : 'bg-border'}`;
        dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
        dot.addEventListener('click', () => goToSlide(i));
        dotsContainer.appendChild(dot);
      }
    }

    function goToSlide(index: number) {
      const maxIdx = getMaxIndex();
      currentIndex = Math.max(0, Math.min(index, maxIdx));

      // Calculate offset
      if (totalSlides > 0) {
        const gap = 20;
        const slideWidthPercent = 100 / visibleCount;
        const gapOffset = (currentIndex * gap * (visibleCount - 1)) / visibleCount;
        const offset = currentIndex * slideWidthPercent;
        track.style.transform = `translateX(calc(-${offset}% - ${currentIndex * gap}px + ${gapOffset}px))`;
      }

      // Update dots
      const dots = dotsContainer.children;
      for (let i = 0; i < dots.length; i++) {
        dots[i].classList.toggle('bg-blue', i === currentIndex);
        dots[i].classList.toggle('bg-border', i !== currentIndex);
      }
    }

    // Event listeners
    prevBtn?.addEventListener('click', () => goToSlide(currentIndex - 1));
    nextBtn?.addEventListener('click', () => goToSlide(currentIndex + 1));

    // Touch/swipe support
    let touchStartX = 0;
    let touchEndX = 0;

    track.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    track.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) goToSlide(currentIndex + 1);
        else goToSlide(currentIndex - 1);
      }
    }, { passive: true });

    // Auto-play
    let autoPlayTimer: ReturnType<typeof setInterval> | null = null;

    if (shouldAutoPlay) {
      autoPlayTimer = setInterval(() => {
        const maxIdx = getMaxIndex();
        goToSlide(currentIndex >= maxIdx ? 0 : currentIndex + 1);
      }, interval);

      el.addEventListener('mouseenter', () => {
        if (autoPlayTimer) clearInterval(autoPlayTimer);
      });
      el.addEventListener('mouseleave', () => {
        autoPlayTimer = setInterval(() => {
          const maxIdx = getMaxIndex();
          goToSlide(currentIndex >= maxIdx ? 0 : currentIndex + 1);
        }, interval);
      });
      el.addEventListener('focusin', () => {
        if (autoPlayTimer) clearInterval(autoPlayTimer);
      });
      el.addEventListener('focusout', () => {
        autoPlayTimer = setInterval(() => {
          const maxIdx = getMaxIndex();
          goToSlide(currentIndex >= maxIdx ? 0 : currentIndex + 1);
        }, interval);
      });
    }

    // Responsive resize
    window.addEventListener('resize', () => {
      styleSlides();
      buildDots();
      goToSlide(Math.min(currentIndex, getMaxIndex()));
    });

    // Init
    styleSlides();
    buildDots();
    goToSlide(0);
  });
</script>
