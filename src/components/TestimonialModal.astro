---
// This component renders an empty modal shell.
// Content is populated via JS from data attributes on the testimonial cards.
---

<div
  id="testimonial-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-navy/60 backdrop-blur-sm p-4"
  role="dialog"
  aria-modal="true"
  aria-label="Full testimonial"
>
  <div
    id="modal-content"
    class="relative w-full max-w-lg max-h-[85vh] overflow-y-auto rounded-2xl bg-white p-8 shadow-2xl"
  >
    {/* Close Button */}
    <button
      id="modal-close"
      class="absolute right-4 top-4 flex h-8 w-8 items-center justify-center rounded-full text-text-muted transition-colors hover:bg-gray-100 hover:text-navy"
      aria-label="Close"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    {/* Outcome Badge */}
    <div id="modal-outcome" class="mb-4 hidden">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-success/10 px-3 py-1 text-xs font-semibold text-success">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        <span id="modal-outcome-text"></span>
      </span>
    </div>

    {/* Full Quote */}
    <blockquote class="mb-6">
      <p id="modal-quote" class="text-[1.0625rem] leading-[1.85] text-text"></p>
    </blockquote>

    {/* Author */}
    <div class="flex items-center gap-3 border-t border-border pt-5">
      <div id="modal-avatar" class="h-11 w-11 shrink-0 overflow-hidden rounded-full"></div>
      <div class="min-w-0">
        <p id="modal-name" class="text-sm font-semibold text-navy"></p>
        <p id="modal-role" class="text-sm text-text-muted"></p>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('testimonial-modal')!;
  const modalContent = document.getElementById('modal-content')!;
  const modalQuote = document.getElementById('modal-quote')!;
  const modalName = document.getElementById('modal-name')!;
  const modalRole = document.getElementById('modal-role')!;
  const modalAvatar = document.getElementById('modal-avatar')!;
  const modalOutcome = document.getElementById('modal-outcome')!;
  const modalOutcomeText = document.getElementById('modal-outcome-text')!;
  const modalClose = document.getElementById('modal-close')!;

  // Store testimonial data for modal population
  const testimonialData: Record<string, {
    quote: string;
    name: string;
    role: string;
    outcome: string;
    image: string;
    initials: string;
    color: string;
  }> = {};

  // Collect data from hidden data elements
  document.querySelectorAll('[data-testimonial-full]').forEach(el => {
    const htmlEl = el as HTMLElement;
    const idx = htmlEl.dataset.testimonialFull!;
    testimonialData[idx] = {
      quote: htmlEl.dataset.quote || '',
      name: htmlEl.dataset.name || '',
      role: htmlEl.dataset.role || '',
      outcome: htmlEl.dataset.outcome || '',
      image: htmlEl.dataset.image || '',
      initials: htmlEl.dataset.initials || '',
      color: htmlEl.dataset.color || 'bg-blue',
    };
  });

  function openModal(index: string) {
    const data = testimonialData[index];
    if (!data) return;

    modalQuote.innerHTML = `\u201C${data.quote}\u201D`;
    modalName.textContent = data.name;
    modalRole.textContent = data.role;

    if (data.outcome) {
      modalOutcomeText.textContent = data.outcome;
      modalOutcome.classList.remove('hidden');
    } else {
      modalOutcome.classList.add('hidden');
    }

    if (data.image) {
      modalAvatar.innerHTML = `<img src="${data.image}" alt="${data.name}" class="h-full w-full object-cover object-top ring-2 ring-blue/20 rounded-full" />`;
    } else {
      modalAvatar.innerHTML = `<div class="flex h-11 w-11 items-center justify-center rounded-full bg-blue text-sm font-semibold text-white">${data.initials}</div>`;
    }

    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  // Open handlers
  document.querySelectorAll('.testimonial-open-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const index = (btn as HTMLElement).dataset.index;
      if (index) openModal(index);
    });
  });

  // Close handlers
  modalClose.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });
</script>
