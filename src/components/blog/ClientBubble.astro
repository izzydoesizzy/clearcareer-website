---
const letters = 'ABCDEFGHJKLMNPQRSTUVWXYZ';
const letter = letters[Math.floor(Math.random() * letters.length)];
---

<div class="imsg-client not-prose flex justify-start my-2">
  <div class="flex items-end gap-2 max-w-[80%]">
    <div class="w-8 h-8 rounded-full bg-gray-300 flex-shrink-0 flex items-center justify-center">
      <span class="text-xs font-bold text-gray-600">{letter}</span>
    </div>
    <div class="rounded-2xl rounded-bl-sm bg-[#e5e5ea] px-4 py-2.5">
      <p class="text-[0.9375rem] leading-relaxed text-[#1B2A4A] m-0"><slot /></p>
    </div>
  </div>
</div>
