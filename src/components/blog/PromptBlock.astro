---
import CopyButton from '@components/CopyButton.astro'

interface Props {
  id: string;
  label?: string;
}

const { id, label = "AI Prompt" } = Astro.props;
---

<div class="prompt-block not-prose">
  <div class="flex items-center justify-between gap-2 mb-3">
    <div class="flex items-center gap-2">
      <svg class="h-4 w-4 text-blue flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
      </svg>
      <span class="text-xs font-semibold uppercase tracking-wider text-blue">{label}</span>
    </div>
    <span class="text-[0.6875rem] text-text-muted hidden sm:inline">Works with ChatGPT, Claude, or any AI assistant</span>
  </div>
  <div id={id} class="prompt-block-content text-[0.9375rem] leading-relaxed text-navy">
    <slot />
  </div>
  <div class="mt-3 flex items-center justify-between gap-2">
    <span class="text-[0.6875rem] text-text-muted sm:hidden">Works with ChatGPT, Claude, or any AI</span>
    <div class="ml-auto">
      <CopyButton targetId={id} label="Copy Prompt" />
    </div>
  </div>
</div>
