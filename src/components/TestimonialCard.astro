---
interface Props {
  name: string;
  role: string;
  quote: string;
  outcome?: string;
  tagline?: string;
  image?: string;
  color?: string;
}

const {
  name,
  role,
  quote,
  outcome,
  tagline,
  image,
  color = "bg-blue",
} = Astro.props;

const initials = name
  .split(" ")
  .map((n) => n[0])
  .join("")
  .toUpperCase()
  .slice(0, 2);

const isLongQuote = quote.length > 280;
---

<div class:list={[
  "rounded-xl border bg-white p-6 transition-shadow duration-300",
  outcome ? "border-l-4 border-l-success border-t-border border-r-border border-b-border" : "border-border",
  "shadow-[0_4px_24px_-4px_rgba(1,97,239,0.10)] hover:shadow-[0_8px_40px_-4px_rgba(1,97,239,0.18)]",
]}>
  {/* Tagline */}
  {tagline && (
    <p class="mb-3 text-base font-bold leading-snug text-navy">
      {tagline}
    </p>
  )}

  {/* Outcome Badge */}
  {
    outcome && (
      <div class="mb-4">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-success/10 px-3 py-1 text-xs font-semibold text-success">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          {outcome}
        </span>
      </div>
    )
  }

  {/* Quote */}
  <blockquote data-expanded="false" class="relative">
    <span class:list={[
      "block text-[1.0625rem] leading-[1.75] text-text transition-all duration-300",
      isLongQuote && "line-clamp-4 data-[expanded=true]:line-clamp-none",
    ]} data-quote-text>
      &ldquo;{quote}&rdquo;
    </span>
    {isLongQuote && (
      <button
        class="mt-2 text-sm font-semibold text-blue hover:text-blue-dark transition-colors"
        data-readmore-btn
      >
        Read more
      </button>
    )}
  </blockquote>

  {/* Author */}
  <div class="mt-6 flex items-center gap-3">
    {image ? (
      <div class="h-10 w-10 shrink-0 overflow-hidden rounded-full ring-2 ring-blue/20">
        <img
          src={image}
          alt={name}
          width="40"
          height="40"
          class="h-full w-full object-cover object-top"
          loading="lazy"
        />
      </div>
    ) : (
      <div
        class:list={[
          "flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-sm font-semibold text-white",
          color,
        ]}
      >
        {initials}
      </div>
    )}
    <div class="min-w-0">
      <p class="truncate text-sm font-semibold text-text">{name}</p>
      <p class="truncate text-sm text-text-muted">{role}</p>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('[data-readmore-btn]').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('blockquote');
      if (!card) return;
      const quoteText = card.querySelector('[data-quote-text]') as HTMLElement;
      if (!quoteText) return;
      const isExpanded = card.dataset.expanded === 'true';
      card.dataset.expanded = String(!isExpanded);
      if (!isExpanded) {
        quoteText.classList.remove('line-clamp-4');
      } else {
        quoteText.classList.add('line-clamp-4');
      }
      (btn as HTMLElement).textContent = !isExpanded ? 'Show less' : 'Read more';
    });
  });
</script>
