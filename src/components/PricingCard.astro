---
interface Props {
  tier: string;
  price: string;
  originalPrice?: string;
  features: string[];
  ctaText: string;
  ctaHref: string;
  featured?: boolean;
  paymentPlan?: string;
}

const {
  tier,
  price,
  originalPrice,
  features,
  ctaText,
  ctaHref,
  featured = false,
  paymentPlan,
} = Astro.props;
---

<div
  class:list={[
    "relative rounded-xl border p-8 transition-shadow duration-300 hover:shadow-[0_8px_40px_-4px_rgba(1,97,239,0.18)]",
    featured
      ? "border-blue bg-white shadow-[0_4px_24px_-4px_rgba(1,97,239,0.15)] ring-2 ring-blue"
      : "border-border bg-white shadow-[0_4px_24px_-4px_rgba(1,97,239,0.10)]",
  ]}
>
  {
    featured && (
      <div class="absolute -top-3 left-1/2 -translate-x-1/2">
        <span class="rounded-full bg-blue px-4 py-1 text-xs font-semibold text-white">
          Most Popular
        </span>
      </div>
    )
  }

  <!-- Tier Name -->
  <h3 class="text-lg font-semibold text-text">{tier}</h3>

  <!-- Price -->
  <div class="mt-4 flex items-baseline gap-2">
    <span class="text-[clamp(2rem,4vw,2.75rem)] font-bold leading-none text-navy">
      {price}
    </span>
    {
      originalPrice && (
        <span class="text-lg text-text-muted line-through">
          {originalPrice}
        </span>
      )
    }
  </div>

  {
    paymentPlan && (
      <p class="mt-1 text-sm text-text-muted">{paymentPlan}</p>
    )
  }

  <!-- Features -->
  <ul class="mt-8 space-y-3">
    {
      features.map((feature) => (
        <li class="flex items-start gap-3 text-sm text-text">
          <svg
            class="mt-0.5 h-5 w-5 flex-shrink-0 text-success"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span>{feature}</span>
        </li>
      ))
    }
  </ul>

  <!-- CTA -->
  <div class="mt-8">
    <a
      href={ctaHref}
      class:list={[
        "block w-full rounded-lg px-6 py-3 text-center text-base font-semibold transition-colors",
        featured
          ? "bg-blue text-white hover:bg-blue-dark"
          : "border-2 border-blue bg-white text-blue hover:bg-blue-bg",
      ]}
    >
      {ctaText}
    </a>
  </div>
</div>
