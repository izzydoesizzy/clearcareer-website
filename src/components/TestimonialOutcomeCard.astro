---
interface Props {
  name: string;
  role: string;
  quote: string;
  tagline: string;
  outcome?: string;
  image?: string;
  index?: number;
  showReadMore?: boolean;
}

const {
  name,
  role,
  quote,
  tagline,
  outcome,
  image,
  index = 0,
  showReadMore = false,
} = Astro.props;

const initials = name
  .split(" ")
  .map((n) => n[0])
  .join("")
  .toUpperCase()
  .slice(0, 2);

// Truncate quote to ~120 chars at a word boundary
const snippetLength = 120;
const snippet =
  quote.length > snippetLength
    ? quote.slice(0, quote.lastIndexOf(" ", snippetLength)) + "..."
    : quote;

// One-line outcome
const shortOutcome = tagline.split('.')[0].trim();
---

<div
  class="rounded-2xl bg-white p-6 shadow-[0_8px_30px_-4px_rgba(0,0,0,0.08)] hover:shadow-[0_12px_40px_-4px_rgba(0,0,0,0.12)] transition-shadow duration-300 flex flex-col"
  data-testimonial-index={index}
>
  {/* Author row */}
  <div class="flex items-center gap-3 mb-4">
    <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-blue text-sm font-bold text-white">
      {initials}
    </div>
    <div class="min-w-0">
      <p class="text-sm font-bold text-navy truncate">{name}</p>
      <p class="text-xs text-text-muted truncate">{role}</p>
    </div>
  </div>

  {/* Quote snippet */}
  <blockquote class="flex-1">
    <p class="text-[0.9375rem] leading-relaxed text-text">
      &ldquo;{snippet}&rdquo;
    </p>
  </blockquote>

  {/* Outcome bar + Read more */}
  <div class="mt-4 flex flex-col gap-2">
    <div class="rounded-lg bg-emerald-50 px-3 py-1.5">
      <p class="text-xs font-semibold text-emerald-700">
        <svg class="inline h-3 w-3 mr-1 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
        {shortOutcome}
      </p>
    </div>
    {showReadMore && (
      <button
        class="self-end text-xs font-semibold text-blue hover:text-blue-dark transition-colors testimonial-open-btn"
        data-index={index}
      >
        Read more
      </button>
    )}
  </div>
</div>
