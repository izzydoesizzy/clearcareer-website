---
interface Props {
  name: string;
  role: string;
  quote: string;
  tagline: string;
  outcome?: string;
  image?: string;
  index?: number;
  showReadMore?: boolean;
}

const {
  name,
  role,
  quote,
  tagline,
  outcome,
  image,
  index = 0,
  showReadMore = false,
} = Astro.props;

const initials = name
  .split(" ")
  .map((n) => n[0])
  .join("")
  .toUpperCase()
  .slice(0, 2);

// Truncate quote to ~120 chars at a word boundary
const snippetLength = 120;
const snippet =
  quote.length > snippetLength
    ? quote.slice(0, quote.lastIndexOf(" ", snippetLength)) + "..."
    : quote;
---

<div
  class="rounded-xl border border-border border-l-4 border-l-success bg-white p-5 transition-shadow duration-300 flex flex-col shadow-[0_4px_24px_-4px_rgba(1,97,239,0.10)] hover:shadow-[0_8px_40px_-4px_rgba(1,97,239,0.18)]"
  data-testimonial-index={index}
>
  {/* Outcome badge (if different from tagline) */}
  {outcome && (
    <div class="mb-2">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-success/10 px-3 py-1 text-xs font-semibold text-success">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        {outcome}
      </span>
    </div>
  )}

  {/* Tagline headline */}
  <h3 class="text-lg font-bold leading-snug text-navy">
    {tagline}
  </h3>

  {/* Green divider */}
  <div class="my-3 h-px w-12 bg-success"></div>

  {/* Quote snippet */}
  <blockquote class="flex-1">
    <p class="text-sm leading-relaxed italic text-text-muted">
      &ldquo;{snippet}&rdquo;
    </p>
  </blockquote>

  {/* Author row + Read more */}
  <div class="mt-4 flex items-center justify-between gap-3">
    <div class="flex items-center gap-3 min-w-0">
      {image ? (
        <div class="h-9 w-9 shrink-0 overflow-hidden rounded-full ring-2 ring-blue/20">
          <img
            src={image}
            alt={name}
            width="36"
            height="36"
            class="h-full w-full object-cover object-top"
            loading="lazy"
          />
        </div>
      ) : (
        <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-semibold text-white">
          {initials}
        </div>
      )}
      <div class="min-w-0">
        <p class="truncate text-sm font-semibold text-text">{name}</p>
        <p class="truncate text-xs text-text-muted">{role}</p>
      </div>
    </div>
    {showReadMore && (
      <button
        class="shrink-0 text-xs font-semibold text-blue hover:text-blue-dark transition-colors testimonial-open-btn"
        data-index={index}
      >
        Read more
      </button>
    )}
  </div>
</div>
