---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;

// FAQ Schema.org markup
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<section class="py-16 md:py-24">
  <div class="mx-auto max-w-[720px] px-4 sm:px-6 lg:px-8">
    <div class="space-y-3">
      {
        items.map((item, index) => (
          <div
            class="faq-item rounded-xl border border-border bg-white"
            data-faq-index={index}
          >
            <button
              class="flex w-full items-center justify-between px-6 py-5 text-left transition-colors hover:bg-blue-bg/50"
              aria-expanded="false"
              aria-controls={`faq-answer-${index}`}
            >
              <span class="pr-4 text-base font-semibold text-text">
                {item.question}
              </span>
              <svg
                class="faq-icon h-5 w-5 flex-shrink-0 text-text-muted transition-transform duration-200"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12M6 12h12" />
              </svg>
            </button>
            <div
              id={`faq-answer-${index}`}
              class="hidden px-6 pb-5"
              role="region"
            >
              <p class="text-[1.0625rem] leading-[1.75] text-text-muted">
                {item.answer}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</section>

<script>
  document.querySelectorAll(".faq-item").forEach((item) => {
    const button = item.querySelector("button");
    const answer = item.querySelector("[role='region']");
    const icon = item.querySelector(".faq-icon");

    button?.addEventListener("click", () => {
      const isOpen = button.getAttribute("aria-expanded") === "true";

      // Close all other items
      document.querySelectorAll(".faq-item").forEach((other) => {
        if (other !== item) {
          const otherButton = other.querySelector("button");
          const otherAnswer = other.querySelector("[role='region']");
          const otherIcon = other.querySelector(".faq-icon");
          otherButton?.setAttribute("aria-expanded", "false");
          otherAnswer?.classList.add("hidden");
          otherIcon?.classList.remove("rotate-45");
        }
      });

      // Toggle current item
      button.setAttribute("aria-expanded", String(!isOpen));
      answer?.classList.toggle("hidden");
      icon?.classList.toggle("rotate-45");
    });
  });
</script>
