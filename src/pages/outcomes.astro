---
import PageLayout from "@layouts/PageLayout.astro";
import Hero from "@components/Hero.astro";
import CTASection from "@components/CTASection.astro";
---

<PageLayout
  title="Client Outcomes Report | ClearCareer Results"
  description="Data-driven outcomes from ClearCareer coaching. 200+ professionals coached, 46% landed within 1 month, 98% client satisfaction, $1.2M+ in collective raises."
>
  <!-- Hero -->
  <Hero
    variant="page"
    eyebrow="Outcomes Report"
    headline="The Numbers Speak for Themselves"
    subheadline="Based on survey responses from 58 program members. Real data from real clients."
  />

  <!-- Key Metrics -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[1080px] px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
        <div class="rounded-xl border border-border bg-white p-8 text-center">
          <p class="text-[2.5rem] font-bold text-blue">200+</p>
          <p class="mt-2 text-sm text-text-muted">Professionals Coached</p>
        </div>
        <div class="rounded-xl border border-border bg-white p-8 text-center">
          <p class="text-[2.5rem] font-bold text-blue">$1.2M+</p>
          <p class="mt-2 text-sm text-text-muted">Collective Salary Increases</p>
        </div>
        <div class="rounded-xl border border-border bg-white p-8 text-center">
          <p class="text-[2.5rem] font-bold text-blue">46%</p>
          <p class="mt-2 text-sm text-text-muted">Landed Within 1 Month</p>
        </div>
        <div class="rounded-xl border border-border bg-white p-8 text-center">
          <p class="text-[2.5rem] font-bold text-blue">98%</p>
          <p class="mt-2 text-sm text-text-muted">Client Satisfaction</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Detailed Metrics with Charts -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[1080px] px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-blue">Detailed Breakdown</p>
        <h2 class="font-display text-[clamp(1.5rem,3vw,2.25rem)] leading-[1.15] text-navy">A Closer Look at the Data</h2>
      </div>
      <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2">
        <!-- Time to Landing -->
        <div class="rounded-xl border border-border bg-white p-8">
          <h3 class="text-lg font-semibold text-navy">Time to Landing</h3>
          <canvas id="chart-time" class="mt-6 h-64 w-full"></canvas>
          <p class="mt-4 text-sm text-text-muted">
            46% of clients landed within 1 month. 78% within 3 months.
          </p>
        </div>

        <!-- Salary Impact -->
        <div class="rounded-xl border border-border bg-white p-8">
          <h3 class="text-lg font-semibold text-navy">Salary Impact</h3>
          <canvas id="chart-salary" class="mt-6 h-64 w-full"></canvas>
          <p class="mt-4 text-sm text-text-muted">
            Average salary increase: $10K. Top increase: $30K.
          </p>
        </div>

        <!-- Program Satisfaction -->
        <div class="rounded-xl border border-border bg-white p-8">
          <h3 class="text-lg font-semibold text-navy">Program Satisfaction</h3>
          <canvas id="chart-satisfaction" class="mt-6 h-64 w-full"></canvas>
          <p class="mt-4 text-sm text-text-muted">
            84% gave 5 stars. 98% rated better than other programs.
          </p>
        </div>

        <!-- Career Outcomes -->
        <div class="rounded-xl border border-border bg-white p-8">
          <h3 class="text-lg font-semibold text-navy">Career Outcomes</h3>
          <canvas id="chart-outcomes" class="mt-6 h-64 w-full"></canvas>
          <p class="mt-4 text-sm text-text-muted">
            Clients landed in tech, finance, healthcare, nonprofit, and government.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Methodology Note -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[1080px] px-4 sm:px-6 lg:px-8">
      <div class="rounded-xl bg-blue-bg p-6">
        <p class="text-sm text-text-muted">
          This data is based on survey responses from 58 program members collected between 2020-2025. Results vary by individual effort, market conditions, and role level.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    heading="Ready to Add Your Story?"
    primaryCTA={{ text: "Book a Free Audit", href: "https://calendly.com/clearcareer/discovery-call" }}
    variant="blue"
  />
</PageLayout>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>

<script>
  function initCharts() {
    const blue = '#0161EF';
    const blueDark = '#0450c8';
    const blueBg = '#EFF5FF';
    const border = '#e5e7eb';
    const blueLight = '#4d8ef5';
    const blueMid = '#2a75f0';

    // Time to Landing - Bar Chart
    const timeCtx = document.getElementById('chart-time') as HTMLCanvasElement;
    if (timeCtx) {
      new (window as any).Chart(timeCtx, {
        type: 'bar',
        data: {
          labels: ['< 1 Month', '1-3 Months', '3-6 Months', '6+ Months'],
          datasets: [{
            label: '% of Clients',
            data: [46, 32, 16, 6],
            backgroundColor: [blue, blueMid, blueLight, blueBg],
            borderRadius: 6,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            y: { beginAtZero: true, ticks: { callback: (v: number) => v + '%' } },
          },
        },
      });
    }

    // Salary Impact - Bar Chart
    const salaryCtx = document.getElementById('chart-salary') as HTMLCanvasElement;
    if (salaryCtx) {
      new (window as any).Chart(salaryCtx, {
        type: 'bar',
        data: {
          labels: ['$0-5K', '$5-10K', '$10-20K', '$20-30K', '$30K+'],
          datasets: [{
            label: '% of Clients',
            data: [15, 30, 35, 15, 5],
            backgroundColor: [blueBg, blueLight, blueMid, blue, blueDark],
            borderRadius: 6,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            y: { beginAtZero: true, ticks: { callback: (v: number) => v + '%' } },
          },
        },
      });
    }

    // Satisfaction - Doughnut Chart
    const satCtx = document.getElementById('chart-satisfaction') as HTMLCanvasElement;
    if (satCtx) {
      new (window as any).Chart(satCtx, {
        type: 'doughnut',
        data: {
          labels: ['5 Stars', '4 Stars', '3 Stars'],
          datasets: [{
            data: [84, 12, 4],
            backgroundColor: [blue, blueBg, border],
            borderWidth: 0,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: 'bottom' },
          },
        },
      });
    }

    // Career Outcomes - Horizontal Bar
    const outCtx = document.getElementById('chart-outcomes') as HTMLCanvasElement;
    if (outCtx) {
      new (window as any).Chart(outCtx, {
        type: 'bar',
        data: {
          labels: ['Tech', 'Finance', 'Marketing', 'Healthcare', 'Nonprofit', 'Government'],
          datasets: [{
            label: '% of Clients',
            data: [35, 20, 15, 12, 10, 8],
            backgroundColor: blue,
            borderRadius: 6,
          }],
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { beginAtZero: true, ticks: { callback: (v: number) => v + '%' } },
          },
        },
      });
    }
  }

  // Wait for Chart.js to load, then initialize
  if ((window as any).Chart) {
    initCharts();
  } else {
    window.addEventListener('load', initCharts);
  }
</script>
