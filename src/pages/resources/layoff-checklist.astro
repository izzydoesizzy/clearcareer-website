<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var STORAGE_KEY = 'layoff_checklist_progress';
  var checkboxes = document.querySelectorAll('.step-checkbox');
  var progressBar = document.getElementById('progress-bar');
  var progressText = document.getElementById('progress-text');
  var totalSteps = 25;

  function getCompleted() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    } catch(e) { return []; }
  }

  function updateProgress() {
    var completed = getCompleted();
    var pct = Math.round((completed.length / totalSteps) * 100);
    if (progressBar) progressBar.style.width = pct + '%';
    if (progressText) progressText.textContent = completed.length + ' of ' + totalSteps + ' completed';
    // Style completed steps
    checkboxes.forEach(function(cb) {
      var stepNum = parseInt(cb.getAttribute('data-step'));
      var card = cb.closest('.layoff-step');
      if (completed.indexOf(stepNum) !== -1) {
        cb.checked = true;
        if (card) card.style.opacity = '0.6';
      } else {
        cb.checked = false;
        if (card) card.style.opacity = '1';
      }
    });
  }

  checkboxes.forEach(function(cb) {
    cb.addEventListener('change', function() {
      var stepNum = parseInt(cb.getAttribute('data-step'));
      var completed = getCompleted();
      if (cb.checked) {
        if (completed.indexOf(stepNum) === -1) completed.push(stepNum);
      } else {
        completed = completed.filter(function(n) { return n !== stepNum; });
      }
      localStorage.setItem(STORAGE_KEY, JSON.stringify(completed));
      updateProgress();
    });
  });

  updateProgress();

  // Sources toggle
  var sourcesToggle = document.getElementById('sources-toggle');
  var sourcesList = document.getElementById('sources-list');
  var sourcesChevron = document.getElementById('sources-chevron');
  if (sourcesToggle) {
    sourcesToggle.addEventListener('click', function() {
      var isHidden = sourcesList.style.display === 'none';
      sourcesList.style.display = isHidden ? '' : 'none';
      sourcesChevron.style.transform = isHidden ? 'rotate(90deg)' : '';
    });
  }
});
</script>
