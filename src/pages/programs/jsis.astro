---
import PageLayout from "@layouts/PageLayout.astro";
import Hero from "@components/Hero.astro";
import StatsBar from "@components/StatsBar.astro";
import TrustBar from "@components/TrustBar.astro";
import TestimonialCard from "@components/TestimonialCard.astro";
import PricingCard from "@components/PricingCard.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import CTASection from "@components/CTASection.astro";
import deliverables from "@data/deliverables.json";
import faqItems from "@data/faq-jsis.json";
import allTestimonials from "@data/testimonials.json";

const careerOutcomeTestimonials = allTestimonials.filter(
  (t) => t.category === "career-outcome"
);

// Pick 6 specific career-outcome testimonials for the grid
const selectedTestimonialNames = [
  "Septembre Anderson",
  "Tamara Gordon",
  "Julian Pedraza",
  "Chris Chipman",
  "Jorge Garboza",
  "Annie Bell",
];
const testimonialGrid = selectedTestimonialNames
  .map((name) => allTestimonials.find((t) => t.name === name))
  .filter(Boolean);
---

<PageLayout
  title="Job Search Ignition System | 8-Week Career Accelerator | ClearCareer"
  description="An 8-week done-with-you job search accelerator for senior professionals targeting $100K+ roles. 20+ career assets built for you. 3 private sessions. Group accountability. Book a free audit."
>

  <!-- 1. Hero -->
  <Hero
    variant="page"
    eyebrow="An 8-Week Done-With-You Job Search Accelerator"
    headline="You've tried going it alone.<br>Let's try building it <span class='bg-gradient-to-r from-blue to-blue-light bg-clip-text text-transparent'>together.</span>"
    subheadline="For the senior professional who's been grinding alone. A place to rebuild your assets, overhaul your strategy, and find your footing again. Together."
    primaryCTA={{ text: "Book My Free Job Search Audit", href: "https://calendly.com/clearcareer/discovery-call" }}
    secondaryCTA={{ text: "See What's Inside", href: "#deliverables" }}
    trustText="Free 20-minute call · No commitment · No pressure"
  />

  <!-- 2. Stats Bar -->
  <StatsBar
    stats={[
      { number: "84%", label: "5-Star Rating" },
      { number: "$1.2M+", label: "Collective Raises" },
      { number: "46%", label: "Landed Within 1 Month" },
      { number: "98%", label: "Rated Better Than Other Programs" },
    ]}
  />

  <!-- 3. Trust Bar -->
  <TrustBar />

  <!-- 4. The Problem Section -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[720px] px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-blue">The Problem</p>
        <h2 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold leading-[1.2] text-navy">You've tried grinding alone. Let's try building together.</h2>
      </div>

      <div class="mt-10 space-y-5 text-[1.0625rem] leading-[1.75] text-text">
        <p>You want accountability, not just advice you'll "get to later."</p>
        <p>You want to see your achievements written out and think: <em>wait, I'm actually kind of incredible.</em> You want a done-for-you resume and LinkedIn that finally reflects the professional you actually are. You want a strategy overhauled from the ground up. You want to feel recharged, not depleted, by your job search.</p>
        <p class="font-semibold">You've run the math:</p>
        <ul class="space-y-3 pl-1">
          <li class="flex items-start gap-3">
            <span class="mt-0.5 flex-shrink-0">👉</span>
            <span>At <strong>$100K+</strong>, every month without a job costs you <strong>~$8,000+</strong> in lost income</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 flex-shrink-0">👉</span>
            <span>The average senior professional in this market is unemployed for <strong>6-12+ months</strong>. That's up to <strong>$120K</strong> in foregone salary</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 flex-shrink-0">👉</span>
            <span>You've applied. You've tailored. You've followed up. You've gotten silence.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 flex-shrink-0">👉</span>
            <span>You don't need more effort. You need a <strong>completely different system</strong>, built with you</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 flex-shrink-0">👉</span>
            <span>And you need people in your corner. Peers who get it, celebrating your wins and keeping you moving</span>
          </li>
        </ul>
        <p class="pt-2 text-lg font-semibold text-navy">Welcome to the Job Search Ignition System.</p>
      </div>
    </div>
  </section>

  <!-- 5. The Program Section -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-[720px] px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-blue">The Program</p>
        <h2 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold leading-[1.2] text-navy">Introducing the Job Search Ignition System</h2>
      </div>

      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <span class="inline-flex rounded-full bg-blue-bg px-4 py-2 text-sm font-semibold text-blue">20+ assets built for you</span>
        <span class="inline-flex rounded-full bg-blue-bg px-4 py-2 text-sm font-semibold text-blue">Cohort of up to 10</span>
        <span class="inline-flex rounded-full bg-blue-bg px-4 py-2 text-sm font-semibold text-blue">3x 1:1 sessions with Izzy</span>
        <span class="inline-flex rounded-full bg-blue-bg px-4 py-2 text-sm font-semibold text-blue">8 weeks of building</span>
      </div>

      <div class="mt-10 space-y-5 text-[1.0625rem] leading-[1.75] text-text">
        <p>A tight cohort of up to 10. 8 weeks of building, not just talking. Done-for-you resume, LinkedIn, and outreach assets. Three private 1:1 sessions with Izzy. Group accountability that makes this feel less like a grind and more like a team sport.</p>
        <p>This isn't a course you'll watch at 11pm and never finish. It's a hands-on program where we rebuild your job search infrastructure from the foundation up, with peers who are in it with you and 1:1 time with Izzy to make sure everything reflects you.</p>
        <p>By Week 8, you'll have 20+ assets you can use forever. You'll walk out with a strategy you actually believe in, and a belief in yourself you'd almost forgotten.</p>
        <p><strong>Sign up early and you'll get priority access to your first 1:1 session with Izzy</strong>, so your assets are in order and you're applying before the cohort even officially kicks off.</p>
      </div>
    </div>
  </section>

  <!-- 6. Deliverables Section -->
  <section class="py-16 md:py-24" id="deliverables">
    <div class="mx-auto max-w-[1080px] px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-blue">What's Included</p>
        <h2 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold leading-[1.2] text-navy">Here's What You Get</h2>
      </div>

      <!-- Done-For-You Asset Bundle -->
      <div class="mt-12 rounded-2xl bg-blue-bg p-6 sm:p-8">
        <h3 class="text-xl font-bold text-navy">Done-For-You Asset Bundle</h3>
        <p class="mt-1 text-sm font-semibold text-blue">Built from your AI Intake Interview</p>
        <p class="mt-4 text-[1.0625rem] leading-[1.75] text-text">Every asset below is built <em>for you</em>, not assigned as homework. This is what sets the Job Search Ignition System apart from every other coaching program. Other coaches tell you what to do. You still go home and have to do all of it yourself. Not here.</p>

        <div class="mt-8 space-y-8">
          {deliverables.pillars.map((pillar) => (
            <div>
              <h4 class="mb-4 text-sm font-bold uppercase tracking-wider text-blue">
                {pillar.name} <span class="font-normal text-text-muted">(Weeks {pillar.weeks})</span>
              </h4>
              <div class="space-y-3">
                {pillar.deliverables.map((item) => (
                  <div class="flex items-start gap-3">
                    <svg class="mt-1 h-5 w-5 flex-shrink-0 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    <p class="text-[1.0625rem] leading-[1.75] text-text">
                      <strong>{item.name}</strong> - {item.description}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Support & Services -->
      <div class="mt-16">
        <h3 class="text-center text-xl font-bold text-navy">Support & Services</h3>

        <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          <!-- Featured: LinkedIn Content System (spans 2 cols on lg) -->
          <div class="rounded-xl border border-blue bg-blue-bg/30 p-6 shadow-sm ring-2 ring-blue/20 transition-shadow hover:shadow-md lg:col-span-2">
            <span class="text-2xl">📣</span>
            <p class="mt-3 text-lg font-semibold text-text">LinkedIn Content System</p>
            <p class="mt-2 text-[1.0625rem] leading-[1.75] text-text-muted">Most job seekers are invisible. The LinkedIn Content System changes that. Each week, we build 1-2 story-based posts drawn from your experience, written to reflect what you do best and keep you front-of-mind with hiring managers, recruiters, and your network. Passive visibility that works while you sleep.</p>
          </div>

          <!-- 3x Private 1:1 Sessions -->
          <div class="rounded-xl border border-border bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
            <span class="text-2xl">🤝</span>
            <p class="mt-3 text-lg font-semibold text-text">3x Private 1:1 Sessions with Izzy</p>
            <p class="mt-2 text-[1.0625rem] leading-[1.75] text-text-muted">60-min Kickoff (Week 1) · 45-min Mid-Program Review (Week 4) · 60-min Closing Strategy Call (Week 8). Use them for strategy, asset sign-off, confidence work, or whatever you need most. These are yours.</p>
          </div>

          <!-- Weekly Monday Check-In -->
          <div class="rounded-xl border border-border bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
            <span class="text-2xl">📅</span>
            <p class="mt-3 text-lg font-semibold text-text">Weekly Monday Check-In <span class="ml-2 inline-flex rounded-full bg-blue-bg px-2 py-0.5 text-xs font-semibold text-blue">30 min</span></p>
            <p class="mt-2 text-[1.0625rem] leading-[1.75] text-text-muted">Set your priorities for the week. Never start a Monday adrift again.</p>
          </div>

          <!-- Weekly Wednesday Group Call -->
          <div class="rounded-xl border border-border bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
            <span class="text-2xl">📅</span>
            <p class="mt-3 text-lg font-semibold text-text">Weekly Wednesday Group Call</p>
            <p class="mt-2 text-[1.0625rem] leading-[1.75] text-text-muted">Mid-week touchpoint to troubleshoot what isn't working and keep momentum going. This is where breakthroughs happen in front of people who are rooting for you.</p>
          </div>

          <!-- WhatsApp Async Support -->
          <div class="rounded-xl border border-border bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
            <span class="text-2xl">💬</span>
            <p class="mt-3 text-lg font-semibold text-text">WhatsApp Async Support <span class="ml-2 inline-flex rounded-full bg-blue-bg px-2 py-0.5 text-xs font-semibold text-blue">Weekdays</span></p>
            <p class="mt-2 text-[1.0625rem] leading-[1.75] text-text-muted">Izzy is in your corner between sessions. Ask questions, share a draft, get unstuck. Available weekday business hours with lighter support evenings and weekends.</p>
          </div>

          <!-- Private Skool Community -->
          <div class="rounded-xl border border-border bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
            <span class="text-2xl">🏘️</span>
            <p class="mt-3 text-lg font-semibold text-text">Private Skool Community</p>
            <p class="mt-2 text-[1.0625rem] leading-[1.75] text-text-muted">Share wins, vent frustrations, ask "is this normal?", and celebrate offers together. The community is where exhaustion turns into momentum.</p>
          </div>

          <!-- Weekly Voice Notes from Izzy -->
          <div class="rounded-xl border border-border bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
            <span class="text-2xl">🎙️</span>
            <p class="mt-3 text-lg font-semibold text-text">Weekly Voice Notes from Izzy</p>
            <p class="mt-2 text-[1.0625rem] leading-[1.75] text-text-muted">A question, a tip, a nudge every single week, so you never feel like you're drifting.</p>
          </div>

          <!-- Full AI Prompt Library -->
          <div class="rounded-xl border border-border bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
            <span class="text-2xl">🤖</span>
            <p class="mt-3 text-lg font-semibold text-text">Full AI Prompt Library <span class="ml-2 inline-flex rounded-full bg-blue-bg px-2 py-0.5 text-xs font-semibold text-blue">30+ prompts</span></p>
            <p class="mt-2 text-[1.0625rem] leading-[1.75] text-text-muted">Resume, LinkedIn, company research, outreach, interview prep. Built specifically for senior professionals. Ready to use in seconds.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Mid-Page CTA -->
  <CTASection
    heading="10 Spots. Limited Cohort."
    body="The smaller the group, the more attention you get. Book your free audit to see if this is right for you."
    primaryCTA={{ text: "Book My Free Job Search Audit", href: "https://calendly.com/clearcareer/discovery-call" }}
    variant="blue"
  />

  <!-- 8. Testimonials Grid -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[1080px] px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-blue">Client Results</p>
        <h2 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold leading-[1.2] text-navy">More Success Stories</h2>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {testimonialGrid.map((t) => (
          <TestimonialCard
            name={t.name}
            role={t.role}
            quote={t.quote}
            outcome={t.outcome}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- 9. Client Achievement Cards -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-[1080px] px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-blue">Client Results</p>
        <h2 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold leading-[1.2] text-navy">What Past Clients Have Achieved</h2>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <!-- Tamara -->
        <div class="rounded-xl border border-border bg-white p-6">
          <span class="inline-flex rounded-full bg-success/10 px-3 py-1 text-sm font-semibold text-success">$20K salary increase + annual bonuses</span>
          <p class="mt-4 font-semibold text-text">Tamara G.</p>
          <p class="text-sm text-text-muted">AI Strategy Advisor</p>
          <p class="mt-3 text-[1.0625rem] leading-[1.75] text-text">After months of rejection despite strong dedication, Tamara gained clarity, transformed her resume, and landed multiple interviews within weeks. She accepted a role with a $20,000 salary increase plus annual bonuses, giving her the financial stability she needed for her family.</p>
          <p class="mt-3 text-[1.0625rem] italic leading-[1.75] text-text-muted">"Izzy is a game-changer!! 10/10, highly recommend!"</p>
        </div>

        <!-- Kristin -->
        <div class="rounded-xl border border-border bg-white p-6">
          <span class="inline-flex rounded-full bg-success/10 px-3 py-1 text-sm font-semibold text-success">1 year unemployed, hired in 3 weeks</span>
          <p class="mt-4 font-semibold text-text">Kristin D.</p>
          <p class="text-sm text-text-muted">Growth Marketing Manager & Partnerships Lead</p>
          <p class="mt-3 text-[1.0625rem] leading-[1.75] text-text">Unemployed for an entire year and still stuck. After working with Izzy, she was employed in just three weeks. He helped her articulate her unique skill set and shifted her mindset to act like a consultant in her interview. She ended up writing her own job description.</p>
          <p class="mt-3 text-[1.0625rem] italic leading-[1.75] text-text-muted">"That mindset shift changed everything."</p>
        </div>

        <!-- Blake -->
        <div class="rounded-xl border border-border bg-white p-6">
          <span class="inline-flex rounded-full bg-success/10 px-3 py-1 text-sm font-semibold text-success">200+ apps to multiple offers after 27 emails</span>
          <p class="mt-4 font-semibold text-text">Blake M.</p>
          <p class="text-sm text-text-muted">Software Developer</p>
          <p class="mt-3 text-[1.0625rem] leading-[1.75] text-text">After applying to over 200 jobs and getting only 10 interviews and no offers, Blake tried the Izzy Method. He sent 27 targeted emails, got multiple responses, and landed a full-time role at a company that had previously rejected him. He also negotiated a $5,000 salary increase on the offer.</p>
          <p class="mt-3 text-[1.0625rem] italic leading-[1.75] text-text-muted">"Everything changed."</p>
        </div>

        <!-- Sparsh -->
        <div class="rounded-xl border border-border bg-white p-6">
          <span class="inline-flex rounded-full bg-success/10 px-3 py-1 text-sm font-semibold text-success">600+ apps to hired in 30 days</span>
          <p class="mt-4 font-semibold text-text">Sparsh K.</p>
          <p class="text-sm text-text-muted">Operations & Process Improvement Professional</p>
          <p class="mt-3 text-[1.0625rem] leading-[1.75] text-text">After over a year of frustration, Sparsh followed Izzy's advice exactly. Within 30 days, he had a job.</p>
          <p class="mt-3 text-[1.0625rem] italic leading-[1.75] text-text-muted">"The weekly group sessions kept me motivated, and Izzy's personalized approach made all the difference. Trust his process and put in the effort, you won't regret it."</p>
        </div>

        <!-- Laura -->
        <div class="rounded-xl border border-border bg-white p-6">
          <span class="inline-flex rounded-full bg-success/10 px-3 py-1 text-sm font-semibold text-success">Dream job landed, $22K+ salary increase</span>
          <p class="mt-4 font-semibold text-text">Laura S.</p>
          <p class="text-sm text-text-muted">Reproductive Justice Advocate & Program Manager</p>
          <p class="mt-3 text-[1.0625rem] leading-[1.75] text-text">She demonstrated her value, prepared for the interview, and sent an impactful follow-up email that sealed the role, at a 30%+ salary increase.</p>
          <p class="mt-3 text-[1.0625rem] italic leading-[1.75] text-text-muted">"Izzy is a warm, caring, and impactful coach that really knows his stuff."</p>
        </div>

        <!-- Kira -->
        <div class="rounded-xl border border-border bg-white p-6">
          <span class="inline-flex rounded-full bg-success/10 px-3 py-1 text-sm font-semibold text-success">$127K salary, $5K above initial offer</span>
          <p class="mt-4 font-semibold text-text">Kira H.</p>
          <p class="text-sm text-text-muted">Staff Software Engineer</p>
          <p class="mt-3 text-[1.0625rem] leading-[1.75] text-text">Transitioning from freelancing to full-time, Kira lacked confidence in self-promotion. Her lightbulb moment: seeing the job search from the employer's perspective. She negotiated a strong counteroffer, $127,000 USD starting salary, $5,000 more than the initial offer, plus 30 PTO days.</p>
          <p class="mt-3 text-[1.0625rem] italic leading-[1.75] text-text-muted">"His invaluable support empowered me to negotiate."</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. Who It's For / Not For -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[1080px] px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-blue">Is This Right for You?</p>
        <h2 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold leading-[1.2] text-navy">This program is built for a specific kind of professional</h2>
      </div>

      <div class="mt-12 grid gap-8 md:grid-cols-2">
        <!-- Who It's For -->
        <div class="rounded-xl border border-border border-l-4 border-l-success bg-white p-8">
          <h3 class="text-xl font-bold text-navy">Who It's For</h3>
          <p class="mt-2 text-sm text-text-muted">This is for you if any of these ring true.</p>
          <ul class="mt-6 space-y-4">
            <li class="flex items-start gap-3 text-[1.0625rem] leading-[1.75] text-text">
              <svg class="mt-1 h-5 w-5 flex-shrink-0 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>You're earning or targeting $100K+ in tech, product, data, engineering, finance, or marketing</span>
            </li>
            <li class="flex items-start gap-3 text-[1.0625rem] leading-[1.75] text-text">
              <svg class="mt-1 h-5 w-5 flex-shrink-0 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>You've been laid off and the severance clock is ticking. You know every month costs you $8K+ and you want to move strategically, not desperately</span>
            </li>
            <li class="flex items-start gap-3 text-[1.0625rem] leading-[1.75] text-text">
              <svg class="mt-1 h-5 w-5 flex-shrink-0 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>You've sent out 50-200+ applications with little or nothing back (you're motivated, your system is broken)</span>
            </li>
            <li class="flex items-start gap-3 text-[1.0625rem] leading-[1.75] text-text">
              <svg class="mt-1 h-5 w-5 flex-shrink-0 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>You've worked with coaches before who gave you advice and left you to figure it out alone. You want someone to build it with you</span>
            </li>
            <li class="flex items-start gap-3 text-[1.0625rem] leading-[1.75] text-text">
              <svg class="mt-1 h-5 w-5 flex-shrink-0 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>You want a group of people who actually get it, who will celebrate your first reply, challenge your excuses, and keep you accountable every single week</span>
            </li>
            <li class="flex items-start gap-3 text-[1.0625rem] leading-[1.75] text-text">
              <svg class="mt-1 h-5 w-5 flex-shrink-0 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>You're quietly employed and searching, and you need something that works around your schedule (no evening calls, no one at work needs to know)</span>
            </li>
            <li class="flex items-start gap-3 text-[1.0625rem] leading-[1.75] text-text">
              <svg class="mt-1 h-5 w-5 flex-shrink-0 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>You're ready to commit 3-5 hours/week for 8 weeks and do the work</span>
            </li>
          </ul>
          <p class="mt-6 font-semibold text-text">If you've been grinding alone and getting nowhere, this is where you refuel.</p>
        </div>

        <!-- Who It's Not For -->
