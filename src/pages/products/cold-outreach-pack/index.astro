---
import ProductLayout from "@layouts/ProductLayout.astro";
---

<ProductLayout
  title="Cold Outreach Script Pack | ClearCareer"
  description="30 copy-paste scripts for cold emails, LinkedIn DMs, follow-ups, and referral requests."
  headline="30 scripts. Copy. Paste. Send."
  subheadline="Stop staring at a blank screen. Every script has customization brackets so you can personalize in under 2 minutes."
  bullets={[
    "5 cold email variants for hiring managers",
    "5 LinkedIn connection request scripts by context (recruiter, peer, alumni, etc.)",
    "3-touch follow-up cadence with exact timing",
    "5 referral request scripts that don't feel awkward",
    "5 thank-you note variants for every situation",
  ]}
  price="$9 CAD"
  ctaHref="#checkout"
  ctaText="Get Instant Access"
  faq={[
    {
      q: "Are these generic templates or actually usable?",
      a: "Every script has [BRACKET] fields you fill in with your details. They're written to sound like you, not like a template. Each includes a 'when to use' note and a 'why this works' explanation.",
    },
    {
      q: "How is this different from the Script Vault?",
      a: "This pack focuses on cold outreach and follow-ups (30 scripts). The Script Vault covers everything: outreach, negotiation, interviews, rejection responses, and resignation (100+ scripts).",
    },
    {
      q: "Can I use these for LinkedIn and email?",
      a: "Yes. Scripts are organized by channel and scenario. Many include both email and LinkedIn versions.",
    },
  ]}
/>
