---
import BaseLayout from "@layouts/BaseLayout.astro";
import EmailCaptureForm from "@components/products/EmailCaptureForm";
---

<BaseLayout
  title="Rejection Reframe Card Deck | ClearCareer"
  description="10 printable cards with evidence-based CBT reframes for common job search rejection scenarios."
>
  <div class="min-h-screen bg-white">
    <header class="border-b border-border">
      <div class="mx-auto max-w-[720px] px-4 py-4 text-center">
        <a href="/" class="text-lg font-bold text-blue">ClearCareer</a>
      </div>
    </header>

    <section class="bg-gradient-to-b from-blue-bg/50 to-white py-12 md:py-16">
      <div class="mx-auto max-w-[640px] px-4 text-center">
        <span class="inline-block rounded-full bg-blue-bg px-3 py-1 text-xs font-semibold text-blue">
          Free Resource
        </span>
        <h1 class="mt-4 font-display text-[clamp(1.75rem,4vw,2.75rem)] leading-[1.1] text-navy">
          10 evidence-based reframes<br />
          <span class="text-blue">for when rejection hits hard.</span>
        </h1>
        <p class="mx-auto mt-4 max-w-lg text-lg text-gray-600">
          Printable cards based on Cognitive Behavioral Therapy. Each one takes a common rejection scenario and walks you through the automatic thought, the evidence check, and a balanced reframe.
        </p>
      </div>
    </section>

    <section class="py-10">
      <div class="mx-auto max-w-[640px] px-4">
        <h2 class="mb-6 text-center text-xl font-bold text-navy">Covers 10 rejection scenarios</h2>
        <div class="grid grid-cols-2 gap-2 text-sm">
          <div class="rounded-lg bg-gray-50 p-3 text-gray-700">Ghosted after interview</div>
          <div class="rounded-lg bg-gray-50 p-3 text-gray-700">Rejected at final round</div>
          <div class="rounded-lg bg-gray-50 p-3 text-gray-700">"Overqualified"</div>
          <div class="rounded-lg bg-gray-50 p-3 text-gray-700">"Not enough experience"</div>
          <div class="rounded-lg bg-gray-50 p-3 text-gray-700">Salary mismatch</div>
          <div class="rounded-lg bg-gray-50 p-3 text-gray-700">Position filled internally</div>
          <div class="rounded-lg bg-gray-50 p-3 text-gray-700">Ghosted after application</div>
          <div class="rounded-lg bg-gray-50 p-3 text-gray-700">Rejected after take-home</div>
          <div class="rounded-lg bg-gray-50 p-3 text-gray-700">"Went with someone else"</div>
          <div class="rounded-lg bg-gray-50 p-3 text-gray-700">Posting disappeared</div>
        </div>

        <div class="mt-8 rounded-xl border border-blue-200 bg-blue-bg/30 p-6">
          <p class="mb-4 text-center text-sm font-medium text-gray-700">
            Get the cards free
          </p>
          <EmailCaptureForm
            client:load
            productSlug="rejection-cards"
            productName="Rejection Reframe Card Deck"
            ctaText="Send Me the Cards"
          />
        </div>
      </div>
    </section>

    <footer class="border-t border-border py-6 text-center">
      <p class="text-xs text-gray-400">&copy; {new Date().getFullYear()} ClearCareer. All rights reserved.</p>
    </footer>
  </div>
</BaseLayout>
