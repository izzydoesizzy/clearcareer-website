---
import BaseLayout from "@layouts/BaseLayout.astro";
import { PRODUCTS } from "../../../../data/product-config";

export const prerender = false;

const { slug } = Astro.params;
const sessionId = Astro.url.searchParams.get("session_id");

if (!slug || !PRODUCTS[slug]) {
  return Astro.redirect("/404");
}

if (sessionId) {
  return Astro.redirect(`/products/${slug}/access/${sessionId}`);
}
---

<BaseLayout title="Access Your Product | ClearCareer" description="Access your ClearCareer product.">
  <div class="flex min-h-[60vh] items-center justify-center px-4">
    <div class="max-w-md text-center">
      <h1 class="text-2xl font-bold text-gray-900">Check your email</h1>
      <p class="mt-4 text-gray-600">
        We sent an access link to the email you used at checkout. Click the link in that email to access your product.
      </p>
      <a
        href="/shop"
        class="mt-8 inline-block text-sm text-blue-600 hover:underline"
      >
        Back to Shop
      </a>
    </div>
  </div>
</BaseLayout>
