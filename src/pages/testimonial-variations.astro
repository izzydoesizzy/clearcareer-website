---
import PageLayout from "@layouts/PageLayout.astro";
import testimonials from "@data/testimonials.json";
import { formatName } from "@utils/format-name";

// Get 3 good sample testimonials
const samples = testimonials
  .filter((t) => t.tagline && t.outcome)
  .sort((a, b) => (a.sortPriority || 999) - (b.sortPriority || 999))
  .slice(0, 3);

const s1 = samples[0]; // Kira
const s2 = samples[1]; // Annie
const s3 = samples[2]; // Victor

const getInitials = (name: string) =>
  name.split(" ").map((n) => n[0]).join("").toUpperCase().slice(0, 2);
---

<PageLayout title="Testimonial Card Variations" description="Design exploration for testimonial card styles">
  <div class="mx-auto max-w-[1080px] px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="font-display text-4xl text-navy mb-2">Testimonial Card Variations</h1>
    <p class="text-text-muted mb-12">10 different styles. Pick your favorite number.</p>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- VARIATION 1: Clean Minimal -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20">
      <h2 class="text-sm font-bold uppercase tracking-widest text-blue mb-6">Variation 1 — Clean Minimal</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {samples.map((t) => (
          <div class="rounded-xl border border-border bg-white p-6">
            <p class="text-[1.0625rem] leading-relaxed text-navy italic">
              &ldquo;{t.pullQuote || t.quote.slice(0, 140) + '...'}&rdquo;
            </p>
            <div class="mt-5 flex items-center gap-3">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-navy text-xs font-semibold text-white">
                {getInitials(t.name)}
              </div>
              <div>
                <p class="text-sm font-semibold text-text">{formatName(t.name)}</p>
                <p class="text-xs text-text-muted">{t.role.split('/')[0].trim()}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- VARIATION 2: Big Quote with Top Outcome Pill -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20">
      <h2 class="text-sm font-bold uppercase tracking-widest text-blue mb-6">Variation 2 — Outcome Pill + Quote</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {samples.map((t) => (
          <div class="rounded-xl border border-border bg-white p-6 flex flex-col">
            <span class="inline-flex self-start items-center gap-1.5 rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700 mb-4">
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              {t.outcome?.split(';')[0]}
            </span>
            <p class="flex-1 text-[0.9375rem] leading-relaxed text-text-muted">
              &ldquo;{t.pullQuote || t.quote.slice(0, 140) + '...'}&rdquo;
            </p>
            <div class="mt-5 pt-4 border-t border-border flex items-center gap-3">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-blue/10 text-xs font-semibold text-blue">
                {getInitials(t.name)}
              </div>
              <p class="text-sm text-text"><span class="font-semibold">{formatName(t.name)}</span> · {t.role.split('/')[0].trim()}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- VARIATION 3: Tagline-Led Card (Bold Headline) -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20">
      <h2 class="text-sm font-bold uppercase tracking-widest text-blue mb-6">Variation 3 — Tagline-Led (Bold Headline)</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {samples.map((t) => (
          <div class="rounded-xl bg-white border border-border p-6 flex flex-col">
            <h3 class="text-lg font-bold text-navy leading-snug mb-3">{t.tagline}</h3>
            <p class="flex-1 text-sm leading-relaxed text-text-muted italic">
              &ldquo;{t.pullQuote || t.quote.slice(0, 120) + '...'}&rdquo;
            </p>
            <div class="mt-4 flex items-center gap-3">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-navy text-[0.625rem] font-semibold text-white">
                {getInitials(t.name)}
              </div>
              <div>
                <p class="text-sm font-medium text-text">{formatName(t.name)}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- VARIATION 4: Large Quote Marks + Centered -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20">
      <h2 class="text-sm font-bold uppercase tracking-widest text-blue mb-6">Variation 4 — Large Quote Marks, Centered</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {samples.map((t) => (
          <div class="rounded-xl border border-border bg-white p-6 text-center flex flex-col items-center">
            <svg class="h-8 w-8 text-blue/20 mb-3" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z"/></svg>
            <p class="flex-1 text-[0.9375rem] leading-relaxed text-navy">
              {t.pullQuote || t.quote.slice(0, 140) + '...'}
            </p>
            <div class="mt-5 pt-4 border-t border-border w-full">
              <p class="text-sm font-semibold text-text">{formatName(t.name)}</p>
              <p class="text-xs text-text-muted mt-0.5">{t.outcome?.split(';')[0]}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- VARIATION 5: Navy Background Card -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20">
      <h2 class="text-sm font-bold uppercase tracking-widest text-blue mb-6">Variation 5 — Navy Background</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {samples.map((t) => (
          <div class="rounded-xl bg-navy p-6 flex flex-col">
            <span class="inline-flex self-start items-center gap-1.5 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-emerald-400 mb-4">
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              {t.outcome?.split(';')[0]}
            </span>
            <p class="flex-1 text-[0.9375rem] leading-relaxed text-white/90 italic">
              &ldquo;{t.pullQuote || t.quote.slice(0, 140) + '...'}&rdquo;
            </p>
            <div class="mt-5 pt-4 border-t border-white/10 flex items-center gap-3">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-semibold text-white">
                {getInitials(t.name)}
              </div>
              <div>
                <p class="text-sm font-semibold text-white">{formatName(t.name)}</p>
                <p class="text-xs text-white/50">{t.role.split('/')[0].trim()}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- VARIATION 6: Star Rating + Compact -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20">
      <h2 class="text-sm font-bold uppercase tracking-widest text-blue mb-6">Variation 6 — Star Rating, Compact</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {samples.map((t) => (
          <div class="rounded-xl border border-border bg-white p-5 flex flex-col">
            <div class="flex gap-0.5 mb-3">
              {[1,2,3,4,5].map(() => (
                <svg class="h-4 w-4 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <p class="flex-1 text-sm leading-relaxed text-text">
              &ldquo;{t.pullQuote || t.quote.slice(0, 120) + '...'}&rdquo;
            </p>
            <p class="mt-4 text-xs text-text-muted">
              <span class="font-semibold text-text">{formatName(t.name)}</span> · {t.tagline?.split('.')[0]}
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- VARIATION 7: Gradient Accent Top Bar -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20">
      <h2 class="text-sm font-bold uppercase tracking-widest text-blue mb-6">Variation 7 — Gradient Top Accent</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {samples.map((t) => (
          <div class="rounded-xl border border-border bg-white overflow-hidden flex flex-col">
            <div class="h-1.5 bg-gradient-to-r from-blue to-cyan-400"></div>
            <div class="p-6 flex flex-col flex-1">
              <h3 class="text-base font-bold text-navy mb-2">{t.tagline}</h3>
              <p class="flex-1 text-sm leading-relaxed text-text-muted">
                &ldquo;{t.pullQuote || t.quote.slice(0, 120) + '...'}&rdquo;
              </p>
              <div class="mt-4 flex items-center gap-3">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-blue to-cyan-400 text-xs font-semibold text-white">
                  {getInitials(t.name)}
                </div>
                <div>
                  <p class="text-sm font-semibold text-text">{formatName(t.name)}</p>
                  <p class="text-xs text-text-muted">{t.role.split('/')[0].trim()}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- VARIATION 8: Soft Blue Background + Emoji Result -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20">
      <h2 class="text-sm font-bold uppercase tracking-widest text-blue mb-6">Variation 8 — Soft Blue BG + Emoji Result</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {samples.map((t) => (
          <div class="rounded-xl bg-blue-bg p-6 flex flex-col">
            <div class="text-sm font-semibold text-blue mb-3">
              {t.tagline}
            </div>
            <p class="flex-1 text-[0.9375rem] leading-relaxed text-navy">
              &ldquo;{t.pullQuote || t.quote.slice(0, 140) + '...'}&rdquo;
            </p>
            <div class="mt-5 flex items-center gap-3">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-semibold text-white">
                {getInitials(t.name)}
              </div>
              <div>
                <p class="text-sm font-semibold text-navy">{formatName(t.name)}</p>
                <p class="text-xs text-text-muted">{t.role.split('/')[0].trim()}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- VARIATION 9: Two-Tone Split (Outcome | Quote) -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20">
      <h2 class="text-sm font-bold uppercase tracking-widest text-blue mb-6">Variation 9 — Two-Tone Split</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {samples.map((t) => (
          <div class="rounded-xl border border-border bg-white overflow-hidden flex flex-col">
            <div class="bg-navy px-6 py-4">
              <p class="text-sm font-bold text-white">{t.tagline}</p>
              <p class="text-xs text-white/60 mt-1">{formatName(t.name)} · {t.role.split('/')[0].trim()}</p>
            </div>
            <div class="px-6 py-5 flex-1">
              <p class="text-sm leading-relaxed text-text-muted italic">
                &ldquo;{t.pullQuote || t.quote.slice(0, 140) + '...'}&rdquo;
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- VARIATION 10: Floating Card with Shadow + Subtle Dot Pattern -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="mb-20">
      <h2 class="text-sm font-bold uppercase tracking-widest text-blue mb-6">Variation 10 — Floating Card, Strong Shadow</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {samples.map((t) => (
          <div class="rounded-2xl bg-white p-7 shadow-[0_8px_30px_-4px_rgba(0,0,0,0.1)] flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-blue text-sm font-bold text-white">
                {getInitials(t.name)}
              </div>
              <div>
                <p class="text-sm font-bold text-navy">{formatName(t.name)}</p>
                <p class="text-xs text-text-muted">{t.role.split('/')[0].trim()}</p>
              </div>
            </div>
            <p class="flex-1 text-[0.9375rem] leading-relaxed text-text mb-4">
              &ldquo;{t.pullQuote || t.quote.slice(0, 140) + '...'}&rdquo;
            </p>
            <div class="rounded-lg bg-emerald-50 px-3 py-2">
              <p class="text-xs font-semibold text-emerald-700">
                <svg class="inline h-3.5 w-3.5 mr-1 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
                {t.tagline}
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>
</PageLayout>
