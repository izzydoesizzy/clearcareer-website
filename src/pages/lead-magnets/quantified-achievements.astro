---
import LeadMagnetLayout from "@layouts/LeadMagnetLayout.astro";

const SHEET_COPY_URL = "https://docs.google.com/spreadsheets/d/10coFJPjCTFB5Bheob6uPGUucVi7GOTgeWnL3Y-e5h2c/copy";
---

<LeadMagnetLayout
  title="1,600+ Quantified Resume Achievements for 80+ Job Titles | ClearCareer"
  description="Stop writing 'responsible for' on your resume. Copy-paste from 1,600+ quantified achievement bullets across 80+ job titles and 16 industries."
  headline="1,600+ Quantified Achievements<br />for 80+ Job Titles"
  subheadline="Stop writing 'responsible for' on your resume. Find your job title, grab the bullets, and make them yours."
  bullets={[
    "1,600+ ready-to-adapt resume bullets with real numbers and metrics",
    "80+ job titles across 16 industries (tech, finance, marketing, ops, HR, and more)",
    "Organized by seniority level: entry, mid, senior, and leadership",
    "Before/after examples showing weak vs. strong achievement bullets",
    "Google Sheet you can copy and customize for your own resume",
  ]}
  source="quantified-achievements"
  storageKey="achievements_unlocked"
  ctaText="Get the Achievement Bank"
>
  <!-- Spreadsheet Preview Image -->
  <Fragment slot="hero-image">
    <section class="pb-4">
      <div class="mx-auto max-w-[720px] px-4">
        <div class="overflow-hidden rounded-xl border border-border shadow-lg">
          <img
            src="/images/lead-magnets/quantified-achievements-spreadsheet.png"
            alt="Preview of the 1,600+ quantified achievements spreadsheet"
            class="w-full"
            loading="eager"
            onerror="this.parentElement.innerHTML='<div style=&quot;padding:60px;text-align:center;background:#f8fafc;color:#64748b&quot;><p style=&quot;font-size:48px;margin:0&quot;>📊</p><p style=&quot;margin-top:12px;font-weight:600&quot;>1,600+ Achievement Bullets</p><p>80+ Job Titles · 16 Industries · 4 Seniority Levels</p></div>'"
          />
        </div>

        <!-- Sheet Copy CTA (only after gate) -->
        <div class="mt-4 text-center gated-content" style="display: none;">
          <a
            href={SHEET_COPY_URL}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-emerald-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-emerald-700"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2" />
            </svg>
            Copy to Google Sheets
          </a>
          <p class="mt-2 text-xs text-text-muted">Opens in Google Sheets. Make a copy to your Drive.</p>
        </div>
      </div>
    </section>
  </Fragment>

  <!-- Preview: just the categories list -->
  <Fragment slot="preview">
    <h2 class="mb-4 text-center text-lg font-bold text-navy">What's Inside</h2>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      {[
        { icon: "💻", label: "Technology & Engineering", count: "180" },
        { icon: "📊", label: "Marketing & Communications", count: "220" },
        { icon: "💰", label: "Finance & Accounting", count: "100" },
        { icon: "⚙️", label: "Operations & Supply Chain", count: "180" },
        { icon: "👥", label: "Human Resources & People", count: "100" },
        { icon: "📈", label: "Sales & Business Dev", count: "119" },
        { icon: "🎯", label: "Product & Design", count: "80" },
        { icon: "📋", label: "Project & Program Mgmt", count: "100" },
        { icon: "🤝", label: "Nonprofit & Community", count: "120" },
        { icon: "📉", label: "Data & Analytics", count: "80" },
        { icon: "🏢", label: "Administration & Office", count: "100" },
        { icon: "🔬", label: "Research & Development", count: "40" },
        { icon: "🏨", label: "Hospitality & Events", count: "40" },
        { icon: "🧠", label: "Consulting & Strategy", count: "40" },
        { icon: "🏛️", label: "Government & Compliance", count: "40" },
        { icon: "🎓", label: "Customer Success", count: "40" },
      ].map((cat) => (
        <div class="rounded-lg border border-border bg-white p-3 text-center">
          <div class="text-xl">{cat.icon}</div>
          <p class="mt-1 text-xs font-semibold text-navy">{cat.label}</p>
          <p class="text-[10px] text-text-muted">{cat.count} bullets</p>
        </div>
      ))}
    </div>

    <p class="mt-6 text-center text-sm text-text-muted">
      Every bullet is quantified with real numbers. Find your role, grab the bullets, make them yours.
    </p>
  </Fragment>

  <!-- Full content after gate: just the Sheet CTA + how to use -->
  <Fragment slot="full">
    <!-- Google Sheet CTA -->
    <div class="mb-10 rounded-xl bg-blue-bg p-8 text-center">
      <h2 class="text-xl font-bold text-navy">Your Achievement Bank is Ready</h2>
      <p class="mx-auto mt-2 max-w-md text-sm text-text-muted">Click below to copy the spreadsheet to your Google Drive. Find your job title, pick the bullets that match your experience, and customize the numbers.</p>
      <a
        href={SHEET_COPY_URL}
        target="_blank"
        rel="noopener"
        class="mt-5 inline-flex items-center justify-center gap-2 rounded-lg bg-blue px-8 py-4 text-base font-semibold text-white transition-colors hover:bg-blue-dark"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2" />
        </svg>
        Copy to My Google Drive
      </a>
    </div>

    <!-- How to use it -->
    <div class="rounded-xl border-2 border-blue/20 bg-blue-bg/30 p-8">
      <h2 class="text-xl font-bold text-navy">How to Use This</h2>

      <ol class="mt-6 space-y-4">
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">1</span>
          <div>
            <p class="font-semibold text-navy">Find your job title</p>
            <p class="text-sm text-text-muted">Use the Table of Contents tab or filter the main sheet by Industry and Job Title.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">2</span>
          <div>
            <p class="font-semibold text-navy">Pick 10-15 bullets that match your experience</p>
            <p class="text-sm text-text-muted">Don't copy them word for word. Use them as a starting point and swap in your own numbers.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">3</span>
          <div>
            <p class="font-semibold text-navy">Replace the numbers with yours</p>
            <p class="text-sm text-text-muted">The structure is the hard part. The numbers are yours. If you don't have exact figures, use conservative estimates.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">4</span>
          <div>
            <p class="font-semibold text-navy">Check the "Weak vs. Strong" tab</p>
            <p class="text-sm text-text-muted">See 10 before/after examples showing exactly what turns a generic bullet into one that gets interviews.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">5</span>
          <div>
            <p class="font-semibold text-navy">Update your resume and LinkedIn</p>
            <p class="text-sm text-text-muted">Put your strongest 4-5 bullets per role on your resume. Copy them to your LinkedIn Experience section too.</p>
          </div>
        </li>
      </ol>
    </div>

    <!-- Cross-link to related content -->
    <div class="mt-10 text-center">
      <p class="text-sm text-text-muted">Want to learn the full process for mining achievements from your own experience?</p>
      <a href="/blog/achievement-mining-how-to-quantify-your-resume-bullets" class="mt-2 inline-block text-sm font-semibold text-blue hover:text-blue-dark">
        Read the Achievement Mining Playbook →
      </a>
    </div>
  </Fragment>
</LeadMagnetLayout>
