// Preview: show first 3 roles from first category
const previewRoles = categories[0].roles.slice(0, 3);
---

<LeadMagnetLayout
  title="40 Job Titles You've Never Heard Of That Pay $100K+ | ClearCareer"
  description="40 non-obvious, lesser-known job titles in Canada that pay $100K+ at the senior level. Real roles being hired for right now, with salary data and search links."
  headline="40 Job Titles You've Never<br />Heard Of That Pay $100K+"
  subheadline="You're not stuck. You just don't know these roles exist. Every one of them is actively being hired for in Canada right now."
  bullets={[
    "40 verified roles across 8 categories (AI, Revenue, Data, People, ESG, Ops, Healthcare, Creative)",
    "Plain-English descriptions of what each role actually does",
    "Real Canadian companies hiring for each role right now",
    "Direct LinkedIn and Indeed search links for every title",
  ]}
  source="hidden-job-titles"
  storageKey="hidden_titles_unlocked"
  ctaText="See All 40 Roles"
>
  <!-- Preview Slot -->
  <Fragment slot="preview">
    <!-- Category Cards -->
    <div class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
      {categories.map((cat) => (
        <div class="rounded-xl border border-border bg-white p-4 text-center">
          <p class="text-2xl">{cat.emoji}</p>
          <p class="mt-1 text-sm font-bold text-navy">{cat.name}</p>
          <p class="text-xs text-text-muted">{cat.count} roles</p>
          <p class="text-xs font-semibold text-blue">{cat.range}</p>
        </div>
      ))}
    </div>

    <!-- Preview: 3 sample roles -->
    <div class="space-y-4">
      {previewRoles.map((role) => (
        <div class="rounded-xl border border-border bg-white p-5">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-bold text-navy">{role.title}</h3>
              <p class="mt-1 text-sm text-text-muted">{role.desc}</p>
            </div>
            <span class="shrink-0 rounded-lg bg-blue-bg px-3 py-1 text-sm font-bold text-blue">{role.salary.split(" - ")[1] || role.salary}</span>
          </div>
          <div class="mt-3 flex flex-wrap gap-2">
            {role.skills.slice(0, 3).map((skill) => (
              <span class="rounded-full bg-blue-bg/50 px-3 py-1 text-xs text-text-muted">{skill}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Blurred roles -->
    <div class="relative mt-2 overflow-hidden" style="max-height: 160px;">
      <div class="pointer-events-none select-none blur-[6px] opacity-50 space-y-4" aria-hidden="true">
        {categories[0].roles.slice(3, 5).map((role) => (
          <div class="rounded-xl border border-border bg-white p-5">
            <h3 class="font-bold text-navy">{role.title}</h3>
            <p class="mt-1 text-sm text-text-muted">{role.desc}</p>
          </div>
        ))}
      </div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-white/70 to-white"></div>
    </div>

    <p class="mt-6 text-center text-sm font-medium text-text-muted">
      + 37 more roles hiding behind that blur...
    </p>
  </Fragment>

  <!-- Full Content Slot (gated) -->
  <Fragment slot="full">
    <!-- Search + Category Filter -->
    <div class="mb-4">
      <input type="text" id="titles-search" placeholder="Search job titles..." class="w-full rounded-lg border border-border bg-white px-4 py-3 text-sm text-text shadow-sm placeholder:text-text-muted focus:border-blue focus:outline-none focus:ring-2 focus:ring-blue/20" />
    </div>
    <div class="mb-8 flex flex-wrap gap-2" id="titles-filters">
      <button data-filter="all" class="rounded-full bg-navy px-4 py-1.5 text-xs font-semibold text-white transition-colors">All</button>
      {categories.map((cat) => (
        <button data-filter={cat.name} class="rounded-full border border-border bg-white px-4 py-1.5 text-xs font-semibold text-text-muted transition-colors hover:border-blue hover:text-blue">{cat.emoji} {cat.name}</button>
      ))}
    </div>

    <p id="titles-no-results" class="mb-8 hidden text-center text-sm text-text-muted">No roles match your search.</p>

    {categories.map((cat) => (
      <div class="mb-12 titles-category" data-category={cat.name}>
        <h2 class="mb-1 flex items-center gap-2 text-xl font-bold text-navy">
          <span>{cat.emoji}</span> {cat.name}
        </h2>
        <p class="mb-6 text-sm text-text-muted">{cat.count} roles | Senior salary range: {cat.range}</p>

        <div class="space-y-6">
          {cat.roles.map((role) => (
            <div class="rounded-xl border border-border bg-white p-6 titles-role" data-title={role.title.toLowerCase()} data-category={cat.name}>
              <div class="flex items-start justify-between gap-4">
                <h3 class="text-lg font-bold text-navy">{role.num}. {role.title}</h3>
                <span class="shrink-0 rounded-lg bg-blue-bg px-3 py-1.5 text-sm font-bold text-blue">{role.salary}</span>
              </div>

              <p class="mt-2 text-sm text-text-muted">{role.desc}</p>

              <div class="mt-4 grid gap-4 sm:grid-cols-2">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wide text-navy">Who hires</p>
                  <p class="mt-1 text-sm text-text-muted">{role.hires}</p>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wide text-navy">Key skills</p>
                  <ul class="mt-1 space-y-1">
                    {role.skills.map((skill) => (
                      <li class="flex items-start gap-2 text-sm text-text-muted">
                        <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-blue"></span>
                        {skill}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <p class="mt-4 text-sm text-text-muted"><strong class="text-navy">Why it's hot:</strong> {role.hot}</p>

              <div class="mt-4 flex gap-3">
                <a href={role.linkedin} target="_blank" rel="noopener" class="rounded-lg bg-blue px-4 py-2 text-xs font-semibold text-white hover:bg-blue-dark">Search LinkedIn</a>
                <a href={role.indeed} target="_blank" rel="noopener" class="rounded-lg border border-border px-4 py-2 text-xs font-semibold text-navy hover:bg-blue-bg/30">Search Indeed</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}

    <!-- How to Use -->
    <div class="mt-12 rounded-xl border-2 border-blue/20 bg-blue-bg/30 p-8">
      <h2 class="text-xl font-bold text-navy">See a Role That Fits?</h2>
      <ol class="mt-6 space-y-4">
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">1</span>
          <div>
            <p class="font-semibold text-navy">Click the search links to see what's posted right now</p>
            <p class="text-sm text-text-muted">LinkedIn and Indeed links are pre-filtered for Canada.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">2</span>
          <div>
            <p class="font-semibold text-navy">Update your resume to highlight the matching skills</p>
            <p class="text-sm text-text-muted">Focus on the key skills listed for the role you're targeting.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">3</span>
          <div>
            <p class="font-semibold text-navy">Research the companies listed in "Who hires"</p>
            <p class="text-sm text-text-muted">Go directly to their careers pages. Many roles aren't posted on job boards.</p>
          </div>
        </li>
      </ol>
    </div>

    <!-- Sources -->
    <div class="mt-12 border-t border-border pt-6">
      <button id="sources-toggle" class="flex items-center gap-2 text-sm font-semibold text-text-muted hover:text-navy">
        <svg id="sources-chevron" class="h-4 w-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        Sources & References
      </button>
      <div id="sources-list" style="display: none;" class="mt-4 text-sm text-text-muted">
        <p class="mb-2">Salary data and job availability verified through:</p>
        <ul class="list-disc pl-5 space-y-1">
          <li><a href="https://www.glassdoor.ca/Salaries" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">Glassdoor Canada</a>, <a href="https://www.payscale.com/research/CA" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">PayScale Canada</a>, <a href="https://ca.indeed.com/career" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">Indeed Canada</a></li>
          <li><a href="https://www.salaryexpert.com" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">ERI SalaryExpert</a>, <a href="https://www.ziprecruiter.com/Salaries" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">ZipRecruiter</a>, <a href="https://www.salary.com/research/salary" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">Salary.com</a></li>
          <li><a href="https://www.roberthalf.com/ca/en/insights/salary-guide" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">Robert Half 2026</a>, <a href="https://salaryguide-americas.hays.com/canada/en/" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">Hays 2026</a>, <a href="https://www.randstad.ca/employers/salary-guide/" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">Randstad 2026</a> salary guides</li>
          <li><a href="https://eco.ca/environmental-employers/salary-guide-2025/" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">ECO Canada Environmental Salary Guide</a></li>
          <li><a href="https://www.levels.fyi" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">Levels.fyi</a>, <a href="https://www.morganmckinley.com/ca/salary-guide" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">Morgan McKinley 2026</a></li>
          <li><a href="https://www.adp.com/spark/articles/2026/01/key-employee-experience-trends-for-2026-and-how-to-prioritize.aspx" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">ADP Employee Experience Trends 2026</a></li>
          <li>Job availability confirmed via <a href="https://www.linkedin.com/jobs" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">LinkedIn Canada</a> and <a href="https://ca.indeed.com" target="_blank" rel="noopener" class="text-blue hover:text-blue-dark">Indeed Canada</a></li>
        </ul>
        <p class="mt-3 text-xs">All salary ranges reflect senior-level base salary in CAD. Data compiled April 2026.</p>
      </div>
    </div>
  </Fragment>
</LeadMagnetLayout>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var searchInput = document.getElementById('titles-search');
  var filterBtns = document.querySelectorAll('#titles-filters button');
  var catSections = document.querySelectorAll('.titles-category');
  var noResults = document.getElementById('titles-no-results');
  var activeFilter = 'all';

  function applyFilters() {
    var query = (searchInput ? searchInput.value : '').toLowerCase().trim();
    var visibleCount = 0;
    catSections.forEach(function(sec) {
      var cat = sec.getAttribute('data-category');
      var catMatch = activeFilter === 'all' || cat === activeFilter;
      var catHasVisible = false;
      sec.querySelectorAll('.titles-role').forEach(function(role) {
        var title = role.getAttribute('data-title');
        var titleMatch = !query || title.indexOf(query) !== -1;
        if (catMatch && titleMatch) {
          role.style.display = '';
          catHasVisible = true;
          visibleCount++;
        } else {
          role.style.display = 'none';
        }
      });
      sec.style.display = catHasVisible ? '' : 'none';
    });
    if (noResults) {
      noResults.style.display = visibleCount === 0 ? '' : 'none';
      noResults.classList.toggle('hidden', visibleCount > 0);
    }
  }

  if (searchInput) searchInput.addEventListener('input', applyFilters);

  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      activeFilter = btn.getAttribute('data-filter');
      filterBtns.forEach(function(b) {
        b.className = 'rounded-full border border-border bg-white px-4 py-1.5 text-xs font-semibold text-text-muted transition-colors hover:border-blue hover:text-blue';
      });
      btn.className = 'rounded-full bg-navy px-4 py-1.5 text-xs font-semibold text-white transition-colors';
      applyFilters();
    });
  });

  // Sources toggle
  var sourcesToggle = document.getElementById('sources-toggle');
  var sourcesList = document.getElementById('sources-list');
  var sourcesChevron = document.getElementById('sources-chevron');
  if (sourcesToggle) {
    sourcesToggle.addEventListener('click', function() {
      var isHidden = sourcesList.style.display === 'none';
      sourcesList.style.display = isHidden ? '' : 'none';
      sourcesChevron.style.transform = isHidden ? 'rotate(90deg)' : '';
    });
  }
});
</script>
