    { num: 39, title: "Localization Program Manager", desc: "Manages adapting products and content for different languages and markets. Not just translation.", hires: "Shopify, Google, Microsoft, Ubisoft Montreal, EA, e-commerce platforms, SaaS companies expanding internationally", salary: "$100,000 - $135,000 (director: up to $206K)", skills: ["Translation management systems (memoQ, Smartling, Phrase)", "Internationalization (i18n) technical concepts", "Vendor management and quality assurance", "Project management across time zones and languages"], hot: "Canadian companies expanding globally and global companies operating in bilingual Canada both need this. Managing 10+ languages is genuinely hard.", linkedin: "https://www.linkedin.com/jobs/search/?keywords=localization%20manager&location=Canada", indeed: "https://ca.indeed.com/jobs?q=localization+program+manager" },
    { num: 40, title: "Conversation Designer", desc: "Designs how chatbots, voice assistants, and AI agents talk to people. Writes dialogue flows, personality, error handling.", hires: "All Big 5 banks, Bell, Rogers, Telus, tech companies building AI products, contact center tech", salary: "$100,000 - $140,000", skills: ["Dialogue design and conversational UX", "NLU/NLP platforms (Dialogflow, Amazon Lex, Rasa)", "Prompt engineering for LLM-powered conversations", "Error handling and escalation flow design"], hot: "Every company is deploying AI chat and voice assistants, but most sound terrible. The person who makes AI pleasant to talk to is in high demand.", linkedin: "https://www.linkedin.com/jobs/search/?keywords=conversation%20designer&location=Canada", indeed: "https://ca.indeed.com/jobs?q=conversation+designer" },
