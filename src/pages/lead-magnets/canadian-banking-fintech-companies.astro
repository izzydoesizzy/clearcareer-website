---
import LeadMagnetLayout from "@layouts/LeadMagnetLayout.astro";
import companies from "@data/canadian-finance-companies.json";

// Group by subcategory
const subcategories = [...new Set(companies.map((c) => c.subcategory))];
const grouped = subcategories.map((sub) => ({
  name: sub,
  companies: companies.filter((c) => c.subcategory === sub),
}));

// Preview: first 12 companies (Traditional Banks)
const previewCompanies = companies.filter((c) => c.subcategory === "Traditional Banks").slice(0, 12);

const SHEET_COPY_URL = "https://docs.google.com/spreadsheets/d/1GNyVSBTVlmkMEBDRp7f3D4XzNVsjX1gpNL3XsLhGBAY/copy";
---

<LeadMagnetLayout
  title="76 Companies Hiring in Canadian Banking & Fintech | ClearCareer"
  description="Stop limiting your job search to the Big 5. Here are 76 banks, fintechs, neobanks, and financial services companies hiring in Canada."
  headline="76 Companies Hiring in Canadian Banking & Fintech"
  subheadline="Most people stop at RBC, TD, and BMO. Here are 76 companies you should actually be looking at."
  bullets={[
    "76 companies across 11 categories (banks, fintech, neobanks, payments, crypto, and more)",
    "Direct links to every company's LinkedIn page and recent job posts",
    "Organized by sector so you can target the right companies for your skills",
    "Google Sheet you can copy and customize for your own job search",
  ]}
  source="canadian-finance-companies"
  storageKey="canadian_finance_unlocked"
  ctaText="Get the Full List"
>
  <!-- Preview Slot -->
  <Fragment slot="preview">
    <h2 class="mb-2 text-lg font-bold text-navy">Preview: Traditional Banks</h2>
    <p class="mb-6 text-sm text-text-muted">Here's a taste. The full list has 76 companies across 11 categories.</p>

    <div class="overflow-x-auto rounded-xl border border-border">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-navy text-white">
            <th class="px-4 py-3 text-left font-semibold">Company</th>
            <th class="px-4 py-3 text-left font-semibold hidden sm:table-cell">Description</th>
            <th class="px-4 py-3 text-center font-semibold">LinkedIn</th>
          </tr>
        </thead>
        <tbody>
          {previewCompanies.map((c, i) => (
            <tr class:list={[i % 2 === 0 ? "bg-white" : "bg-blue-bg/30"]}>
              <td class="px-4 py-3 font-medium text-navy">
                <a href={c.website} target="_blank" rel="noopener" class="hover:text-blue">{c.name}</a>
              </td>
              <td class="px-4 py-3 text-text-muted hidden sm:table-cell">{c.description}</td>
              <td class="px-4 py-3 text-center">
                <a href={c.linkedin} target="_blank" rel="noopener" class="text-blue hover:text-blue-dark text-xs font-semibold">View</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Blurred tease -->
    <div class="relative mt-0 overflow-hidden" style="max-height: 120px;">
      <div class="pointer-events-none select-none blur-sm opacity-40" aria-hidden="true">
        <table class="w-full text-sm">
          <tbody>
            {[1,2,3,4].map((i) => (
              <tr class:list={[i % 2 === 0 ? "bg-white" : "bg-blue-bg/30"]}>
                <td class="px-4 py-3 font-medium text-navy">Company Name Here</td>
                <td class="px-4 py-3 text-text-muted">Description of the company and what they do.</td>
                <td class="px-4 py-3 text-center text-blue text-xs">View</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-white/80 to-white"></div>
    </div>

    <p class="mt-4 text-center text-sm text-text-muted">
      + 64 more companies across fintech, neobanks, payments, crypto, and more...
    </p>
  </Fragment>

  <!-- Full Content Slot (gated) -->
  <Fragment slot="full">
    <!-- Google Sheet CTA -->
    <div class="mb-10 rounded-xl bg-blue-bg p-6 text-center">
      <h2 class="text-lg font-bold text-navy">Get the Spreadsheet</h2>
      <p class="mt-2 text-sm text-text-muted">Click below to copy this list to your Google Drive. Add your own notes, track your outreach, and customize it for your search.</p>
      <a
        href={SHEET_COPY_URL}
        target="_blank"
        rel="noopener"
        class="mt-4 inline-flex items-center justify-center gap-2 rounded-lg bg-blue px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-dark"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2" />
        </svg>
        Copy to My Google Drive
      </a>
    </div>

    <!-- Full Company List by Subcategory -->
    {grouped.map((group) => (
      <div class="mb-10">
        <h2 class="mb-1 text-xl font-bold text-navy">{group.name}</h2>
        <p class="mb-4 text-sm text-text-muted">{group.companies.length} companies</p>

        <div class="overflow-x-auto rounded-xl border border-border">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-navy text-white">
                <th class="px-4 py-3 text-left font-semibold">Company</th>
                <th class="px-4 py-3 text-left font-semibold hidden sm:table-cell">Description</th>
                <th class="px-4 py-3 text-center font-semibold">LinkedIn</th>
                <th class="px-4 py-3 text-center font-semibold hidden md:table-cell">Posts</th>
              </tr>
            </thead>
            <tbody>
              {group.companies.map((c, i) => (
                <tr class:list={[i % 2 === 0 ? "bg-white" : "bg-blue-bg/30", "hover:bg-blue-bg/50 transition-colors"]}>
                  <td class="px-4 py-3">
                    <a href={c.website} target="_blank" rel="noopener" class="font-medium text-navy hover:text-blue">{c.name}</a>
                  </td>
                  <td class="px-4 py-3 text-text-muted hidden sm:table-cell">{c.description}</td>
                  <td class="px-4 py-3 text-center">
                    <a href={c.linkedin} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-blue hover:text-blue-dark text-xs font-semibold">
                      Profile
                    </a>
                  </td>
                  <td class="px-4 py-3 text-center hidden md:table-cell">
                    <a href={c.linkedinPosts} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-blue hover:text-blue-dark text-xs font-semibold">
                      Recent
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    ))}

    <!-- How to Use This List -->
    <div class="mt-12 rounded-xl border-2 border-blue/20 bg-blue-bg/30 p-8">
      <h2 class="text-xl font-bold text-navy">How to Use This List</h2>
      <p class="mt-2 text-text-muted">Don't just bookmark it. Work it. Here's your 5-step plan:</p>

      <ol class="mt-6 space-y-4">
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">1</span>
          <div>
            <p class="font-semibold text-navy">Pick 10-15 companies that match your skills</p>
            <p class="text-sm text-text-muted">Don't try to target all 76. Focus on the sectors where your experience fits best.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">2</span>
          <div>
            <p class="font-semibold text-navy">Follow each one on LinkedIn</p>
            <p class="text-sm text-text-muted">Click the "Recent Posts" link for each company. Follow them so their updates appear in your feed.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">3</span>
          <div>
            <p class="font-semibold text-navy">Find 2-3 people at each company to connect with</p>
            <p class="text-sm text-text-muted">Search "[Company name] + [your target role]" on LinkedIn. Look for hiring managers, team leads, and recruiters.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">4</span>
          <div>
            <p class="font-semibold text-navy">Start commenting on their posts</p>
            <p class="text-sm text-text-muted">Not "great post." Add your perspective, share a related experience, or ask a smart question. Do this for 2-3 weeks.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">5</span>
          <div>
            <p class="font-semibold text-navy">Send a personalized connection request</p>
            <p class="text-sm text-text-muted">After they've seen your name a few times, your message won't be cold anymore. That's the whole game.</p>
          </div>
        </li>
      </ol>
    </div>
  </Fragment>
</LeadMagnetLayout>
