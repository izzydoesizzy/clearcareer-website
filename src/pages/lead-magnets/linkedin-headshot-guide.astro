---
import LeadMagnetLayout from "@layouts/LeadMagnetLayout.astro";

const PDF_URL = "/downloads/diy-linkedin-headshot-guide.pdf";
---

<LeadMagnetLayout
  title="DIY LinkedIn Headshot Guide — Take a Professional Photo at Home | ClearCareer"
  description="Take a professional LinkedIn headshot at home with just your phone. Step-by-step guide covering lighting, posing, camera settings, what to wear, and editing."
  headline="Take a Professional LinkedIn Headshot<br />at Home With Your Phone"
  subheadline="No photographer needed. This 7-page guide covers lighting, posing, camera settings, what to wear, and editing. Everything you need to look polished and confident."
  bullets={[
    "Profiles with a professional photo get 21x more views and 36x more messages",
    "Step-by-step setup: lighting, background, camera settings, and wardrobe",
    "5 go-to poses that work for any industry (with exact angles)",
    "Do's and Don'ts cheat sheet you can reference while shooting",
    "Final checklist to make sure your photo is upload-ready",
  ]}
  source="linkedin-headshot"
  storageKey="linkedin_headshot_unlocked"
  ctaText="Get the Free Guide"
  deliveryType="pdf"
>
  <!-- Cheat Sheet Preview -->
  <Fragment slot="hero-image">
    <section class="pb-4">
      <div class="mx-auto max-w-[480px] px-4">
        <div class="overflow-hidden rounded-xl border border-border shadow-lg bg-white">
          <!-- Visual representation of the cheat sheet -->
          <div class="bg-gradient-to-r from-[#4a9e8e] to-[#3d8b7d] px-6 py-4 text-center">
            <p class="text-lg font-bold text-white">DIY LinkedIn Headshot</p>
            <p class="text-sm font-semibold text-white/80">QUICK-START CHEAT SHEET</p>
          </div>
          <div class="grid grid-cols-2 gap-4 p-5 text-sm">
            <div>
              <p class="font-bold text-[#4a9e8e] text-xs uppercase tracking-wide">What You Need</p>
              <ul class="mt-1.5 space-y-0.5 text-xs text-text-muted">
                <li>Smartphone (any recent model)</li>
                <li>Tripod or stack of books</li>
                <li>A window with natural light</li>
                <li>Clean, plain background</li>
              </ul>
            </div>
            <div>
              <p class="font-bold text-[#4a9e8e] text-xs uppercase tracking-wide">5 Go-To Poses</p>
              <ul class="mt-1.5 space-y-0.5 text-xs text-text-muted">
                <li><strong>Classic:</strong> Squared shoulders</li>
                <li><strong>Quarter Turn:</strong> Body angled</li>
                <li><strong>Crossed Arms:</strong> Confident</li>
                <li><strong>The Lean:</strong> Warm, engaging</li>
              </ul>
            </div>
          </div>
          <div class="border-t border-border px-5 py-3 text-center">
            <p class="text-[10px] text-text-muted">+ full guide: lighting, camera settings, what to wear, editing tips, and final checklist</p>
          </div>
        </div>
      </div>
    </section>
  </Fragment>

  <!-- Preview: why it matters + what's inside -->
  <Fragment slot="preview">
    <!-- Stats -->
    <h2 class="mb-6 text-center text-lg font-bold text-navy">Why Your LinkedIn Photo Matters</h2>

    <div class="mb-8 grid grid-cols-1 gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-border bg-blue-bg/30 p-5 text-center">
        <p class="text-3xl font-bold text-blue">21x</p>
        <p class="mt-1 text-sm text-text-muted">more profile views with a professional photo</p>
      </div>
      <div class="rounded-xl border border-border bg-blue-bg/30 p-5 text-center">
        <p class="text-3xl font-bold text-blue">36x</p>
        <p class="mt-1 text-sm text-text-muted">more messages from recruiters and connections</p>
      </div>
      <div class="rounded-xl border border-border bg-blue-bg/30 p-5 text-center">
        <p class="text-3xl font-bold text-blue">$0</p>
        <p class="mt-1 text-sm text-text-muted">cost: just your phone and a window</p>
      </div>
    </div>

    <p class="mb-8 text-center text-sm text-text-muted">
      Your headshot is the first impression a recruiter, hiring manager, or connection has of you. You don't need a professional photographer. With the right setup and a few simple techniques, you can take a headshot at home that looks polished, confident, and ready for your next opportunity.
    </p>

    <!-- What's in the guide -->
    <h3 class="mb-4 text-center text-base font-bold text-navy">What's in the Guide</h3>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
      {[
        { icon: "💡", label: "Lighting Setup", detail: "Window positioning, time of day, avoiding shadows" },
        { icon: "📱", label: "Camera Settings", detail: "Portrait mode, HDR, grid overlay, rear camera" },
        { icon: "👔", label: "What to Wear", detail: "Colors, patterns, and styles that photograph well" },
        { icon: "🧍", label: "5 Poses", detail: "Classic, Quarter Turn, Crossed Arms, Lean, Look Away" },
        { icon: "✂️", label: "Edit & Upload", detail: "Crop, brightness, contrast (no heavy filters)" },
        { icon: "✅", label: "Final Checklist", detail: "8-point check before you hit upload" },
      ].map((item) => (
        <div class="rounded-lg border border-border bg-white p-3 text-center">
          <div class="text-xl">{item.icon}</div>
          <p class="mt-1 text-xs font-semibold text-navy">{item.label}</p>
          <p class="mt-0.5 text-[10px] text-text-muted">{item.detail}</p>
        </div>
      ))}
    </div>

    <!-- Do's and Don'ts preview -->
    <div class="mt-8 grid grid-cols-2 gap-4">
      <div class="rounded-xl border border-green-200 bg-green-50/50 p-4">
        <p class="mb-2 text-sm font-bold text-green-700">TOP DOs</p>
        <ul class="space-y-1.5 text-xs text-text-muted">
          <li>Face a window for soft, natural light</li>
          <li>Use rear camera + Portrait Mode</li>
          <li>Wear solid jewel tones</li>
          <li>Take 30+ shots and pick the best</li>
          <li>Crop square, light edits only</li>
        </ul>
      </div>
      <div class="rounded-xl border border-red-200 bg-red-50/50 p-4">
        <p class="mb-2 text-sm font-bold text-red-600">TOP DON'Ts</p>
        <ul class="space-y-1.5 text-xs text-text-muted">
          <li>Use flash or overhead lights</li>
          <li>Zoom in (move closer instead)</li>
          <li>Wear busy patterns or logos</li>
          <li>Settle for 1-2 quick selfies</li>
          <li>Use heavy filters or skin smoothing</li>
        </ul>
      </div>
    </div>

    <p class="mt-6 text-center text-sm text-text-muted">
      The full guide breaks each section down step by step, with pro tips you won't find in a quick Google search.
    </p>
  </Fragment>

  <!-- Full content after gate -->
  <Fragment slot="full">
    <!-- PDF Download CTA -->
    <div class="mb-10 rounded-xl bg-blue-bg p-8 text-center">
      <h2 class="text-xl font-bold text-navy">Your Headshot Guide is Ready</h2>
      <p class="mx-auto mt-2 max-w-md text-sm text-text-muted">Download the 7-page PDF. It includes a one-page cheat sheet you can pull up on your phone while shooting, plus the full step-by-step guide.</p>
      <a
        href={PDF_URL}
        target="_blank"
        rel="noopener"
        class="mt-5 inline-flex items-center justify-center gap-2 rounded-lg bg-blue px-8 py-4 text-base font-semibold text-white transition-colors hover:bg-blue-dark"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Download the PDF Guide
      </a>
    </div>

    <!-- Quick-start steps -->
    <div class="rounded-xl border-2 border-blue/20 bg-blue-bg/30 p-8">
      <h2 class="text-xl font-bold text-navy">Quick-Start: Your Shoot in 4 Steps</h2>

      <ol class="mt-6 space-y-4">
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">1</span>
          <div>
            <p class="font-semibold text-navy">Set the scene</p>
            <p class="text-sm text-text-muted">Find a large window. Face it. Put a clean, plain wall behind you. Turn off overhead lights. That's your studio.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">2</span>
          <div>
            <p class="font-semibold text-navy">Set up your phone</p>
            <p class="text-sm text-text-muted">Prop it at eye level (tripod, stack of books, shelf). Use the rear camera in Portrait Mode. Turn on HDR and the grid overlay. Set the timer to 10 seconds.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">3</span>
          <div>
            <p class="font-semibold text-navy">Shoot 30+ photos</p>
            <p class="text-sm text-text-muted">Try all 5 poses from the guide. Vary your smile. Take way more than you think you need. You're looking for one great shot, not a perfect first take.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue text-xs font-bold text-white">4</span>
          <div>
            <p class="font-semibold text-navy">Pick, crop, upload</p>
            <p class="text-sm text-text-muted">Narrow to your top 3. Crop to square (1:1). Bump brightness and contrast slightly. Upload to LinkedIn. Done.</p>
          </div>
        </li>
      </ol>
    </div>

    <!-- Cross-link -->
    <div class="mt-10 text-center">
      <p class="text-sm text-text-muted">Got your headshot sorted? Now make sure the rest of your profile is working just as hard.</p>
      <a href="/lead-magnets/linkedin-banners" class="mt-2 inline-block text-sm font-semibold text-blue hover:text-blue-dark">
        Grab a free LinkedIn banner to match &rarr;
      </a>
    </div>
  </Fragment>
</LeadMagnetLayout>
