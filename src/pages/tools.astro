---
import PageLayout from "@layouts/PageLayout.astro";
import Hero from "@components/Hero.astro";
import CTASection from "@components/CTASection.astro";

import toolsData from "@data/tools.json";

// Group tools by category
const categories = [...new Set(toolsData.map((t) => t.category))];
const toolsByCategory = categories.map((cat) => ({
  name: cat,
  tools: toolsData.filter((t) => t.category === cat),
}));

const pricingColors: Record<string, string> = {
  Free: "bg-success/10 text-success",
  Freemium: "bg-blue-bg text-blue",
  Paid: "bg-warning/10 text-warning",
};
---

<PageLayout
  title="Career Tools & Resources | ClearCareer"
  description="Curated directory of career tools for job seekers. Resume builders, salary research, interview prep, and more. Personally tested and recommended."
>
  <!-- Hero -->
  <Hero
    variant="page"
    eyebrow="Career Tools"
    headline="Tools That Make Your Job Search Smarter"
    subheadline="Every tool on this page is one I've personally used with clients. Some are free, some are paid. All are worth your time."
  />

  <!-- Tools Grid by Category -->
  {toolsByCategory.map((category) => (
    <section class="py-16 md:py-24">
      <div class="mx-auto max-w-[1080px] px-4 sm:px-6 lg:px-8">
        <h3 class="text-2xl font-bold text-navy">{category.name}</h3>
        <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {category.tools.map((tool) => (
            <div class="flex flex-col rounded-xl border border-border bg-white p-6 transition-shadow hover:shadow-md">
              <div class="flex items-start justify-between gap-4">
                <h4 class="text-lg font-semibold text-text">{tool.name}</h4>
                <div class="flex flex-shrink-0 gap-2">
                  {tool.recommended && (
                    <span class="rounded-full bg-success/10 px-3 py-1 text-xs font-medium text-success">
                      Recommended
                    </span>
                  )}
                </div>
              </div>

              <div class="mt-3 flex gap-2">
                <span class="inline-block rounded-full bg-blue-bg px-3 py-1 text-xs font-medium text-blue">
                  {tool.category}
                </span>
                <span class={`inline-block rounded-full px-3 py-1 text-xs font-medium ${pricingColors[tool.pricing] || "bg-blue-bg text-blue"}`}>
                  {tool.pricing}
                </span>
              </div>

              <p class="mt-3 text-[1.0625rem] leading-[1.75] text-text-muted">
                {tool.description}
              </p>

              {tool.review && (
                <p class="mt-3 border-l-2 border-blue pl-4 text-sm italic text-text-muted">
                  "{tool.review}"
                </p>
              )}

              <div class="mt-auto pt-4">
                {tool.url && (
                  <a
                    href={tool.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center text-sm font-semibold text-blue hover:text-blue-dark"
                  >
                    Visit {tool.name} &rarr;
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Affiliate Disclosure -->
  <section class="border-t border-border py-8">
    <div class="mx-auto max-w-[1080px] px-4 sm:px-6 lg:px-8">
      <p class="text-sm text-text-muted">
        <strong>Disclosure:</strong> Some links on this page are affiliate links. If you sign up through these links, ClearCareer may earn a small commission at no extra cost to you. We only recommend tools we personally use and believe in. Want detailed reviews? Check out our <a href="/affiliates" class="text-blue hover:text-blue-dark underline">full tool reviews and comparisons</a>.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    heading="Want Expert Guidance on Your Job Search?"
    primaryCTA={{ text: "Book a Free Audit", href: "https://calendly.com/clearcareer/discovery-call" }}
    variant="blue"
  />
</PageLayout>
