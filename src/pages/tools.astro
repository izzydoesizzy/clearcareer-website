---
import PageLayout from "@layouts/PageLayout.astro";
import Hero from "@components/Hero.astro";
import CTASection from "@components/CTASection.astro";

import toolsData from "@data/tools.json";

// Group tools by category
const categories = [...new Set(toolsData.map((t) => t.category))];
const toolsByCategory = categories.map((cat) => ({
  name: cat,
  tools: toolsData.filter((t) => t.category === cat),
}));
---

<PageLayout
  title="Career Tools & Resources | ClearCareer"
  description="Curated directory of career tools for job seekers. Resume builders, salary research, interview prep, and more."
>
  <!-- Hero -->
  <Hero
    variant="page"
    eyebrow="Career Tools"
    headline="Tools That Make Your Job Search Smarter"
    subheadline="Curated tools we recommend to our clients. Some are free, some are paid. All are worth your time."
  />

  <!-- Tools Grid by Category -->
  {toolsByCategory.map((category) => (
    <section class="py-16 md:py-24">
      <div class="mx-auto max-w-[1080px] px-4 sm:px-6 lg:px-8">
        <h3 class="text-2xl font-bold text-navy">{category.name}</h3>
        <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {category.tools.map((tool) => (
            <div class="rounded-xl border border-border bg-white p-6">
              <div class="flex items-start justify-between gap-4">
                <h4 class="text-lg font-semibold text-text">{tool.name}</h4>
                {tool.recommended && (
                  <span class="flex-shrink-0 rounded-full bg-success/10 px-3 py-1 text-xs font-medium text-success">
                    Recommended
                  </span>
                )}
              </div>
              <span class="mt-3 inline-block rounded-full bg-blue-bg px-3 py-1 text-xs font-medium text-blue">
                {tool.category}
              </span>
              <p class="mt-3 text-[1.0625rem] leading-[1.75] text-text-muted">
                {tool.description}
              </p>
              {tool.link && (
                <a
                  href={tool.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 inline-flex items-center text-sm font-semibold text-blue hover:text-blue-dark"
                >
                  Visit Tool &rarr;
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <CTASection
    heading="Want Expert Guidance on Your Job Search?"
    primaryCTA={{ text: "Book a Free Audit", href: "https://calendly.com/clearcareer/discovery-call" }}
    variant="blue"
  />
</PageLayout>
