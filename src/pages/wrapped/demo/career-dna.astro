---
import PageLayout from "@layouts/PageLayout.astro";
import CareerDNAResult from "@components/wrapped/CareerDNAResult";

const result = {
  archetype: {
    name: "The Community Alchemist",
    tagline: "Turns strangers into movements, movements into revenue",
    description: "You don't just build communities, you engineer ecosystems that generate measurable outcomes. From scaling Lighthouse Labs events 400% to converting 900 free members into 123 paying clients to facilitating retreats across 7 countries, you have an unusual ability to create gravity around ideas and then monetize the orbit. Most community builders stop at engagement. You build the engine underneath."
  },
  superpowers: [
    {
      name: "Ecosystem Engineering",
      evidence: "Scaled Lighthouse Labs from 150 to 650+ monthly attendees across 6 cities, built 30+ partnerships with McKinsey/PwC/Microsoft, and created two top-5% Skool communities within 90 days.",
      strength: 9
    },
    {
      name: "Methodology Creation",
      evidence: "Invented the CHARM Framework, Job Hacking methodology, Confident Selling System, and Job Search Ignition System, each adopted by hundreds of professionals as repeatable systems.",
      strength: 9
    },
    {
      name: "AI-Augmented Delivery",
      evidence: "Built custom GPTs deployed across 200+ client engagements, an AI client manager replacing 8-10 hours of manual work, a Claude Code marketing agent, and an AI headshot platform with Stripe payments.",
      strength: 8
    }
  ],
  hiddenPattern: {
    insight: "Every role you've held, without exception, follows the same playbook: enter a new territory nobody else wants to pioneer, build the infrastructure from scratch, then systematize it so others can run it without you. You're not a community builder. You're a first-mover who disguises market entry as community work.",
    evidence: "LeafLogix first Canadian entity + office, Canada's first freeCodeCamp conference, Hacker Paradise's expansion into 7 new countries, ClearCareer as the first AI-native coaching practice with custom tooling, and Unlock China bridging Western/Chinese tech ecosystems."
  },
  careerArc: {
    summary: "A steady escalation from facilitating programs for institutions to building and owning the entire platform, audience, and revenue stream yourself.",
    direction: "ascending" as const
  },
  rarityScore: "Your combination of community scaling + proprietary methodology creation + AI tool building is found in roughly 2% of professionals in the career services and ed-tech space."
};
---

<PageLayout title="Career DNA Demo | ClearCareer" description="Demo of the Career DNA result page.">
  <section class="bg-navy py-16 md:py-24">
    <div class="max-w-[1080px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-sm font-medium text-amber-400">
          Demo Preview
        </span>
      </div>
      <CareerDNAResult client:load result={result} resultId="demo" isOwner={false} />
    </div>
  </section>
</PageLayout>
