---
import PageLayout from "@layouts/PageLayout.astro";
import WrappedPrivacyFooter from "@components/wrapped/WrappedPrivacyFooter.astro";

const tools = [
  {
    slug: "career-dna",
    title: "Career DNA",
    description: "Discover your career archetype, superpowers, and hidden patterns most people never notice.",
    icon: "🧬",
    color: "#0161EF",
  },
  {
    slug: "roast",
    title: "Roast My Resume",
    description: "Get brutally honest (and hilarious) AI feedback on your resume. No feelings were spared.",
    icon: "🔥",
    color: "#D97706",
  },
  {
    slug: "worth",
    title: "What You're Actually Worth",
    description: "Find out your real market value, whether you're underpaid, and which companies pay top dollar.",
    icon: "💰",
    color: "#059669",
  },
  {
    slug: "five-cards",
    title: "Your Career in 5 Cards",
    description: "Your career story told in 5 swipeable cards. Shareable, surprising, and designed for social.",
    icon: "🃏",
    color: "#06b6d4",
  },
];
---

<PageLayout
  title="Career Wrapped | ClearCareer"
  description="Free AI-powered career analysis tools. Discover your Career DNA, get your resume roasted, find out what you're worth, and more. Shareable and fun."
>
  <!-- Hero -->
  <section class="bg-navy py-20 md:py-28">
    <div class="max-w-[1080px] mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-sm font-medium text-blue-light mb-6">
        Free Career Tools
      </div>
      <h1
        class="font-display text-[clamp(2rem,5vw,3.5rem)] leading-[1.05] text-white mb-4"
      >
        Your Career, Unwrapped
      </h1>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto leading-relaxed">
        Upload your resume. Get personalized AI-powered insights about your career
        in seconds. Share the results everywhere.
      </p>
    </div>
  </section>

  <!-- Tool Grid -->
  <section class="py-16 md:py-24">
    <div class="max-w-[1080px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-6">
        {tools.map((tool) => (
          <a
            href={tool.badge ? undefined : `/wrapped/${tool.slug}`}
            class:list={[
              "group relative rounded-2xl border border-border bg-white p-8 transition-all",
              tool.badge
                ? "opacity-60 cursor-default"
                : "hover:shadow-[var(--shadow-card-hover)] hover:border-[var(--color-blue)]/20 cursor-pointer",
            ]}
          >
            {tool.badge && (
              <span class="absolute top-4 right-4 rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-text-muted">
                {tool.badge}
              </span>
            )}
            <span class="text-4xl block mb-4">{tool.icon}</span>
            <h2 class="text-xl font-semibold text-navy mb-2 group-hover:text-blue transition-colors">
              {tool.title}
            </h2>
            <p class="text-text-muted leading-relaxed">
              {tool.description}
            </p>
            {!tool.badge && (
              <div class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-blue">
                Try it free
                <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="bg-blue-bg py-16 md:py-24">
    <div class="max-w-[720px] mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-[clamp(1.5rem,3vw,2.25rem)] leading-[1.15] text-navy mb-12">
        How It Works
      </h2>
      <div class="grid md:grid-cols-3 gap-8 text-left">
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue text-white text-sm font-bold mb-3">
            1
          </div>
          <h3 class="font-semibold text-navy mb-1">Upload your resume</h3>
          <p class="text-sm text-text-muted">PDF, Word, or just paste the text. Takes 10 seconds.</p>
        </div>
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue text-white text-sm font-bold mb-3">
            2
          </div>
          <h3 class="font-semibold text-navy mb-1">AI analyzes your career</h3>
          <p class="text-sm text-text-muted">Our AI reads between the lines of your experience.</p>
        </div>
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue text-white text-sm font-bold mb-3">
            3
          </div>
          <h3 class="font-semibold text-navy mb-1">Share your results</h3>
          <p class="text-sm text-text-muted">Download branded cards or share a link to LinkedIn and X.</p>
        </div>
      </div>
    </div>
  </section>
  <WrappedPrivacyFooter />
</PageLayout>
