---
import PageLayout from "@layouts/PageLayout.astro";
import WrappedPrivacyFooter from "@components/wrapped/WrappedPrivacyFooter.astro";
import ResumeUploader from "@components/wrapped/ResumeUploader";
---

<PageLayout
  title="Roast My Resume | ClearCareer"
  description="Get brutally honest (and hilarious) AI feedback on your resume. Sharp, funny, specific. No feelings were spared."
>
  <section class="bg-navy py-16 md:py-24">
    <div class="max-w-[1080px] mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <a href="/wrapped" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-white transition-colors mb-6">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        All Wrapped Tools
      </a>
      <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-sm font-medium text-[#D97706] mb-4">
        🔥 Roast My Resume
      </div>
      <h1 class="font-display text-[clamp(2rem,5vw,3rem)] leading-[1.1] text-white mb-3">
        Can Your Resume Take the Heat?
      </h1>
      <p class="text-lg text-gray-400 max-w-xl mx-auto leading-relaxed">
        Our AI will roast your resume with sharp, specific, actually-funny observations.
        Then it'll tell you what you're genuinely great at. You'll laugh, then you'll fix things.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-16 -mt-8">
    <div class="max-w-[1080px] mx-auto px-4 sm:px-6 lg:px-8">
      <ResumeUploader client:load tool="roast" toolLabel="Resume Roast" />
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div class="max-w-[720px] mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-[clamp(1.25rem,2.5vw,1.75rem)] leading-[1.2] text-navy text-center mb-8">
        What You'll Get
      </h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="rounded-xl bg-amber-50 p-5">
          <span class="text-2xl mb-2 block">😬</span>
          <h3 class="font-semibold text-navy mb-1">5 Specific Roasts</h3>
          <p class="text-sm text-text-muted">From mild observations to one savage truth bomb.</p>
        </div>
        <div class="rounded-xl bg-amber-50 p-5">
          <span class="text-2xl mb-2 block">📊</span>
          <h3 class="font-semibold text-navy mb-1">Overall Grade</h3>
          <p class="text-sm text-text-muted">A letter grade with a brutally honest subtitle.</p>
        </div>
        <div class="rounded-xl bg-amber-50 p-5">
          <span class="text-2xl mb-2 block">💛</span>
          <h3 class="font-semibold text-navy mb-1">The Redemption</h3>
          <p class="text-sm text-text-muted">What you're genuinely great at, stated sincerely.</p>
        </div>
        <div class="rounded-xl bg-amber-50 p-5">
          <span class="text-2xl mb-2 block">📸</span>
          <h3 class="font-semibold text-navy mb-1">Shareable Card</h3>
          <p class="text-sm text-text-muted">Download your grade card and share on LinkedIn or X.</p>
        </div>
      </div>
    </div>
  </section>
  <WrappedPrivacyFooter />
</PageLayout>
