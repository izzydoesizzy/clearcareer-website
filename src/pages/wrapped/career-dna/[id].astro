---
import PageLayout from "@layouts/PageLayout.astro";
import CareerDNAResult from "@components/wrapped/CareerDNAResult";
import { getResult } from "../../../lib/wrapped/storage";
import type { CareerDNAResult as CareerDNAData } from "../../../lib/wrapped/types";

export const prerender = false;

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/wrapped/career-dna");
}

const analysis = await getResult(id);

if (!analysis || analysis.tool !== "career-dna") {
  return Astro.redirect("/wrapped/career-dna");
}

const result = analysis.result as CareerDNAData;

// Check if the viewer just created this (via referrer or cookie - simple heuristic)
const referer = Astro.request.headers.get("referer") || "";
const isOwner = referer.includes("/wrapped/api/") || referer.includes("/wrapped/career-dna");

const ogImageUrl = `/wrapped/og/career-dna/${id}`;
---

<PageLayout
  title={`${result.archetype.name} | Career DNA | ClearCareer`}
  description={`${result.archetype.tagline}. Discover your Career DNA at ClearCareer.`}
  image={ogImageUrl}
>
  <!-- Result Section -->
  <section class="bg-navy py-16 md:py-24">
    <div class="max-w-[1080px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <a
          href="/wrapped"
          class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-white transition-colors"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Career Wrapped
        </a>
      </div>

      <CareerDNAResult
        client:load
        result={result}
        resultId={id}
        isOwner={isOwner}
      />
    </div>
  </section>
</PageLayout>
