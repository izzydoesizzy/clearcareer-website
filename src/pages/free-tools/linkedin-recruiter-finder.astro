---
import PageLayout from "@layouts/PageLayout.astro";
import CTASection from "@components/CTASection.astro";
import XRaySearchCoaching from "@components/tools/XRaySearchCoaching";
import { generateWebApplicationSchema, generateBreadcrumbSchema, generateFAQSchema } from "@utils/seo";

const title = "LinkedIn Recruiter Finder";
const description = "Find recruiters and hiring managers on LinkedIn using Google. Bypass LinkedIn's search limits and connect directly with the people who fill roles in your industry.";
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://joinclearcareer.com";
const toolUrl = `${siteUrl}/free-tools/linkedin-recruiter-finder`;

const faqItems = [
  { question: "How does this tool find recruiters?", answer: "It uses Google to search LinkedIn profiles directly, bypassing LinkedIn's free search limits. Google indexes public LinkedIn profiles, so this tool can find recruiters, hiring managers, and professionals by industry, location, and company without needing LinkedIn Premium." },
  { question: "Is searching LinkedIn through Google legal?", answer: "Yes. You're searching publicly available information that Google has already indexed. LinkedIn profiles that appear in Google search results are public. You're not scraping or accessing anything behind a login." },
  { question: "Why not just use LinkedIn's built-in search?", answer: "LinkedIn's free search limits results, hides profiles behind 'LinkedIn Member,' and pushes you toward Premium. Searching through Google has no limits, no paywall, and often surfaces profiles LinkedIn's own search misses." },
  { question: "What should I say when I connect?", answer: "Personalize every request. Mention their industry, a recent post, or a shared connection. Keep it under 300 characters. Ask for advice, not a job. Use our Networking Message Builder for templates." },
  { question: "How many connection requests should I send per week?", answer: "15-25 per week is sustainable. Quality matters more than quantity. 5 personalized requests outperform 50 generic ones. LinkedIn may restrict your account if you send too many too fast." },
  { question: "Does this work for hiring managers too?", answer: "Yes. Change the job title field to 'hiring manager' OR 'director' OR 'VP' to find decision-makers instead of recruiters. Same technique, different targets." },
];
---

<PageLayout title={`${title} | ClearCareer`} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateWebApplicationSchema({ name: title, description, url: toolUrl, category: "BusinessApplication", featureList: ["Google X-Ray search builder", "Boolean operator formatting", "Direct Google search link", "One-click copy"] }))} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateBreadcrumbSchema([{ name: "Home", url: siteUrl }, { name: "Free Tools", url: `${siteUrl}/free-tools` }, { name: title, url: toolUrl }]))} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateFAQSchema(faqItems))} />

  <section class="relative overflow-hidden bg-navy py-12 md:py-16">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -right-20 -top-20 h-[300px] w-[300px] rounded-full bg-blue/10 blur-[80px]"></div>
    </div>
    <div class="relative mx-auto max-w-[640px] px-4 sm:px-6">
      <nav aria-label="Breadcrumb" class="mb-6 text-sm text-white/50">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-white/80 transition-colors">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/free-tools" class="hover:text-white/80 transition-colors">Free Tools</a></li>
          <li aria-hidden="true">/</li>
          <li class="truncate text-white/70" aria-current="page">Recruiter Finder</li>
        </ol>
      </nav>
      <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-white/80 mb-4">Job Search</span>
      <h1 class="font-display text-[clamp(1.75rem,5vw,2.75rem)] leading-[1.1] text-white">LinkedIn Recruiter Finder</h1>
      <p class="mt-3 text-[1.0625rem] leading-[1.6] text-white/60">Find recruiters and hiring managers on LinkedIn. No Premium needed. One click to open results in Google.</p>
      <div class="mt-5 flex items-center gap-3">
        <img src="/images/izzy-coaching.jpg" alt="Izzy" class="w-9 h-9 rounded-full object-cover border-2 border-white/20" loading="eager" />
        <div><p class="text-sm font-medium text-white/90">Izzy Piyale-Sheard</p><p class="text-xs text-white/50">Career Coach, ClearCareer</p></div>
      </div>
    </div>
  </section>

  <section class="py-8 md:py-12">
    <div class="mx-auto max-w-[1100px] px-4 sm:px-6 lg:px-8">
      <XRaySearchCoaching client:visible />
    </div>
  </section>

  <section class="border-t border-border py-12 md:py-16">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="font-display text-[clamp(1.5rem,3vw,2rem)] leading-[1.15] text-navy">Frequently Asked Questions</h2>
      <div class="mt-8 space-y-4">
        {faqItems.map((item) => (
          <details class="group rounded-xl border border-border bg-white p-5 transition-shadow hover:shadow-sm">
            <summary class="cursor-pointer list-none text-base font-semibold text-navy [&::-webkit-details-marker]:hidden">
              <div class="flex items-center justify-between gap-4">
                <span>{item.question}</span>
                <svg class="h-5 w-5 flex-shrink-0 text-blue transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </div>
            </summary>
            <p class="mt-4 text-[0.9375rem] leading-[1.75] text-text-muted">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-blue-bg py-12 md:py-16">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="text-lg font-bold text-navy">Related Tools</h2>
      <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <a href="/free-tools/linkedin-job-search-builder" class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md">
          <span class="text-2xl">🔗</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">LinkedIn Job Search URL Builder</span>
        </a>
        <a href="/free-tools/networking-message-builder" class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md">
          <span class="text-2xl">💬</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">Networking Message Builder</span>
        </a>
      </div>
    </div>
  </section>

  <CTASection heading="Want a Complete Outreach Strategy?" body="The X-Ray search finds the people. Our program builds the messages, the follow-ups, and the system that gets replies." primaryCTA={{ text: "Book a Free Audit", href: "https://calendly.com/clearcareer/discovery-call" }} secondaryCTA={{ text: "Explore the Program", href: "/programs/jsis" }} variant="gradient" />
</PageLayout>
