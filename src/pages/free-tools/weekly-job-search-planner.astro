---
import PageLayout from "@layouts/PageLayout.astro";
import CTASection from "@components/CTASection.astro";
import WeeklyPlannerCoaching from "@components/tools/WeeklyPlannerCoaching";
import { generateWebApplicationSchema, generateBreadcrumbSchema, generateFAQSchema } from "@utils/seo";

const title = "Weekly Job Search Planner";
const description = "Get a personalized weekly job search plan. Allocates your time across networking, applications, interview prep, and more based on what actually works.";
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://joinclearcareer.com";
const toolUrl = `${siteUrl}/free-tools/weekly-job-search-planner`;

const faqItems = [
  { question: "How many hours per week should I spend job searching?", answer: "Full-time search: 25-35 hours. While employed: 10-15 hours. Consistency matters more than marathon sessions. 2 focused hours every day beats 10 hours on Saturday." },
  { question: "Why does networking get the most time?", answer: "70-80% of jobs are filled through networking and referrals. One good coffee chat can lead to a referral that skips the application pile entirely. It's the highest-ROI activity in a job search." },
  { question: "What if I'm currently employed and searching?", answer: "10-15 hours per week. Focus networking on evenings and weekends, applications during lunch or after work, and interview prep the night before. The planner adjusts to your available hours." },
  { question: "Should I adjust when interviews start coming in?", answer: "Yes. Shift 50-60% of your time to interview prep and company research, but keep networking and applying. Pipelines dry up. Multiple rounds at multiple companies is how you get leverage." },
  { question: "How long does a typical job search take?", answer: "3-6 months for mid-career roles in 2025-2026. 6-9 months for senior or executive positions. A structured, networking-heavy approach is typically 4-8 weeks faster than spray-and-pray applications." },
];
---

<PageLayout title={`${title} | ClearCareer`} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateWebApplicationSchema({ name: title, description, url: toolUrl, category: "BusinessApplication", featureList: ["Personalized time allocation", "5 activity categories", "Daily focus schedule", "Activity suggestions"] }))} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateBreadcrumbSchema([{ name: "Home", url: siteUrl }, { name: "Free Tools", url: `${siteUrl}/free-tools` }, { name: title, url: toolUrl }]))} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateFAQSchema(faqItems))} />

  <section class="relative overflow-hidden bg-navy py-12 md:py-16">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -right-20 -top-20 h-[300px] w-[300px] rounded-full bg-blue/10 blur-[80px]"></div>
    </div>
    <div class="relative mx-auto max-w-[640px] px-4 sm:px-6">
      <nav aria-label="Breadcrumb" class="mb-6 text-sm text-white/50">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-white/80 transition-colors">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/free-tools" class="hover:text-white/80 transition-colors">Free Tools</a></li>
          <li aria-hidden="true">/</li>
          <li class="truncate text-white/70" aria-current="page">Weekly Planner</li>
        </ol>
      </nav>
      <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-white/80 mb-4">Job Search</span>
      <h1 class="font-display text-[clamp(1.75rem,5vw,2.75rem)] leading-[1.1] text-white">Weekly Job Search Planner</h1>
      <p class="mt-3 text-[1.0625rem] leading-[1.6] text-white/60">Get a structured weekly plan that puts your hours where they actually matter. Based on 200+ coached job searches.</p>
      <div class="mt-5 flex items-center gap-3">
        <img src="/images/izzy-coaching.jpg" alt="Izzy" class="w-9 h-9 rounded-full object-cover border-2 border-white/20" loading="eager" />
        <div><p class="text-sm font-medium text-white/90">Izzy Piyale-Sheard</p><p class="text-xs text-white/50">Career Coach, ClearCareer</p></div>
      </div>
    </div>
  </section>

  <section class="py-8 md:py-12">
    <div class="mx-auto max-w-[1100px] px-4 sm:px-6 lg:px-8">
      <WeeklyPlannerCoaching client:visible />
    </div>
  </section>

  <section class="border-t border-border py-12 md:py-16">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="font-display text-[clamp(1.5rem,3vw,2rem)] leading-[1.15] text-navy">Frequently Asked Questions</h2>
      <div class="mt-8 space-y-4">
        {faqItems.map((item) => (
          <details class="group rounded-xl border border-border bg-white p-5 transition-shadow hover:shadow-sm">
            <summary class="cursor-pointer list-none text-base font-semibold text-navy [&::-webkit-details-marker]:hidden">
              <div class="flex items-center justify-between gap-4">
                <span>{item.question}</span>
                <svg class="h-5 w-5 flex-shrink-0 text-blue transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </div>
            </summary>
            <p class="mt-4 text-[0.9375rem] leading-[1.75] text-text-muted">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-blue-bg py-12 md:py-16">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="text-lg font-bold text-navy">Related Tools</h2>
      <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <a href="/free-tools/financial-runway-calculator" class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md">
          <span class="text-2xl">💰</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">Financial Runway Calculator</span>
        </a>
        <a href="/free-tools/resume-bullet-scorer" class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md">
          <span class="text-2xl">✅</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">Resume Bullet Scorer</span>
        </a>
      </div>
    </div>
  </section>

  <CTASection heading="Want the Full Job Search System?" body="The planner gives you structure. Our program gives you the assets, the coaching, and the accountability to execute it." primaryCTA={{ text: "Book a Free Audit", href: "https://calendly.com/clearcareer/discovery-call" }} secondaryCTA={{ text: "Explore the Program", href: "/programs/jsis" }} variant="gradient" />
</PageLayout>
