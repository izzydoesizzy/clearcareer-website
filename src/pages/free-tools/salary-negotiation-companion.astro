---
import PageLayout from "@layouts/PageLayout.astro";
import CTASection from "@components/CTASection.astro";
import SalaryNegotiationCompanion from "@components/tools/SalaryNegotiationCompanion";
import { generateWebApplicationSchema, generateBreadcrumbSchema, generateFAQSchema } from "@utils/seo";

const title = "Salary Negotiation Impact Calculator";
const description = "See how much one negotiation is worth over 1, 5, and 10 years. The compounding math that makes every negotiation worth it.";
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://joinclearcareer.com";
const toolUrl = `${siteUrl}/free-tools/salary-negotiation-companion`;

const faqItems = [
  { question: "Will negotiating get my offer rescinded?", answer: "In my experience coaching 200+ negotiations: zero rescinded offers. Companies expect negotiation. They budget for it. A professional, research-backed counter-offer signals confidence, not greed." },
  { question: "How much should I counter-offer?", answer: "10-20% above their initial offer is standard for most professional roles. Back it up with market data from Glassdoor, Levels.fyi, or Payscale. The number should be ambitious but defensible." },
  { question: "What if the company says 'the offer is final'?", answer: "Ask about other forms of compensation: signing bonus, extra PTO, remote work days, professional development budget, equity, or an earlier performance review (3 months instead of 12). Total compensation is more than base salary." },
  { question: "Should I negotiate base salary or total compensation?", answer: "Base salary first. Everything else compounds on your base: raises, bonuses (often a percentage of base), 401(k) match, and future offers. A higher base is the single most valuable thing you can negotiate." },
  { question: "When is the right time to negotiate?", answer: "After you have the written offer and before you sign. Never negotiate during interviews. Never negotiate verbally, always in writing (email). And never give your number first. Let them make the opening offer." },
];
---

<PageLayout title={`${title} — Companion Style | ClearCareer`} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateWebApplicationSchema({ name: title, description, url: toolUrl, category: "FinanceApplication" }))} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateBreadcrumbSchema([{ name: "Home", url: siteUrl }, { name: "Free Tools", url: `${siteUrl}/free-tools` }, { name: title, url: toolUrl }]))} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateFAQSchema(faqItems))} />

  <!-- Hero -->
  <section class="bg-navy py-8 sm:py-10">
    <div class="mx-auto max-w-[1100px] px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-4 text-xs text-white/40">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-white/70 transition-colors">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/free-tools" class="hover:text-white/70 transition-colors">Free Tools</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-white/60" aria-current="page">Salary Negotiation</li>
        </ol>
      </nav>
      <h1 class="font-display text-[clamp(1.5rem,4vw,2.25rem)] leading-[1.1] text-white">{title}</h1>
      <p class="mt-2 text-sm text-white/50 max-w-xl">
        Use the calculator alongside this guide to understand the compounding math behind every negotiation.
      </p>
    </div>
  </section>

  <!-- Two-Column Layout -->
  <section class="py-8 md:py-12">
    <div class="mx-auto max-w-[1100px] px-4 sm:px-6 lg:px-8">
      <SalaryNegotiationCompanion client:visible />
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-border py-12 md:py-16">
    <div class="mx-auto max-w-[720px] px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-[clamp(1.5rem,3vw,2rem)] leading-[1.15] text-navy">
        Frequently Asked Questions
      </h2>
      <div class="mt-8 space-y-4">
        {faqItems.map((item) => (
          <details class="group rounded-xl border border-border bg-white p-5 transition-shadow hover:shadow-sm">
            <summary class="cursor-pointer list-none text-base font-semibold text-navy [&::-webkit-details-marker]:hidden">
              <div class="flex items-center justify-between gap-4">
                <span>{item.question}</span>
                <svg class="h-5 w-5 flex-shrink-0 text-blue transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </summary>
            <p class="mt-4 text-[0.9375rem] leading-[1.75] text-text-muted">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Tools -->
  <section class="bg-blue-bg py-12 md:py-16">
    <div class="mx-auto max-w-[720px] px-4 sm:px-6 lg:px-8">
      <h2 class="text-lg font-bold text-navy">Related Tools</h2>
      <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <a href="/free-tools/contract-vs-salary-calculator" class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md">
          <span class="text-2xl">⚖️</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">Contract vs. Salary Calculator</span>
        </a>
        <a href="/free-tools/opportunity-cost-calculator" class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md">
          <span class="text-2xl">⏱️</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">Opportunity Cost Calculator</span>
        </a>
      </div>
    </div>
  </section>

  <CTASection
    heading="Want a Personalized Strategy for Your Job Search?"
    body="You've seen what one negotiation is worth. Imagine what a complete strategy could do."
    primaryCTA={{ text: "Book a Free Audit", href: "https://calendly.com/clearcareer/discovery-call" }}
    secondaryCTA={{ text: "Explore the Program", href: "/jsis" }}
    variant="gradient"
  />
</PageLayout>
