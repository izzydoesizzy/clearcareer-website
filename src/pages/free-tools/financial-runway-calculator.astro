---
import PageLayout from "@layouts/PageLayout.astro";
import RunwayStory from "@components/tools/RunwayStory";
import { generateWebApplicationSchema, generateBreadcrumbSchema, generateFAQSchema } from "@utils/seo";

const title = "Financial Runway Calculator";
const description = "Calculate how many months of runway you have before your savings run out. Factor in severance, unemployment, and side income.";
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://joinclearcareer.com";
const toolUrl = `${siteUrl}/free-tools/financial-runway-calculator`;

const faqItems = [
  { question: "What is financial runway?", answer: "Financial runway is the number of months you can cover your living expenses without a paycheck. It includes your savings, severance, unemployment benefits, and any side income, minus your monthly expenses." },
  { question: "How much savings should I have before quitting my job?", answer: "Most career coaches recommend 6 months of expenses as a minimum. If you're in a specialized field or targeting senior roles, 9-12 months gives you the freedom to be selective instead of desperate." },
  { question: "Should I include my partner's income in the calculation?", answer: "If your partner's income covers shared expenses, you can reduce your monthly burn rate by your share. Be conservative. Use the number you'd need if you were covering everything yourself, then adjust down." },
  { question: "What if I get severance?", answer: "Severance extends your runway directly. Enter the total amount (weeks x weekly pay) into the calculator. Remember: severance is taxed as regular income, so your take-home will be less than the gross amount." },
  { question: "How can I reduce my expenses during a job search?", answer: "Start with subscriptions and recurring charges. Pause what you don't need. Negotiate bills (internet, insurance, phone). Cook more. Cut discretionary spending by 20-30%. Small changes add months to your runway." },
  { question: "When should I start worrying about my runway?", answer: "When you hit 3 months of expenses remaining, shift into urgent mode. That means accepting a wider range of roles, ramping up applications, and considering contract or freelance work as a bridge." },
];
---

<PageLayout title={`${title} | ClearCareer`} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateWebApplicationSchema({ name: title, description, url: toolUrl, category: "FinanceApplication", featureList: ["Savings runway calculation", "Severance and unemployment offsets", "Monthly burn rate breakdown", "Start-searching date with safety buffer"] }))} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateBreadcrumbSchema([{ name: "Home", url: siteUrl }, { name: "Free Tools", url: `${siteUrl}/free-tools` }, { name: title, url: toolUrl }]))} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateFAQSchema(faqItems))} />

  <RunwayStory client:load />

  <!-- FAQ -->
  <section class="border-t border-border py-12 md:py-16 print:hidden">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="font-display text-[clamp(1.5rem,3vw,2rem)] leading-[1.15] text-navy">
        Frequently Asked Questions
      </h2>
      <div class="mt-8 space-y-4">
        {faqItems.map((item) => (
          <details class="group rounded-xl border border-border bg-white p-5 transition-shadow hover:shadow-sm">
            <summary class="cursor-pointer list-none text-base font-semibold text-navy [&::-webkit-details-marker]:hidden">
              <div class="flex items-center justify-between gap-4">
                <span>{item.question}</span>
                <svg class="h-5 w-5 flex-shrink-0 text-blue transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </summary>
            <p class="mt-4 text-[0.9375rem] leading-[1.75] text-text-muted">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Tools -->
  <section class="bg-blue-bg py-12 md:py-16 print:hidden">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="text-lg font-bold text-navy">Related Tools</h2>
      <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <a href="/free-tools/salary-negotiation-calculator" class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md">
          <span class="text-2xl">📈</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">Salary Negotiation Calculator</span>
        </a>
        <a href="/free-tools/severance-calculator" class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md">
          <span class="text-2xl">🧮</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">Canadian Severance Calculator</span>
        </a>
      </div>
    </div>
  </section>
</PageLayout>
