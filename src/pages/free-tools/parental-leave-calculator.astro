---
import PageLayout from "@layouts/PageLayout.astro";
import ParentalLeaveCalculator from "@components/tools/ParentalLeaveCalculator";
import { generateWebApplicationSchema, generateBreadcrumbSchema, generateFAQSchema } from "@utils/seo";

const title = "Canadian Parental Leave Calculator";
const description = "Calculate your family's EI or QPIP benefits during parental leave. Standard and extended plans, employer top-ups, sharing bonus, and week allocation for all provinces.";
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://joinclearcareer.com";
const toolUrl = `${siteUrl}/free-tools/parental-leave-calculator`;

const faqItems = [
  { question: "What's the difference between standard and extended parental leave?", answer: "Standard parental leave is 12 months at 55% of your insurable earnings (max $729/week). Extended parental leave is 18 months at 33% (max $437/week). The total payout is roughly the same, just spread over more weeks. Choose based on whether you need higher weekly income or more time off." },
  { question: "What is the sharing bonus?", answer: "The sharing bonus is extra weeks of benefits you unlock when both parents take parental leave. For standard leave, both parents need at least 5 weeks each to unlock 5 bonus weeks. For extended leave, the same threshold unlocks 8 bonus weeks. These are use-it-or-lose-it. Most families don't know they exist." },
  { question: "How is QPIP different from EI?", answer: "Quebec's QPIP (Quebec Parental Insurance Plan) pays higher replacement rates (70-75% vs. EI's 55%), has a higher insurable earnings cap ($103,000 vs. $68,900), covers self-employed workers automatically, and includes exclusive paternity leave weeks. Quebec families generally receive significantly higher benefits." },
  { question: "Can self-employed workers get parental leave benefits?", answer: "Outside Quebec, self-employed workers must opt into EI special benefits by registering with Service Canada and paying premiums for at least 12 months before their claim. In Quebec, self-employed workers are automatically covered by QPIP with no opt-in required." },
  { question: "What is an employer top-up?", answer: "Some employers 'top up' your EI or QPIP benefits to a percentage of your regular salary (commonly 75-95%) for a set number of weeks. This is an employment benefit, not a government program. Check your employer's parental leave policy or ask HR." },
  { question: "Do I need 600 hours to qualify?", answer: "For EI maternity and parental benefits, you need 600 insurable hours in the 52 weeks before your claim (or since your last claim). This is roughly 12 weeks of full-time work. Part-time hours count. Contact Service Canada to verify your hours." },
  { question: "Are these estimates accurate?", answer: "These are educational estimates based on 2026 EI and QPIP rates. Actual benefits depend on your specific insurable earnings, hours worked, and individual circumstances. Use the official Service Canada EI estimator or RQAP calculator for precise figures." },
];
---

<PageLayout title={`${title} | ClearCareer`} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateWebApplicationSchema({ name: title, description, url: toolUrl, category: "FinanceApplication", featureList: ["EI and QPIP benefit calculations for all provinces", "Standard and extended leave comparison", "Employer top-up configuration per parent", "Sharing bonus eligibility and optimization", "Visual timeline of leave phases", "Personalized financial recommendations"] }))} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateBreadcrumbSchema([{ name: "Home", url: siteUrl }, { name: "Free Tools", url: `${siteUrl}/free-tools` }, { name: title, url: toolUrl }]))} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateFAQSchema(faqItems))} />

  <!-- Story Arc Calculator -->
  <ParentalLeaveCalculator client:load />

  <!-- FAQ -->
  <section class="border-t border-border py-12 md:py-16">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="font-display text-[clamp(1.5rem,3vw,2rem)] leading-[1.15] text-navy">
        Frequently Asked Questions
      </h2>
      <div class="mt-8 space-y-4">
        {faqItems.map((item) => (
          <details class="group rounded-xl border border-border bg-white p-5 transition-shadow hover:shadow-sm">
            <summary class="cursor-pointer list-none text-base font-semibold text-navy [&::-webkit-details-marker]:hidden">
              <div class="flex items-center justify-between gap-4">
                <span>{item.question}</span>
                <svg class="h-5 w-5 flex-shrink-0 text-blue transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </summary>
            <p class="mt-4 text-[0.9375rem] leading-[1.75] text-text-muted">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Tools -->
  <section class="bg-blue-bg py-12 md:py-16">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="text-lg font-bold text-navy">Related Tools</h2>
      <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <a href="/free-tools/financial-runway-calculator" class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md">
          <span class="text-2xl">💰</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">Financial Runway Calculator</span>
        </a>
        <a href="/free-tools/severance-calculator" class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md">
          <span class="text-2xl">🧮</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">Canadian Severance Calculator</span>
        </a>
      </div>
    </div>
  </section>
</PageLayout>
