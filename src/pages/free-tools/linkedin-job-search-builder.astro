---
import PageLayout from "@layouts/PageLayout.astro";
import CTASection from "@components/CTASection.astro";
import JobSearchBuilderCoaching from "@components/tools/JobSearchBuilderCoaching";
import { generateWebApplicationSchema, generateBreadcrumbSchema, generateFAQSchema } from "@utils/seo";

const title = "LinkedIn Job Search URL Builder";
const description = "Build a filtered LinkedIn job search URL with your exact criteria. Bookmark it for one-click access to matching jobs every morning.";
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://joinclearcareer.com";
const toolUrl = `${siteUrl}/free-tools/linkedin-job-search-builder`;

const faqItems = [
  { question: "Can I save the URL as a bookmark?", answer: "Yes. That's the whole point. Add it to your bookmarks bar and open it every morning. You'll see fresh results with your exact filters already applied, no re-entering anything." },
  { question: "Why use a URL instead of LinkedIn's manual search?", answer: "Consistency and speed. A bookmarked URL gives you the exact same filtered results every time in one click. Manual search means re-entering your title, location, and filters every session." },
  { question: "How often should I run this search?", answer: "Daily if you're actively searching. Use the 'Past 24 hours' or 'Past week' filter to see only new postings. Most job boards refresh overnight." },
  { question: "Can I search for multiple job titles?", answer: "Yes. Separate titles with OR in the keywords field: 'Product Manager OR Program Manager OR Product Owner'. LinkedIn will match any of them." },
  { question: "What if LinkedIn changes their URL parameters?", answer: "LinkedIn rarely changes their URL structure. These parameters have been stable for years. If something breaks, the tool will be updated." },
];
---

<PageLayout title={`${title} | ClearCareer`} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateWebApplicationSchema({ name: title, description, url: toolUrl, category: "BusinessApplication", featureList: ["LinkedIn URL parameter builder", "Experience level filtering", "Date posted filtering", "Remote/hybrid/on-site filtering"] }))} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateBreadcrumbSchema([{ name: "Home", url: siteUrl }, { name: "Free Tools", url: `${siteUrl}/free-tools` }, { name: title, url: toolUrl }]))} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateFAQSchema(faqItems))} />

  <section class="relative overflow-hidden bg-navy py-12 md:py-16">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -right-20 -top-20 h-[300px] w-[300px] rounded-full bg-blue/10 blur-[80px]"></div>
    </div>
    <div class="relative mx-auto max-w-[640px] px-4 sm:px-6">
      <nav aria-label="Breadcrumb" class="mb-6 text-sm text-white/50">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-white/80 transition-colors">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/free-tools" class="hover:text-white/80 transition-colors">Free Tools</a></li>
          <li aria-hidden="true">/</li>
          <li class="truncate text-white/70" aria-current="page">Job Search URL Builder</li>
        </ol>
      </nav>
      <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-white/80 mb-4">Job Search</span>
      <h1 class="font-display text-[clamp(1.75rem,5vw,2.75rem)] leading-[1.1] text-white">LinkedIn Job Search URL Builder</h1>
      <p class="mt-3 text-[1.0625rem] leading-[1.6] text-white/60">Build a filtered search URL. Bookmark it. Check new jobs every morning in one click.</p>
      <div class="mt-5 flex items-center gap-3">
        <img src="/images/izzy-coaching.jpg" alt="Izzy" class="w-9 h-9 rounded-full object-cover border-2 border-white/20" loading="eager" />
        <div><p class="text-sm font-medium text-white/90">Izzy Piyale-Sheard</p><p class="text-xs text-white/50">Career Coach, ClearCareer</p></div>
      </div>
    </div>
  </section>

  <section class="py-8 md:py-12">
    <div class="mx-auto max-w-[1100px] px-4 sm:px-6 lg:px-8">
      <JobSearchBuilderCoaching client:visible />
    </div>
  </section>

  <section class="border-t border-border py-12 md:py-16">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="font-display text-[clamp(1.5rem,3vw,2rem)] leading-[1.15] text-navy">Frequently Asked Questions</h2>
      <div class="mt-8 space-y-4">
        {faqItems.map((item) => (
          <details class="group rounded-xl border border-border bg-white p-5 transition-shadow hover:shadow-sm">
            <summary class="cursor-pointer list-none text-base font-semibold text-navy [&::-webkit-details-marker]:hidden">
              <div class="flex items-center justify-between gap-4">
                <span>{item.question}</span>
                <svg class="h-5 w-5 flex-shrink-0 text-blue transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </div>
            </summary>
            <p class="mt-4 text-[0.9375rem] leading-[1.75] text-text-muted">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-blue-bg py-12 md:py-16">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="text-lg font-bold text-navy">Related Tools</h2>
      <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <a href="/free-tools/linkedin-recruiter-finder" class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md">
          <span class="text-2xl">🔍</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">LinkedIn Recruiter Finder</span>
        </a>
        <a href="/free-tools/weekly-job-search-planner" class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md">
          <span class="text-2xl">📅</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">Weekly Job Search Planner</span>
        </a>
      </div>
    </div>
  </section>

  <CTASection heading="Want a Complete Job Search Strategy?" body="The URL builder finds jobs. Our program builds the resume, outreach, and interview prep that gets you hired." primaryCTA={{ text: "Book a Free Audit", href: "https://calendly.com/clearcareer/discovery-call" }} secondaryCTA={{ text: "Explore the Program", href: "/programs/jsis" }} variant="gradient" />
</PageLayout>
