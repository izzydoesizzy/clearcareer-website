---
import PageLayout from "@layouts/PageLayout.astro";
import CTASection from "@components/CTASection.astro";
import SalaryNegotiationCalculator from "@components/tools/SalaryNegotiationCalculator";
import { generateWebApplicationSchema, generateBreadcrumbSchema, generateFAQSchema } from "@utils/seo";

const title = "Salary Negotiation Impact Calculator";
const description = "See how much one negotiation is worth over 1, 5, and 10 years. The compounding math that makes every negotiation worth it.";
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://joinclearcareer.com";
const toolUrl = `${siteUrl}/free-tools/salary-negotiation-calculator`;

const faqItems = [
  { question: "Will negotiating get my offer rescinded?", answer: "In my experience coaching 200+ negotiations: zero rescinded offers. Companies expect negotiation. They budget for it. A professional, research-backed counter-offer signals confidence, not greed." },
  { question: "How much should I counter-offer?", answer: "10-20% above their initial offer is standard for most professional roles. Back it up with market data from Glassdoor, Levels.fyi, or Payscale. The number should be ambitious but defensible." },
  { question: "What if the company says 'the offer is final'?", answer: "Ask about other forms of compensation: signing bonus, extra PTO, remote work days, professional development budget, equity, or an earlier performance review (3 months instead of 12). Total compensation is more than base salary." },
  { question: "Should I negotiate base salary or total compensation?", answer: "Base salary first. Everything else compounds on your base: raises, bonuses (often a percentage of base), 401(k) match, and future offers. A higher base is the single most valuable thing you can negotiate." },
  { question: "When is the right time to negotiate?", answer: "After you have the written offer and before you sign. Never negotiate during interviews. Never negotiate verbally, always in writing (email). And never give your number first. Let them make the opening offer." },
];
---

<PageLayout title={`${title} | ClearCareer`} description={description}>
  <!-- Structured Data -->
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(
      generateWebApplicationSchema({
        name: title,
        description,
        url: toolUrl,
        category: "FinanceApplication",
        featureList: ["Compound salary growth modeling", "1, 5, and 10 year projections", "Cumulative earnings difference", "Annual raise impact analysis"],
      })
    )}
  />
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(
      generateBreadcrumbSchema([
        { name: "Home", url: siteUrl },
        { name: "Free Tools", url: `${siteUrl}/free-tools` },
        { name: title, url: toolUrl },
      ])
    )}
  />
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(generateFAQSchema(faqItems))}
  />

  <!-- Hero (navy gradient) -->
  <section class="relative overflow-hidden bg-navy py-12 md:py-16">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -right-20 -top-20 h-[300px] w-[300px] rounded-full bg-blue/10 blur-[80px]"></div>
      <div class="absolute -bottom-20 -left-20 h-[200px] w-[200px] rounded-full bg-blue/5 blur-[60px]"></div>
    </div>
    <div class="relative mx-auto max-w-[640px] px-4 sm:px-6">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="mb-6 text-sm text-white/50">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-white/80 transition-colors">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/free-tools" class="hover:text-white/80 transition-colors">Free Tools</a></li>
          <li aria-hidden="true">/</li>
          <li class="truncate text-white/70" aria-current="page">Salary Negotiation</li>
        </ol>
      </nav>

      <div class="flex items-center gap-3 mb-4">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-white/80">
          Financial Planning
        </span>
        <span class="text-xs text-white/40">Updated April 2026</span>
      </div>

      <h1 class="font-display text-[clamp(1.75rem,5vw,2.75rem)] leading-[1.1] text-white">
        Salary Negotiation Impact Calculator
      </h1>
      <p class="mt-3 text-[1.0625rem] leading-[1.6] text-white/60">
        See how much one negotiation is worth over 1, 5, and 10 years. The compounding math that makes every negotiation worth it.
      </p>

      <!-- Izzy attribution -->
      <div class="mt-5 flex items-center gap-3">
        <img
          src="/images/izzy-coaching.jpg"
          alt="Izzy Piyale-Sheard"
          class="w-9 h-9 rounded-full object-cover border-2 border-white/20"
          loading="eager"
        />
        <div>
          <p class="text-sm font-medium text-white/90">Izzy Piyale-Sheard</p>
          <p class="text-xs text-white/50">Career Coach, ClearCareer</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Coach Block 1: Why This Matters -->
  <section class="py-8 md:py-10">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <div class="rounded-xl border-l-4 border-blue bg-blue-bg p-5 sm:p-6">
        <div class="flex gap-3 sm:gap-4 items-start">
          <img
            src="/images/izzy-coaching.jpg"
            alt="Izzy, Career Coach"
            class="w-8 h-8 rounded-full object-cover flex-shrink-0 mt-0.5"
            loading="lazy"
          />
          <div class="text-[0.9375rem] sm:text-[1rem] leading-[1.7] text-text space-y-3">
            <p>
              <strong class="text-navy">Here's what I tell every client before we start.</strong> 200+ coached negotiations. Zero rescinded offers. Average increase: $5,000 to $15,000. But a $10,000 bump isn't a $10,000 win. It compounds through every raise, bonus, and future offer. One conversation, six figures over a career.
            </p>
            <p>
              Plug in your numbers below and watch the gap widen year after year. Then decide if 15 minutes is worth $100,000+.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator (React Island) -->
  <section class="pb-8 md:pb-10">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <SalaryNegotiationCalculator client:visible />
    </div>
  </section>

  <!-- Coach Block 3: The Negotiation Playbook (Tips) -->
  <section class="py-8 md:py-10 border-t border-border">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="font-display text-[clamp(1.5rem,3vw,2rem)] leading-[1.15] text-navy">
        The Negotiation Playbook
      </h2>

      <div class="mt-6 space-y-5">
        <div class="rounded-xl border-l-4 border-blue bg-blue-bg p-5 sm:p-6">
          <div class="flex gap-3 sm:gap-4 items-start">
            <img
              src="/images/izzy-coaching.jpg"
              alt="Izzy, Career Coach"
              class="w-8 h-8 rounded-full object-cover flex-shrink-0 mt-0.5"
              loading="lazy"
            />
            <div class="text-[0.9375rem] sm:text-[1rem] leading-[1.7] text-text space-y-4">
              <p>
                <strong class="text-navy">Zero clients have had offers rescinded.</strong> Not one. Companies expect it. The only risk is leaving money on the table by not asking.
              </p>
              <p>
                <strong class="text-navy">Do your research first.</strong> Pull salary data from Glassdoor, Levels.fyi, and Payscale. Know the range for your role, level, and location before you counter.
              </p>
              <p>
                <strong class="text-navy">Always negotiate in writing.</strong> Email gives you time to craft your words and creates a paper trail.
              </p>
              <p>
                <strong class="text-navy">If base salary is "final," negotiate everything else.</strong> Signing bonus, extra PTO, remote flexibility, equity, or an accelerated review at 3 months instead of 12.
              </p>
            </div>
          </div>
        </div>

        <div class="rounded-lg border border-border bg-white p-5">
          <h3 class="text-base font-semibold text-navy">Related Reading</h3>
          <p class="mt-2 text-[0.9375rem] leading-[1.7] text-text-muted">
            Learn the full framework for negotiating any offer:
            <a href="/blog/always-negotiate-the-first-offer-is-never-the-final-offer" class="font-medium text-blue underline underline-offset-2 hover:text-blue-dark transition-colors">
              Always Negotiate: The First Offer Is Never the Final Offer
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-border py-12 md:py-16">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="font-display text-[clamp(1.5rem,3vw,2rem)] leading-[1.15] text-navy">
        Frequently Asked Questions
      </h2>
      <div class="mt-8 space-y-4">
        {faqItems.map((item) => (
          <details class="group rounded-xl border border-border bg-white p-5 transition-shadow hover:shadow-sm">
            <summary class="cursor-pointer list-none text-base font-semibold text-navy [&::-webkit-details-marker]:hidden">
              <div class="flex items-center justify-between gap-4">
                <span>{item.question}</span>
                <svg
                  class="h-5 w-5 flex-shrink-0 text-blue transition-transform group-open:rotate-180"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </summary>
            <p class="mt-4 text-[0.9375rem] leading-[1.75] text-text-muted">
              {item.answer}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Tools -->
  <section class="bg-blue-bg py-12 md:py-16">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="text-lg font-bold text-navy">Related Tools</h2>
      <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <a
          href="/free-tools/contract-vs-salary-calculator"
          class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md"
        >
          <span class="text-2xl">&#9878;&#65039;</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">Contract vs. Salary Calculator</span>
        </a>
        <a
          href="/free-tools/opportunity-cost-calculator"
          class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md"
        >
          <span class="text-2xl">&#9201;&#65039;</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">Opportunity Cost Calculator</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    heading="Want a Personalized Strategy for Your Job Search?"
    body="You've seen what one negotiation is worth. Imagine what a complete strategy could do."
    primaryCTA={{
      text: "Book a Free Audit",
      href: "https://calendly.com/clearcareer/discovery-call",
    }}
    secondaryCTA={{
      text: "Explore the Program",
      href: "/jsis",
    }}
    variant="gradient"
  />
</PageLayout>
