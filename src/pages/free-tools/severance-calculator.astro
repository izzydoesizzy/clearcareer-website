---
import ToolLayout from "@layouts/ToolLayout.astro";
import { SeveranceCalculator } from "@components/layoff-kit/SeveranceCalculator";
---

<ToolLayout
  title="Canadian Severance Calculator"
  headline="Canadian Severance Calculator"
  description="Estimate your severance under Canadian employment law. ESA statutory minimums and common-law Bardal factor estimates for all provinces. Free educational tool."
  category="Financial Planning"
  icon="🧮"
  relatedTags={["job search strategy", "salary negotiation"]}
  slug="severance-calculator"
  lastUpdated="April 2026"
  featureList={["ESA statutory minimum calculation", "Common-law Bardal factor estimates", "Province-specific rules for all Canadian provinces", "Age, tenure, and role-level weighting"]}
  faqItems={[
    { question: "Is this legal advice?", answer: "No. This calculator provides educational estimates based on general Canadian employment law precedent. Every situation is different. A valid termination clause in your contract may limit your severance. Consult an employment lawyer in your province before making any decisions." },
    { question: "What are the Bardal factors?", answer: "The Bardal factors are the criteria Canadian courts use to determine common-law (reasonable notice) severance: age, length of service, character of employment (seniority), and availability of similar employment. Older workers, longer-tenured employees, and senior professionals typically receive more." },
    { question: "What's the difference between ESA and common-law severance?", answer: "ESA (Employment Standards Act) severance is the statutory minimum your employer must pay. Common-law severance is what courts have awarded in similar cases and is almost always higher, especially for professionals earning $100K+. Your contract may contain a termination clause that limits you to the ESA amount." },
    { question: "Does this work for all provinces?", answer: "Yes. The calculator covers Ontario, BC, Alberta, Quebec, and federal jurisdiction. Provincial statutory rules differ, but the common-law Bardal factor analysis applies across Canada." },
    { question: "Should I negotiate my severance?", answer: "If your offer is below the common-law estimate, it's worth consulting an employment lawyer. Many offer free initial consultations. For professionals earning $100K+, the gap between the statutory minimum and common-law entitlement can be tens of thousands of dollars." },
  ]}
  relatedTools={[
    { name: "Financial Runway Calculator", slug: "financial-runway-calculator", icon: "💰" },
    { name: "Salary Negotiation Impact Calculator", slug: "salary-negotiation-calculator", icon: "📈" },
  ]}
>
  <!-- Disclaimer banner -->
  <div class="mb-6 rounded-xl border-2 border-amber-200 bg-amber-50 p-4">
    <p class="text-sm text-amber-800 leading-relaxed">
      <strong>This tool is not legal advice.</strong> It provides educational estimates based on general Canadian employment law precedent. Every situation is different. A valid termination clause in your contract may limit your severance. <strong>Consult an employment lawyer in your province before making any decisions about your severance package.</strong>
    </p>
  </div>

  <SeveranceCalculator client:load />

  <!-- Inline upgrade CTA -->
  <div slot="intro">
    <h2 class="text-xl font-bold text-navy">Want the full playbook?</h2>
    <div class="mt-4 space-y-4 text-[1.0625rem] leading-[1.75] text-text">
      <p>
        The calculator gives you a number. The <a href="/layoff-survival-kit" class="font-semibold text-blue hover:text-blue-dark underline">Layoff Survival Kit</a> gives you everything you need to act on it:
      </p>
      <ul class="space-y-2 text-[0.9375rem]">
        <li class="flex gap-2"><span class="text-success">&#10003;</span> Severance negotiation playbook with email scripts and counter-offer templates</li>
        <li class="flex gap-2"><span class="text-success">&#10003;</span> Curated employment lawyer directory (30+ firms, free consultation flags)</li>
        <li class="flex gap-2"><span class="text-success">&#10003;</span> Tax planning strategies to reduce withholding on your severance</li>
        <li class="flex gap-2"><span class="text-success">&#10003;</span> 30/60/90 day job search plan, LinkedIn guide, and 7 more complete modules</li>
      </ul>
      <p>
        <a href="/layoff-survival-kit" class="inline-block mt-2 bg-blue text-white font-semibold px-6 py-2.5 rounded-lg hover:bg-blue-dark transition-colors text-sm">
          See the Full Kit — $67 CAD
        </a>
      </p>
    </div>
  </div>

  <!-- Methodology -->
  <div slot="methodology">
    <h2 class="text-xl font-bold text-navy">How the Calculator Works</h2>
    <div class="mt-4 space-y-4 text-[1.0625rem] leading-[1.75] text-text">
      <p>
        The calculator produces two estimates: the <strong>ESA statutory minimum</strong> (what your province's employment standards legislation requires) and a <strong>common-law range</strong> (what courts have typically awarded in similar cases using the Bardal factors).
      </p>
      <p>
        The Bardal factors are: age, length of service, character of employment (how senior the role is), and availability of similar employment. The calculator weighs these factors to produce a range. Actual court awards vary widely based on individual circumstances.
      </p>
    </div>
  </div>
</ToolLayout>
