---
import PageLayout from "@layouts/PageLayout.astro";
import CTASection from "@components/CTASection.astro";
import BulletScorerCoaching from "@components/tools/BulletScorerCoaching";
import { generateWebApplicationSchema, generateBreadcrumbSchema, generateFAQSchema } from "@utils/seo";

const title = "Resume Bullet Point Scorer";
const description = "Paste a resume bullet point and get a score out of 5. Checks for action verbs, metrics, impact, length, and weak language.";
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://joinclearcareer.com";
const toolUrl = `${siteUrl}/free-tools/resume-bullet-scorer`;

const faqItems = [
  { question: "What makes a strong resume bullet point?", answer: "Five things: starts with an action verb, includes at least one number, shows impact (not just activity), is 10-30 words long, and uses no passive or weak language. Hit all 5 and your bullet is in the top 10% of what recruiters see." },
  { question: "How many bullet points should I have per job?", answer: "3-5 bullets for your most recent 2 roles, 2-3 for older roles. Total resume bullets should be 12-18. More than that and you're diluting your strongest points." },
  { question: "What are the best action verbs for resumes?", answer: "The strongest verbs show leadership and results: Led, Built, Launched, Delivered, Generated, Reduced, Increased, Negotiated, Designed, Implemented. Avoid: Helped, Assisted, Contributed, Participated, Responsible for." },
  { question: "How do I add metrics if my work wasn't measured?", answer: "Estimate. 'Roughly 20%' is better than nothing. Think about: How many people did you work with? How much time did you save? How many projects did you complete? What was the dollar value? If you truly can't quantify, describe the scope: 'for a team of 40' or 'across 3 departments.'" },
  { question: "Should resume bullets be full sentences or fragments?", answer: "Fragments. No 'I' at the start. No period at the end. Start with the action verb: 'Led 8-person team...' not 'I led an 8-person team.' This is a universal resume convention." },
];
---

<PageLayout title={`${title} | ClearCareer`} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateWebApplicationSchema({ name: title, description, url: toolUrl, category: "BusinessApplication", featureList: ["5-point scoring system", "Action verb detection", "Metrics and impact analysis", "Weak language flagging", "Word count optimization"] }))} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateBreadcrumbSchema([{ name: "Home", url: siteUrl }, { name: "Free Tools", url: `${siteUrl}/free-tools` }, { name: title, url: toolUrl }]))} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateFAQSchema(faqItems))} />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-navy py-12 md:py-16">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -right-20 -top-20 h-[300px] w-[300px] rounded-full bg-blue/10 blur-[80px]"></div>
    </div>
    <div class="relative mx-auto max-w-[640px] px-4 sm:px-6">
      <nav aria-label="Breadcrumb" class="mb-6 text-sm text-white/50">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-white/80 transition-colors">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/free-tools" class="hover:text-white/80 transition-colors">Free Tools</a></li>
          <li aria-hidden="true">/</li>
          <li class="truncate text-white/70" aria-current="page">Bullet Scorer</li>
        </ol>
      </nav>

      <div class="flex items-center gap-3 mb-4">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-white/80">
          Interview & Resume
        </span>
      </div>

      <h1 class="font-display text-[clamp(1.75rem,5vw,2.75rem)] leading-[1.1] text-white">
        Resume Bullet Point Scorer
      </h1>
      <p class="mt-3 text-[1.0625rem] leading-[1.6] text-white/60">
        Paste a bullet point and get an instant score out of 5. Real-time feedback on action verbs, metrics, impact, length, and weak language.
      </p>

      <div class="mt-5 flex items-center gap-3">
        <img src="/images/izzy-coaching.jpg" alt="Izzy" class="w-9 h-9 rounded-full object-cover border-2 border-white/20" loading="eager" />
        <div>
          <p class="text-sm font-medium text-white/90">Izzy Piyale-Sheard</p>
          <p class="text-xs text-white/50">Career Coach, ClearCareer</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator -->
  <section class="py-8 md:py-10">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <BulletScorerCoaching client:visible />
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-border py-12 md:py-16">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="font-display text-[clamp(1.5rem,3vw,2rem)] leading-[1.15] text-navy">
        Frequently Asked Questions
      </h2>
      <div class="mt-8 space-y-4">
        {faqItems.map((item) => (
          <details class="group rounded-xl border border-border bg-white p-5 transition-shadow hover:shadow-sm">
            <summary class="cursor-pointer list-none text-base font-semibold text-navy [&::-webkit-details-marker]:hidden">
              <div class="flex items-center justify-between gap-4">
                <span>{item.question}</span>
                <svg class="h-5 w-5 flex-shrink-0 text-blue transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </summary>
            <p class="mt-4 text-[0.9375rem] leading-[1.75] text-text-muted">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Tools -->
  <section class="bg-blue-bg py-12 md:py-16">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6">
      <h2 class="text-lg font-bold text-navy">Related Tools</h2>
      <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <a href="/free-tools/star-story-builder" class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md">
          <span class="text-2xl">⭐</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">STAR Story Builder</span>
        </a>
        <a href="/free-tools/linkedin-xray-search" class="group flex items-center gap-4 rounded-xl border border-border bg-white p-5 transition-all hover:border-blue/30 hover:shadow-md">
          <span class="text-2xl">🔍</span>
          <span class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">LinkedIn X-Ray Search</span>
        </a>
      </div>
    </div>
  </section>

  <CTASection
    heading="Want Your Entire Resume Rewritten by a Pro?"
    body="The scorer checks one bullet. Our program builds your complete resume with 15-20 quantified achievements."
    primaryCTA={{ text: "Book a Free Audit", href: "https://calendly.com/clearcareer/discovery-call" }}
    secondaryCTA={{ text: "Explore the Program", href: "/programs/jsis" }}
    variant="gradient"
  />
</PageLayout>
