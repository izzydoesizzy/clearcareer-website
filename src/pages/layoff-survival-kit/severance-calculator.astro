---
import BaseLayout from "@layouts/BaseLayout.astro";
import Footer from "@components/Footer.astro";
import { SeveranceCalculator } from "@components/layoff-kit/SeveranceCalculator";
---

<BaseLayout
  title="Free Severance Calculator (Canada) — ClearCareer"
  description="Estimate your severance under Canadian employment law. ESA statutory minimums and common-law Bardal factor estimates for all provinces. Free educational tool."
  type="website"
>
  <!-- Header -->
  <header class="border-b border-border">
    <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/layoff-survival-kit" class="text-sm font-semibold text-blue hover:text-blue-dark">&larr; Layoff Survival Kit</a>
      <a href="/" class="text-sm text-text-muted hover:text-text">ClearCareer</a>
    </div>
  </header>

  <!-- Disclaimer banner -->
  <div class="bg-amber-50 border-b border-amber-200">
    <div class="max-w-4xl mx-auto px-4 py-3">
      <p class="text-sm text-amber-800 leading-relaxed">
        <strong>This tool is not legal advice.</strong> It provides educational estimates based on general Canadian employment law precedent. Every situation is different. A valid termination clause in your contract may limit your severance. <strong>Consult an employment lawyer in your province before making any decisions about your severance package.</strong>
      </p>
    </div>
  </div>

  <main class="max-w-4xl mx-auto px-4 py-12 md:py-16">
    <div class="text-center mb-10">
      <p class="text-sm font-semibold text-blue uppercase tracking-wide mb-2">Free Educational Tool</p>
      <h1 class="font-display text-3xl md:text-4xl font-bold text-navy mb-4">Canadian Severance Calculator</h1>
      <p class="text-lg text-text-muted max-w-xl mx-auto">
        Get an estimate of your statutory minimum and what courts have typically awarded in similar situations. Use these numbers as a starting point for a conversation with your employment lawyer.
      </p>
    </div>

    <SeveranceCalculator client:load />

    <!-- CTA to full kit -->
    <div class="mt-16 border-t border-border pt-12">
      <div class="max-w-2xl mx-auto bg-blue-bg rounded-xl border border-blue/10 p-8">
        <h2 class="font-display text-2xl font-bold text-navy mb-3 text-center">Need more than a calculator?</h2>
        <p class="text-text-muted text-center max-w-lg mx-auto mb-6">
          The Layoff Survival Kit includes a severance negotiation playbook, tax planning strategies (to discuss with your CPA), a curated employment lawyer directory, LinkedIn optimization, and 10 complete guides for navigating a layoff in Canada.
        </p>
        <div class="text-center">
          <a href="/layoff-survival-kit" class="inline-block bg-blue text-white font-semibold px-8 py-3 rounded-lg hover:bg-blue-dark transition-colors">
            See the Full Kit — $67
          </a>
        </div>
        <div class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-3 text-center">
          <div class="text-xs text-text-muted"><span class="block font-semibold text-text">30+</span>Employment lawyers listed</div>
          <div class="text-xs text-text-muted"><span class="block font-semibold text-text">10</span>Complete guides</div>
          <div class="text-xs text-text-muted"><span class="block font-semibold text-text">All provinces</span>Canada-specific</div>
          <div class="text-xs text-text-muted"><span class="block font-semibold text-text">Lifetime</span>Access + updates</div>
        </div>
      </div>
      <p class="text-center text-sm text-text-muted mt-6">
        Or learn more about ClearCareer's <a href="/programs/jsis" class="text-blue underline hover:text-blue-dark">career coaching programs</a>
      </p>
    </div>
  </main>

  <!-- Footer disclaimer -->
  <footer class="border-t border-border bg-blue-bg py-6">
    <div class="max-w-3xl mx-auto px-4 text-xs text-text-muted leading-relaxed">
      <p>
        This calculator provides educational estimates only. It is not legal advice, tax advice, or financial advice. ClearCareer is a career coaching company, not a law firm. Estimates are based on general legal precedent (the Bardal factors framework) and statutory rules as of April 2026. Actual outcomes depend on your specific contract, circumstances, province, and many other factors. Government program details and rates are subject to change. Always consult an employment lawyer and CPA before making decisions about your severance.
      </p>
      <p class="mt-3 text-text-muted/60">&copy; {new Date().getFullYear()} ClearCareer. All rights reserved.</p>
    </div>
  </footer>
</BaseLayout>
