---
import PageLayout from "@layouts/PageLayout.astro";
import PromptViewer from "@components/vault/PromptViewer";
import InstallGuide from "@components/vault/InstallGuide";
import Stripe from "stripe";
import { readFileSync } from "fs";
import { join } from "path";

export const prerender = false;

// Verify payment via Stripe session
const sessionId = Astro.url.searchParams.get("session_id");
let buyerName = "";
let isValid = false;

const stripeKey = import.meta.env.STRIPE_SECRET_KEY;
if (stripeKey && sessionId) {
  try {
    const stripe = new Stripe(stripeKey);
    const session = await stripe.checkout.sessions.retrieve(sessionId);

    if (
      session.payment_status === "paid" &&
      session.metadata?.product === "vault"
    ) {
      isValid = true;
      buyerName = session.customer_details?.name?.split(" ")[0] || "";
    }
  } catch {
    // Invalid session ID — will show error page
  }
}

// Load prompt files (only if valid — no need to read files for error page)
const promptFileNames = [
  "01-resume-skills.md",
  "02-linkedin.md",
  "03-interview.md",
  "04-networking-outreach.md",
  "05-market-research.md",
  "06-negotiation-lifecycle.md",
];

let files: { filename: string; content: string }[] = [];
if (isValid) {
  files = promptFileNames.map((filename) => {
    const filePath = join(process.cwd(), "public/downloads/nova/prompts", filename);
    const content = readFileSync(filePath, "utf-8");
    return { filename, content };
  });
}
---

{isValid ? (
<PageLayout title="Career Prompt Vault — Your Access | ClearCareer" description="Your Career Prompt Vault: 50 AI career frameworks with copy buttons." noindex={true}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-blue-bg to-white pb-12 pt-12 md:pt-16">
    <div class="mx-auto max-w-[720px] px-4 text-center sm:px-6">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-success/10">
        <svg class="h-8 w-8 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
      </div>
      <h1 class="font-display text-[clamp(1.5rem,4vw,2.5rem)] text-navy">
        {buyerName ? `Welcome, ${buyerName}!` : "Your Career Prompt Vault"}
      </h1>
      <p class="mx-auto mt-3 max-w-lg text-base text-text-muted">50 AI career frameworks, ready to use. Browse them below, or download everything as files.</p>
    </div>
  </section>

  <!-- Setup Steps -->
  <section class="py-12">
    <div class="mx-auto max-w-[720px] px-4 sm:px-6">
      <h2 class="font-display text-xl text-navy">Set up in 5 minutes</h2>
      <div class="mt-6 space-y-5">
        {[
          { step: "1", title: "Create a free AI account", desc: "Go to claude.ai, chatgpt.com, or your preferred AI tool and sign up." },
          { step: "2", title: "Upload your resume", desc: "Add your resume (PDF, DOCX, or TXT) to the chat so the AI can reference your real experience." },
          { step: "3", title: "Copy a prompt below and paste it", desc: "Click the copy button on any prompt, paste it into your AI chat, replace the [brackets] with your details, and hit send." },
        ].map(item => (
          <div class="flex gap-4">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-blue text-sm font-bold text-white">{item.step}</div>
            <div><h3 class="font-semibold text-navy">{item.title}</h3><p class="mt-1 text-sm text-text-muted">{item.desc}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Installation Guide -->
  <section class="bg-blue-bg py-12">
    <div class="mx-auto max-w-[900px] px-4 sm:px-6">
      <h2 class="font-display text-xl text-navy mb-2">Installation Guide</h2>
      <p class="text-sm text-text-muted mb-8">Choose your preferred AI tool. We'll walk you through setup.</p>
      <div class="rounded-xl border border-border bg-white p-6 shadow-sm">
        <InstallGuide client:load />
      </div>
    </div>
  </section>

  <!-- Prompt Viewer -->
  <section class="py-12">
    <div class="mx-auto max-w-[900px] px-4 sm:px-6">
      <h2 class="font-display text-xl text-navy mb-2">Your Prompts</h2>
      <p class="text-sm text-text-muted mb-8">Click any prompt to expand it. Use the copy button to grab the text.</p>
      <PromptViewer client:load files={files} />
    </div>
  </section>

  <!-- Downloads -->
  <section class="bg-blue-bg py-12">
    <div class="mx-auto max-w-[720px] px-4 sm:px-6">
      <h2 class="font-display text-xl text-navy">Download Files</h2>
      <p class="mt-2 text-sm text-text-muted">Prefer to work offline? Download everything.</p>
      <div class="mt-6 space-y-3">
        <div class="rounded-xl border border-border bg-white p-4 shadow-sm">
          <div class="flex items-center justify-between">
            <div><h3 class="font-semibold text-navy">Project Instructions</h3><p class="mt-0.5 text-xs text-text-muted">System prompt for Claude Projects</p></div>
            <a href="/downloads/nova/nova-project-instructions.md" download class="shrink-0 rounded-lg border border-blue px-3 py-1.5 text-sm font-semibold text-blue hover:bg-blue-bg">Download</a>
          </div>
        </div>
        {promptFileNames.map(file => (
          <div class="rounded-xl border border-border bg-white p-4 shadow-sm">
            <div class="flex items-center justify-between">
              <h3 class="font-semibold text-navy text-sm">{file}</h3>
              <a href={`/downloads/nova/prompts/${file}`} download class="shrink-0 rounded-lg border border-blue px-3 py-1.5 text-sm font-semibold text-blue hover:bg-blue-bg">Download</a>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-6 text-center">
        <a href="/downloads/nova/nova-complete-bundle.zip" download class="inline-flex items-center gap-2 rounded-lg bg-blue px-6 py-3 text-sm font-bold text-white shadow-lg hover:bg-blue-dark">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
          Download Everything (.zip)
        </a>
      </div>
    </div>
  </section>

  <!-- Guides -->
  <section class="py-12">
    <div class="mx-auto max-w-[720px] px-4 sm:px-6">
      <h2 class="font-display text-xl text-navy">Guides</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-border bg-white p-5 shadow-sm"><h3 class="font-semibold text-navy">Setup Guide</h3><p class="mt-1 text-sm text-text-muted">Step-by-step instructions for Claude Projects setup.</p><a href="/downloads/nova/guides/setup-guide.md" download class="mt-3 inline-block text-sm font-semibold text-blue hover:text-blue-dark">Download &rarr;</a></div>
        <div class="rounded-xl border border-border bg-white p-5 shadow-sm"><h3 class="font-semibold text-navy">Quick Start: First 30 Minutes</h3><p class="mt-1 text-sm text-text-muted">4 quick wins you can generate in your first session.</p><a href="/downloads/nova/guides/quick-start.md" download class="mt-3 inline-block text-sm font-semibold text-blue hover:text-blue-dark">Download &rarr;</a></div>
      </div>
    </div>
  </section>

  <!-- Bonuses -->
  <section class="bg-blue-bg py-12">
    <div class="mx-auto max-w-[720px] px-4 sm:px-6">
      <h2 class="font-display text-xl text-navy">Bonus Resources</h2>
      <div class="mt-6 space-y-3">
        {[
          { title: "AI Job Search Prompt Pack", desc: "15 copy-paste prompts for every stage of your search.", file: "bonus-ai-job-search-prompt-pack.md" },
          { title: "Salary Research Prompt Pack", desc: "7 prompts for finding real salary data.", file: "bonus-salary-research-prompt-pack.md" },
          { title: '"Tell Me About Yourself" Guide', desc: "The 5-part framework for the most common interview question.", file: "bonus-tell-me-about-yourself-guide.md" },
        ].map(bonus => (
          <div class="flex items-center justify-between rounded-xl border border-border bg-white p-4 shadow-sm">
            <div class="min-w-0 pr-4"><h3 class="font-semibold text-navy">{bonus.title}</h3><p class="mt-0.5 text-xs text-text-muted">{bonus.desc}</p></div>
            <a href={`/downloads/nova/${bonus.file}`} download class="shrink-0 rounded-lg border border-success px-3 py-1.5 text-sm font-semibold text-success hover:bg-success/5">Bonus</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Upsell CTA -->
  <section class="relative overflow-hidden py-12" style="background: linear-gradient(135deg, #0161EF 0%, #0450c8 50%, #030620 100%);">
    <div class="relative mx-auto max-w-[720px] px-4 text-center sm:px-6">
      <p class="text-sm font-medium uppercase tracking-wider text-blue-100">Want more than prompts?</p>
      <h2 class="mt-3 font-display text-[clamp(1.25rem,3vw,2rem)] text-white">The Job Search Ignition System</h2>
      <p class="mx-auto mt-4 max-w-lg text-base leading-relaxed text-blue-100">The Career Prompt Vault gives you the frameworks. The full 8-week program gives you done-for-you resume and LinkedIn rewrites, 1:1 coaching, and personalized strategy.</p>
      <a href="/programs/jsis" class="mt-8 inline-flex items-center justify-center rounded-lg bg-white px-8 py-3.5 text-base font-semibold text-blue hover:bg-gray-100 hover:shadow-lg">Learn about the full program</a>
    </div>
  </section>
</PageLayout>
) : (
<PageLayout title="Access Not Found — ClearCareer" description="Career Prompt Vault access page." noindex={true}>
  <div class="min-h-screen bg-white flex items-center justify-center">
    <div class="max-w-md mx-auto px-4 text-center">
      <h1 class="font-display text-2xl font-bold text-navy mb-4">Access not found</h1>
      <p class="text-text-muted mb-6">
        This access link is invalid or the payment hasn't been confirmed yet.
        If you recently purchased the Career Prompt Vault, check your email
        for the correct access link. It may take a few minutes to arrive.
      </p>
      <div class="space-y-3">
        <a href="/tools/career-prompt-vault" class="inline-block bg-blue text-white font-semibold px-6 py-2.5 rounded-lg hover:bg-blue-dark transition-colors text-sm">
          View the Career Prompt Vault
        </a>
        <p class="text-xs text-text-muted">
          Need help? <a href="mailto:izzy@joinclearcareer.com" class="text-blue underline">izzy@joinclearcareer.com</a>
        </p>
      </div>
    </div>
  </div>
</PageLayout>
)}
