---
import PageLayout from "@layouts/PageLayout.astro";
import Hero from "@components/Hero.astro";
import CTASection from "@components/CTASection.astro";

const resources = [
  {
    icon: "💰",
    title: "2026 Canadian Salary Guide",
    description: "50 in-demand roles across Toronto, Vancouver, Calgary, Montreal, and Ottawa. Entry, mid, and senior ranges.",
    tag: "Interactive Guide",
    href: "/resources/2026-salary-guide",
  },
  {
    icon: "🔑",
    title: "40 Job Titles That Pay $100K+",
    description: "Non-obvious roles you've never heard of, with who's hiring and direct search links.",
    tag: "Research Guide",
    href: "/resources/hidden-job-titles",
  },
  {
    icon: "🏠",
    title: "194 Canadian Remote & Hybrid Companies",
    description: "Verified remote policies across 14 industries with direct links to careers pages.",
    tag: "Company List",
    href: "/resources/canadian-remote-companies",
  },
  {
    icon: "🆘",
    title: "The Layoff Survival Kit",
    description: "25 Canada-specific steps for the first 72 hours after being let go. EI, severance, legal rights.",
    tag: "Checklist",
    href: "/resources/layoff-survival-kit",
  },
  {
    icon: "🔎",
    title: "LinkedIn Boolean Search Cheat Sheet",
    description: "30 copy-paste search strings to find the right people at your target companies.",
    tag: "Cheat Sheet",
    href: "/resources/linkedin-boolean-search",
  },
  {
    icon: "📊",
    title: "1,600+ Quantified Resume Achievements",
    description: "Copy-paste achievement bullets for 80+ job titles across 16 industries.",
    tag: "Google Sheet",
    href: "/resources/quantified-achievements",
  },
  {
    icon: "🏦",
    title: "86 Canadian Banking & Fintech Companies",
    description: "Banks, fintechs, and financial institutions hiring in Canada.",
    tag: "Google Sheet",
    href: "/resources/canadian-banking-fintech-companies",
  },
  {
    icon: "📧",
    title: "7 Email Templates for Job Seekers",
    description: "Informational interviews, hiring managers, thank-yous, follow-ups, and salary negotiation.",
    tag: "Templates",
    href: "/resources/email-templates",
  },
  {
    icon: "🎨",
    title: "33 Free LinkedIn Banners",
    description: "Solids, gradients, and patterns. Pre-sized. Upload in 60 seconds.",
    tag: "Image Pack",
    href: "/resources/linkedin-banners",
  },
  {
    icon: "📸",
    title: "DIY LinkedIn Headshot Guide",
    description: "Take a professional headshot at home with your phone. 7-page PDF.",
    tag: "PDF Guide",
    href: "/resources/linkedin-headshot-guide",
  },
  {
    icon: "🔍",
    title: "Free LinkedIn Audit",
    description: "Send me screenshots of your profile. I'll send back a personalized PDF.",
    tag: "Personalized",
    href: "https://www.linkedin.com/in/izzydoesizzy/",
    external: true,
  },
  {
    icon: "📈",
    title: "AI Salary Research Report",
    description: "Your target role + city = anchor, target, and walk-away numbers.",
    tag: "Personalized",
    href: "https://www.linkedin.com/in/izzydoesizzy/",
    external: true,
  },
];
---

<PageLayout
  title="Free Career Resources | ClearCareer"
  description="Free tools, templates, and guides to level up your job search. Resume achievement bullets, LinkedIn banners, headshot guide, and more."
>
  <Hero
    variant="page"
    eyebrow="Free Resources"
    headline="Everything You Need to Level Up Your Job Search"
    subheadline="Each resource is pulled directly from the ClearCareer coaching program. Grab one, grab them all."
  />

  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-[720px] px-4 sm:px-6">
      <div class="divide-y divide-border">
        {resources.map((r) => (
          <a
            href={r.href}
            target={r.external ? '_blank' : undefined}
            rel={r.external ? 'noopener noreferrer' : undefined}
            class="group flex items-center gap-4 py-5 transition-colors first:pt-0 last:pb-0"
          >
            <div class="text-2xl">{r.icon}</div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                <h3 class="text-sm font-semibold text-navy group-hover:text-blue transition-colors">{r.title}</h3>
                <span class="rounded-full bg-blue-bg px-2 py-0.5 text-[10px] font-semibold text-blue leading-tight">
                  {r.tag}
                </span>
              </div>
              <p class="mt-0.5 text-sm text-text-muted">{r.description}</p>
            </div>
            <svg class="h-4 w-4 shrink-0 text-text-muted/50 transition-all group-hover:text-blue group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    heading="Want Personalized Guidance?"
    body="Free resources are great, but nothing beats working with a coach who knows your situation."
    primaryCTA={{ text: "Book a Free Audit", href: "https://calendly.com/clearcareer/discovery-call" }}
    secondaryCTA={{ text: "See the Program", href: "/programs/jsis" }}
    variant="blue"
  />
</PageLayout>
