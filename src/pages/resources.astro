---
import PageLayout from "@layouts/PageLayout.astro";
import Hero from "@components/Hero.astro";
import CTASection from "@components/CTASection.astro";

const leadMagnets = [
  {
    icon: "🔍",
    title: "Free LinkedIn Audit",
    description: "Send me 2-3 screenshots of your LinkedIn profile and I'll send you a personalized PDF showing exactly what's holding you back and what to fix.",
    howToGet: "DM me AUDIT on LinkedIn",
    ctaText: "Message Izzy on LinkedIn",
    ctaHref: "https://www.linkedin.com/in/izzypiyalesheard/",
    highlight: true,
  },
  {
    icon: "💰",
    title: "AI Salary Research Report",
    description: "Tell me your target role and city. I'll generate a report with anchor, target, and walk-away numbers backed by real market data.",
    howToGet: "DM me SALARY on LinkedIn",
    ctaText: "Message Izzy on LinkedIn",
    ctaHref: "https://www.linkedin.com/in/izzypiyalesheard/",
    highlight: false,
  },
  {
    icon: "📧",
    title: 'The "27 Emails" Playbook',
    description: "The exact framework one client used to land a job with 27 targeted emails after 220 applications got zero results. Three fill-in-the-blank templates included.",
    howToGet: "DM me METHOD on LinkedIn",
    ctaText: "Get the Playbook",
    ctaHref: "#email-gate-method",
    highlight: false,
  },
  {
    icon: "📊",
    title: "Achievement Quantifier Worksheet",
    description: "Turn vague resume bullets into quantified achievements that get interviews. Includes the XYZ format and 5 real client examples.",
    howToGet: "DM me NUMBERS on LinkedIn",
    ctaText: "Get the Worksheet",
    ctaHref: "#email-gate-numbers",
    highlight: false,
  },
];
---

<PageLayout
  title="Free Career Resources | ClearCareer"
  description="Free LinkedIn audit, salary research report, email playbook, and achievement quantifier. Real tools that help you land faster."
>
  <!-- Hero -->
  <Hero
    variant="page"
    eyebrow="Free Resources"
    headline="Four Free Tools to Jump-Start Your Search"
    subheadline="Each one is pulled directly from the ClearCareer coaching program. Grab one, grab all four."
  />

  <!-- Lead Magnets -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[1080px] px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        {leadMagnets.map((lm) => (
          <div class:list={[
            "rounded-xl border p-8 transition-shadow duration-300 hover:shadow-[0_8px_40px_-4px_rgba(1,97,239,0.18)]",
            lm.highlight
              ? "border-blue bg-white shadow-[0_4px_24px_-4px_rgba(1,97,239,0.15)] ring-2 ring-blue"
              : "border-border bg-white shadow-[0_4px_24px_-4px_rgba(1,97,239,0.10)]",
          ]}>
            <div class="mb-4 text-3xl">{lm.icon}</div>
            <h3 class="text-xl font-semibold text-navy">{lm.title}</h3>
            <p class="mt-3 text-[1.0625rem] leading-[1.75] text-text-muted">
              {lm.description}
            </p>
            <p class="mt-4 text-sm font-medium text-blue">
              {lm.howToGet}
            </p>
            <a
              href={lm.ctaHref}
              target={lm.ctaHref.startsWith('http') ? '_blank' : undefined}
              rel={lm.ctaHref.startsWith('http') ? 'noopener noreferrer' : undefined}
              class:list={[
                "mt-6 inline-block rounded-lg px-6 py-3 text-center font-semibold transition-colors",
                lm.highlight
                  ? "bg-blue text-white hover:bg-blue-dark"
                  : "border-2 border-blue bg-white text-blue hover:bg-blue-bg",
              ]}
            >
              {lm.ctaText}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Email Gate for PDFs -->
  <section class="bg-blue-bg py-16 md:py-24" id="email-gate-method">
    <div class="mx-auto max-w-[640px] px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-[clamp(1.5rem,3vw,2.25rem)] leading-[1.15] text-navy">
        Get the free resources
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-text-muted">
        Enter your email and I'll send you the "27 Emails" Playbook and the Achievement Quantifier Worksheet. Plus one career tip per week. No spam.
      </p>
      <form class="mx-auto mt-8 flex max-w-md flex-col gap-3 sm:flex-row" id="resource-email-form">
        <label for="resource-email" class="sr-only">Email address</label>
        <input
          id="resource-email"
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          class="flex-1 rounded-lg border border-border bg-white px-4 py-3 text-text placeholder:text-text-muted focus:border-blue focus:outline-none focus:ring-2 focus:ring-blue/20"
        />
        <button
          type="submit"
          class="rounded-lg bg-blue px-6 py-3 font-semibold text-white transition-colors hover:bg-blue-dark"
        >
          Send me the PDFs
        </button>
      </form>
      <p class="mt-3 text-xs text-text-muted">Unsubscribe anytime. I respect your inbox.</p>
    </div>
  </section>
  <span id="email-gate-numbers"></span>

  <!-- CTA -->
  <CTASection
    heading="Want Personalized Guidance?"
    body="Free resources are great, but nothing beats working with a coach who knows your situation."
    primaryCTA={{ text: "Book a Free Audit", href: "https://calendly.com/clearcareer/discovery-call" }}
    secondaryCTA={{ text: "See the Program", href: "/programs/jsis" }}
    variant="blue"
  />
</PageLayout>

<script>
  // Kit email capture for lead magnets
  // Replace FORM_ID with your actual Kit form ID from https://app.kit.com/forms
  const KIT_RESOURCE_FORM_ID = 'YOUR_KIT_FORM_ID';

  document.getElementById('resource-email-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = form.querySelector('button[type="submit"]');
    const input = form.querySelector('input[type="email"]') as HTMLInputElement;
    const email = input?.value;

    if (!email || !btn) return;

    if (KIT_RESOURCE_FORM_ID === 'YOUR_KIT_FORM_ID') {
      btn.textContent = 'Setup needed';
      btn.setAttribute('disabled', 'true');
      btn.classList.add('opacity-60', 'cursor-not-allowed');
      return;
    }

    btn.textContent = 'Sending...';
    btn.setAttribute('disabled', 'true');

    try {
      const res = await fetch(`https://app.kit.com/forms/${KIT_RESOURCE_FORM_ID}/subscriptions`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email_address: email }),
      });

      if (res.ok) {
        btn.textContent = 'Check your inbox!';
        btn.classList.add('opacity-60', 'cursor-not-allowed');
        input.value = '';
      } else {
        btn.textContent = 'Try again';
        btn.removeAttribute('disabled');
      }
    } catch {
      btn.textContent = 'Try again';
      btn.removeAttribute('disabled');
    }
  });
</script>
